  },
  {
   "kind": 2,
   "value": "findDotProductEffectivePhotonNumbers[]:=(\r\nnPhotonAvg=First[nPhotonAvgList];\r\nnPhotonEff=nPhotonAvg*getDotToIdeal[dat,meanTrace];\r\n) ",
