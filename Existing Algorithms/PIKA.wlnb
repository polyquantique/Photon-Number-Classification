  {
   "kind": 2,
   "value": "findInitialObjectiveFunction[]:=(\r\nsqDevOfClust=getSqDevOfClust[dat,iObsOfClust,clustMeanTrace];\r\nnOfClust=Map[Length,iObsOfClust];\r\nlogLikeProb=probComboLogLikelihood[nPhotonOfClust,nOfClust,nPhotonAvg];\r\nsigmaObjFtn=Sqrt[Total[sqDevOfClust]/nObs]//N;\r\nprint[iNPhotonAvgList,\"PIKA: sigmaObjFtn \",sigmaObjFtn];\r\nsigmaObjFtn=Table[sigmaObjFtn,{nClust}];\r\n\r\nobjFtn=getObjFtn[sqDevOfClust,sigmaObjFtn,logLikeProb];\r\nprintSp[iNPhotonAvgList,\"\",\"Initial objective function: \",objFtn];\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820441942,
     "endTime": 1690820442036
    },
    "executionOrder": 180,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "graphClusterDeviationsFromMean[]:=(\r\np7=ListPlot[pair[nPhotonOfClust,Sqrt[ sqDevOfClust /nOfClust]],\r\nAxesOrigin->{\r\nFloor[Min[nPhotonOfClust],10],\r\nFloor[Min[Sqrt[ sqDevOfClust /nOfClust]],10]\r\n},\r\nJoined->False,\r\nPlotStyle->PointSize[0.015],\r\nFrameLabel->{\"Number of photons n\",\"RMS deviation (Voltage input units)\"},\r\nPlotLabel->\"RMS deviations of clusters to their means\",\r\nImageSize->outputImageSize\r\n];\r\nprintSp[iNPhotonAvgList,\"Cluster Deviations\",\"Before optimization:\"];\r\noutputAdd[p7,iNPhotonAvgList,\"Cluster Deviations\"];\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442036,
     "endTime": 1690820442113
    },
    "executionOrder": 181,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "prepareOptimizationLoop[]:=(\r\n\r\nIf[Sort[Flatten[iObsOfClust]]!= Range[Length[dat]],\r\nprint[iNPhotonAvgList,\"PIKA: WARNING: iObsOfClust does not map each observation to a cluster\"]\r\n];\r\niClustOfObs=getIClustOfObs[iObsOfClust];\r\nIf[Min[iClustOfObs]<= 0,\r\nprint[iNPhotonAvgList,\"PIKA: WARNING: iClustOfObs does not map each observation to a cluster\"]\r\n];\r\n\r\nneighborOfClust=pair[Range[nClust]-1,Range[nClust]+1];\r\nneighborOfClust[[1]]=Drop[neighborOfClust[[ 1]],1];\r\nneighborOfClust[[-1]]=Drop[neighborOfClust[[-1]],-1];\r\n\r\nkMove=0;(* count of moves made *)\r\nbirthOfClust=Table[0,{nClust}];\r\nbirthOfObsClust=Table[-1,{nObs},{nClust}];(* older than birthOfClust *)\r\nsqDevOfObsClust=birthOfObsClust (* dummy array of correct shape *)\r\n\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442113,
     "endTime": 1690820442191
    },
    "executionOrder": 182,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "prepareSubLoop[]:=(\r\niObsAll=RandomSample[Range[nObs]];\r\nprintSp[iNPhotonAvgList,\"Detailed Log\",\"Mean \",iNPhotonAvgList,\", round \",iCool,\r\n\": kMove \",kMove,\" logLikeProb \",logLikeProb,\r\n\" objFtn \",objFtn,\" TimeUsed \",TimeUsed[]-tStart];\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442191,
     "endTime": 1690820442284
    },
    "executionOrder": 183,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "getClusterAndNeighbors[]:=(\r\niObs=iObsAll[[jObs]];\r\niClust=iClustOfObs [[ iObs ]];\r\nIf[nOfClust[[iClust]]<= 1,Continue[]];\r\nneighbor=neighborOfClust[[ iClust ]];\r\njClust=neighbor[[ RandomInteger[{1,Length[neighbor]}] ]]\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442284,
     "endTime": 1690820442393
    },
    "executionOrder": 184,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "updateRelevantDeviations[]:=(\r\nIf[birthOfObsClust[[iObs,iClust]]<birthOfClust[[iClust]],\r\nsqDevOfObsClust[[iObs,iClust]]=meanSquare[dat[[iObs]] - clustMeanTrace[[iClust]]];\r\nbirthOfObsClust[[iObs,iClust]]=kMove\r\n];\r\nIf[birthOfObsClust[[iObs,jClust]]<birthOfClust[[jClust]],\r\nsqDevOfObsClust[[iObs,jClust]]=meanSquare[dat[[iObs]] - clustMeanTrace[[jClust]]];\r\nbirthOfObsClust[[iObs,jClust]]=kMove\r\n]\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442393,
     "endTime": 1690820442488
    },
    "executionOrder": 185,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "findChangeInObjectiveFunction[]:=(\r\ndeltaI=deltaKMeansDel[nOfClust[[iClust]],sqDevOfObsClust[[iObs,iClust]]];\r\ndeltaJ=deltaKMeansAdd[nOfClust[[jClust]],sqDevOfObsClust[[iObs,jClust]]];\r\ndeltaKMeansScaled=deltaJ/(2*sigmaObjFtn[[jClust]]^2) - deltaI/(2*sigmaObjFtn[[iClust]]^2);\r\ndeltaProb=If[jClust<iClust,\r\ndeltaPoissonDn[nPhotonOfClust[[iClust]],nOfClust[[jClust]],nOfClust[[iClust]],nPhotonAvg],\r\ndeltaPoissonUp[nPhotonOfClust[[iClust]],nOfClust[[jClust]],nOfClust[[iClust]],nPhotonAvg]\r\n];\r\ndeltaObjFtn=deltaKMeansScaled - deltaProb;\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442488,
     "endTime": 1690820442580
    },
    "executionOrder": 186,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "decideWhetherToMove[]:=(\r\nacceptMove=If[deltaObjFtn<0,\r\nTrue,\r\nIf[iCool > nGreedy,\r\nRandomReal[]<Exp[-deltaObjFtn/tAnneal],\r\nFalse\r\n]\r\n]\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442580,
     "endTime": 1690820442658
    },
    "executionOrder": 187,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "updateIfMoving[]:=(\r\nIf[acceptMove, (* transfer a trace from cluster i to cluster j *)\r\nprintSp[iNPhotonAvgList,\"Detailed Log\",\"   Round \",iCool,\", observation \",iObs,\": deltaObjFtn \",deltaObjFtn,\" from \",iClust,\" to \",jClust];\r\nkMove++;\r\nbirthOfClust[[iClust]]=kMove;\r\nclustMeanTrace[[iClust]]=newMeanTraceDel[nOfClust[[iClust]],clustMeanTrace[[iClust]],dat[[iObs]]];\r\nnOfClust[[iClust]]--;\r\nbirthOfClust[[jClust]]=kMove;\r\nclustMeanTrace[[jClust]]=newMeanTraceAdd[nOfClust[[jClust]],clustMeanTrace[[jClust]],dat[[iObs]]];\r\nnOfClust[[jClust]]++;\r\niClustOfObs[[iObs]]=jClust;\r\nsqDevOfClust[[iClust]] -= deltaI;\r\nsqDevOfClust[[jClust]] += deltaJ;\r\nobjFtn += deltaObjFtn;\r\n]\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442659,
     "endTime": 1690820442752
    },
    "executionOrder": 188,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "updateAnnealingTemperature[]:=(\r\ntAnneal*= coolConst\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820442752,
     "endTime": 1690820442843
