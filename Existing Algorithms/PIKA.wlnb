  {
   "kind": 2,
   "value": "createInitialClusters[]:=(\r\nnPhotonAvg=nPhotonAvgList[[iNPhotonAvgList]];\r\n{prob,nPhotonOfClust,iObsOfClust,clustMeanTrace}=groupProbability[dat,nPhotonAvg,nPhotonEff,nSigma];\r\nnClust=Length[clustMeanTrace];\r\nprint[iNPhotonAvgList,\"PIKA: nClust \",nClust];\r\nprintSp[iNPhotonAvgList,\"\",\"Initial mean photon number: \",nPhotonAvg];\r\n) ",
   "languageId": "wolfram",
