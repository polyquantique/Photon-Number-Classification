  {
   "kind": 2,
   "value": "poisson[mu_,nSigma_]:=Module[\r\n{sigma,tab},\r\nsigma=Sqrt[mu];\r\ntab=Table[{n,(N[Exp[-mu]]*mu^n)/n!},{n,Max[Floor[mu-sigma*nSigma],0],Ceiling[mu+sigma*nSigma]}];\r\nMap[{First[#],Last[#]/Total[tab[[All,2]]]}&,tab]\r\n] ",
   "languageId": "wolfram",
   "outputs": [],
