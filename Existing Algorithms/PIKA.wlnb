  {
   "kind": 2,
   "value": "graphNewClusterToMeanDeviations[]:=(\r\nsqDevClustClust=getSqDevClustClust[dat,iObsOfClustNew,clustMeanTrace];\r\nsqrtsdccDiag=Table[\r\n{nPhotonOfClust[[iClust]],\r\nSqrt[sqDevClustClust[[iClust,iClust]]]},\r\n{iClust,nClust}];\r\nsqrtsdccUDiag=Table[\r\n{nPhotonOfClust[[iClust]],\r\nSqrt[sqDevClustClust[[iClust,iClust+1]]]},\r\n{iClust,nClust-1}];\r\nsqrtsdccLDiag=Table[\r\n{nPhotonOfClust[[iClust]],\r\nSqrt[sqDevClustClust[[iClust,iClust-1]]]},\r\n{iClust,2,nClust}];\r\n\r\np13=ListPlot[{sqrtsdccDiag,sqrtsdccLDiag,sqrtsdccUDiag},PlotStyle->{Red,Green,Blue},\r\nJoined->True,Frame->True,\r\nPlotLabel->\"RMS deviation of cluster traces to means of clusters: R: same; G: +1; B: -1\",\r\nFrameLabel->{\"Cluster\",\"RMS deviation (input voltage units)\"},\r\nImageSize->outputImageSize\r\n];\r\nprintSp[iNPhotonAvgList,\"Cluster Deviations\",\"After optimization:\"];\r\noutputAdd[p13,iNPhotonAvgList,\"Cluster Deviations\"];\r\n) ",
   "languageId": "wolfram",
