  {
   "kind": 2,
   "value": "graphClusterMeans[]:=(\r\np6=ListPlot[clustMeanTrace,\r\nPlotStyle->Green,\r\nPlotLabel->\"Cluster mean traces\",\r\nFrameLabel->{\"Time (input units)\",\"Voltage (input units)\"},\r\nImageSize->outputImageSize];\r\nprintSp[iNPhotonAvgList,\"Cluster Means\",\"Before optimization:\"];\r\noutputAdd[p6,iNPhotonAvgList,\"Cluster Means\"];\r\n) ",
   "languageId": "wolfram",
   "outputs": [],
