  {
   "kind": 2,
   "value": "readTES[iNPhoton_,iDataSet_,fileInfo_]:=\r\nModule[{fileNameA,nSamplePerTrace,nFile,fileNamePart,nTracePerFile,nTrace,dat,serialNumber,fileName,dim,datImport},\r\n{fileNamePart,nSamplePerTrace,nTracePerFile}=fileInfo;fileNameA=fileNamePart[[1]]<>IntegerString[iNPhoton]<>fileNamePart[[2]];\r\nnFile=Length[iDataSet];\r\nnTrace=nTracePerFile*nFile;\r\ndat=ConstantArray[{},nTrace];\r\nDo[\r\nserialNumber=IntegerString[iDataSet[[iFile]],10,2]; (* padding to ensure 2 digits *)\r\nfileName=fileNameA<>serialNumber;\r\nIf[Not[FileExistsQ[fileName]],\r\nPrint[\"readTESdata: \"<>fileName<>\" does not exist\"];\r\nAbort[]\r\n];\r\ndatImport=Partition[Import[fileName,\"UnsignedInteger16\"],nSamplePerTrace];\r\ndat[[(iFile-1)*nTracePerFile+1;;iFile*nTracePerFile]]=datImport,\r\n{iFile,nFile}\r\n];\r\ndim=Dimensions[dat];\r\nIf[dim !={nTrace,nSamplePerTrace},\r\nPrint[\"readTESdata: unexpected values for dim\",dim];\r\nPrint[\"readTESdata:  expected \",{nTrace,nSamplePerTrace}];\r\nAbort[]\r\n];\r\ndat\r\n] ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820447183,
     "endTime": 1690820447261
    },
    "executionOrder": 240,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "applyFilterShort[x_,filterShort_]:=Module[{ft,ftShort,nFT},\r\nft=Fourier[x,FourierParameters->{1,1}];\r\nnFT=Length[ft];\r\nftShort=Flatten[\r\n{Take[ft,nFT/4],\r\n0,\r\nTake[ft,{(3/4)*nFT+2,nFT}]}\r\n];\r\nChop[InverseFourier[ftShort*filterShort,FourierParameters->{1,1}]/2]\r\n] ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820447261,
     "endTime": 1690820447339
    },
    "executionOrder": 241,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "hanningFilter[n_]:=Chop[Cos[(N[Pi]*Range[0,n-1] )/n]^2] \r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820447339,
     "endTime": 1690820447433
    },
    "executionOrder": 242,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "readTESandFilter[iNPhoton_,iDataSet_,nTime_,fileInfo_]:=\r\nModule[{datUse,dat,datFilt,nTimeUse,nSamplePerTrace,nTracePerFile,nFile},\r\n{nSamplePerTrace,nTracePerFile}=fileInfo[[{2,3}]];\r\nnFile=Length[iDataSet];\r\ndatUse=ConstantArray[{},nTracePerFile*nFile];\r\nDo[\r\ndat=readTES[iNPhoton,{iDataSet[[iFile]]},fileInfo];\r\nhanning=hanningFilter[Last[Dimensions[dat]] / 2];\r\ndatFilt=Map[applyFilterShort[#,hanning]&,dat];\r\nnTimeUse=Min[nTime,Length[hanning]];\r\ndatUse[[(iFile-1)*nTracePerFile+1;;iFile*nTracePerFile]]=datFilt[[ All,Range[nTimeUse] ]]\r\n,\r\n{iFile,nFile}\r\n];\r\ndatUse -= Mean[datUse[[All,10]]]      (* zeroes the signal at an early point, before any photons have arrived *)\r\n] ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820447433,
     "endTime": 1690820447510
    },
    "executionOrder": 243,
    "success": true
   }
