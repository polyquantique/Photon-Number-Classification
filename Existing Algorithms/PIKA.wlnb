  {
   "kind": 2,
   "value": "getIObsOfClust[iClustOfObs_]:=\r\nModule[{iObsGroup},\r\niObsGroup=GatherBy[Transpose[{Range[Length[iClustOfObs]],iClustOfObs}],Last[#]&];\r\nSort[Map[groupCommon,iObsGroup]] [[All,2]]\r\n] \r\n",
   "languageId": "wolfram",
   "outputs": [],
