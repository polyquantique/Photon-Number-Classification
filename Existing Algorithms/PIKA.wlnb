  {
   "kind": 1,
   "value": "### 5.2 Updating de Poisson Log-Likelihood",
   "languageId": "markdown",
   "outputs": [],
   "metadata": {
    "attachments": {}
   },
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "(* from n to n+1 *)\r\ndeltaPoissonUp=Compile[{\r\n{nDel,_Integer},(* cluster number from which to remove the waveform *)\r\n{freqAdd,_Integer},(* size of the cluster to be added to *)\r\n{freqDel,_Integer},(* size of the cluster to be removed from *)\r\n{mu,_Real} (* mean photon number *)\r\n},\r\nLog[(mu*freqDel)/((nDel+1)*(freqAdd+1))]\r\n]; \r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820443916,
     "endTime": 1690820444009
    },
    "executionOrder": 202,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "(* from n to n-1 *)\r\ndeltaPoissonDn=Compile[{\r\n{nDel,_Integer},\r\n{freqAdd,_Integer},\r\n{freqDel,_Integer},\r\n{mu,_Real}\r\n},\r\nLog[(nDel*freqDel)/(mu*(freqAdd+1))]\r\n]; ",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1690820444009,
     "endTime": 1690820444086
    },
    "executionOrder": 203,
    "success": true
   }
  },
