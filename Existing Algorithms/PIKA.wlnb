   "value": "groupProbability[dat_,nPhotonAvg_,nPhotonEff_,nSigma_]:=\r\nModule[{prob},\r\nprob=poisson[nPhotonAvg,nSigma];\r\nPrepend[groupProb[dat,prob,nPhotonEff],prob]\r\n] ",
