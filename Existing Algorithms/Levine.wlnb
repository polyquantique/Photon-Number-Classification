 Cell[BoxData["clustMeanTrace"], "MCode"],
 "\[LongDash]a list of waveforms. ",
 Cell[BoxData[
  RowBox[{
  "clustMeanTrace", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
  "MCode"],
 " is the average waveform of the cluster ",
 Cell[BoxData[
  RowBox[{
  "iObsOfClust", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
  "MCode"],
 "."
}], "ItemNumbered",
 CellChangeTimes->{{3.645356566182388*^9, 3.6453565661979876`*^9}, {
