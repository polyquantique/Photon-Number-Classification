Cell[TextData[{
 "To reduce the computation time, ",
 Cell[BoxData["birthOfObsClust"], "MCode"],
 " and ",
 Cell[BoxData["birthOfClust"], "MCode"],
 " record the \[OpenCurlyDoubleQuote]ages\[CloseCurlyDoubleQuote] of \
observation-to-mean deviation calculations and changes to cluster contents, \
respectively, so this step checks whether ",
 Cell[BoxData["iClust"], "MCode"],
 " and ",
 Cell[BoxData["jClust"], "MCode"],
 " have been modified since we last calculated the deviation of ",
 Cell[BoxData["iObs"], "MCode"],
 " from their means. If they are unchanged, then ",
 Cell[BoxData["sqDevOfObsClust"], "MCode"],
 " is up to date; this condition becomes increasingly common as the \
calculation approaches convergence. If they are changed, we need to \
recalculate one or both deviations and store them in ",
 Cell[BoxData["sqDevOfObsClust"], "MCode"],
 "."
}], "Text",
 CellChangeTimes->{{3.6458679905582294`*^9, 3.64586829684863*^9}, {
  3.64716536324977*^9, 3.647165364294963*^9}, {3.6479401722322316`*^9, 
  3.647940175773409*^9}, {3.650025031102145*^9, 3.6500250387822104`*^9}, {
  3.650025072910802*^9, 3.650025148925984*^9}, {3.667141671059422*^9, 
  3.667141697339177*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"updateRelevantDeviations", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"birthOfObsClust", "\[LeftDoubleBracket]", 
        RowBox[{"iObs", ",", "iClust"}], "\[RightDoubleBracket]"}], "<", 
       RowBox[{
       "birthOfClust", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"sqDevOfObsClust", "\[LeftDoubleBracket]", 
         RowBox[{"iObs", ",", "iClust"}], "\[RightDoubleBracket]"}], "=", 
        RowBox[{"meanSquare", "[", 
         RowBox[{
          RowBox[{
          "dat", "\[LeftDoubleBracket]", "iObs", "\[RightDoubleBracket]"}], 
          " ", "-", " ", 
          RowBox[{
          "clustMeanTrace", "\[LeftDoubleBracket]", "iClust", 
           "\[RightDoubleBracket]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"birthOfObsClust", "\[LeftDoubleBracket]", 
         RowBox[{"iObs", ",", "iClust"}], "\[RightDoubleBracket]"}], "=", 
        "kMove"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"birthOfObsClust", "\[LeftDoubleBracket]", 
        RowBox[{"iObs", ",", "jClust"}], "\[RightDoubleBracket]"}], "<", 
       RowBox[{
       "birthOfClust", "\[LeftDoubleBracket]", "jClust", 
        "\[RightDoubleBracket]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"sqDevOfObsClust", "\[LeftDoubleBracket]", 
         RowBox[{"iObs", ",", "jClust"}], "\[RightDoubleBracket]"}], "=", 
        RowBox[{"meanSquare", "[", 
         RowBox[{
          RowBox[{
          "dat", "\[LeftDoubleBracket]", "iObs", "\[RightDoubleBracket]"}], 
          " ", "-", " ", 
          RowBox[{
          "clustMeanTrace", "\[LeftDoubleBracket]", "jClust", 
           "\[RightDoubleBracket]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"birthOfObsClust", "\[LeftDoubleBracket]", 
         RowBox[{"iObs", ",", "jClust"}], "\[RightDoubleBracket]"}], "=", 
        "kMove"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.6451846186427402`*^9, 3.64518468272713*^9}, {
   3.6451847671075225`*^9, 3.6451848724855223`*^9}, 3.64586824583663*^9, {
   3.6461459800083675`*^9, 3.6461459800239677`*^9}, {3.646146137505968*^9, 
   3.6461461375839677`*^9}, {3.6461471417303677`*^9, 
   3.6461471418083677`*^9}, {3.646147184895568*^9, 3.6461471849579678`*^9}, {
   3.6461498929003677`*^9, 3.6461498988283677`*^9}, {3.646149935878368*^9, 
