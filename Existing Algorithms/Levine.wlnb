Cell[TextData[{
 Cell[BoxData["nPhotonEff"], "MCode"],
 " lists the effective photon number of each observation (",
 Cell[BoxData["getNPhotonEff"], "MCode"],
 " is implemented in Section ",
 
 CounterBox["Section", "FDefEffPhot"],
 ".",
 
 CounterBox["Subsection", "FDefEffPhot"],
 "). The rest of this code creates a histogram of ",
 Cell[BoxData["nPhotonEff"], "MCode"],
 " with bin widths of ",
 Cell[BoxData["binFract"], "MCode"],
 ": ",
 Cell[BoxData["binEdge"], "MCode"],
 " specifies where the edges of the bins should be, ",
 Cell[BoxData["binCnt"], "MCode"],
 " counts the number of waveforms in each bin, and ",
 Cell[BoxData["binCtr"], "MCode"],
 " lists the centers of the bins."
}], "Text",
 CellChangeTimes->{{3.645891729929353*^9, 3.645891811283353*^9}, {
   3.645891846866953*^9, 3.6458918870057535`*^9}, {3.6458920047857533`*^9, 
   3.645892135498153*^9}, 3.647878019533162*^9, 3.647878059356107*^9, 
   3.647878202559389*^9, {3.667141918421009*^9, 3.667141950452463*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"graphNewEffectivePhotonNumber", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nPhotonEff", "=", 
     RowBox[{"getNPhotonEff", "[", 
      RowBox[{"dat", ",", "nPhotonOfClust", ",", "clustMeanTrace"}], "]"}]}], 
    ";", 
    RowBox[{"binEdge", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"nEff", ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"nEff", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Floor", "[", 
             FractionBox[
              RowBox[{"Min", "[", "nPhotonEff", "]"}], "binFract"], "]"}], 
            "-", 
            FractionBox["1", "2"]}], ")"}], "*", "binFract"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Ceiling", "[", 
             FractionBox[
              RowBox[{"Max", "[", "nPhotonEff", "]"}], "binFract"], "]"}], 
            "+", 
            FractionBox["1", "2"]}], ")"}], "*", "binFract"}], ",", 
         "\[IndentingNewLine]", " ", "binFract"}], "}"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"binCnt", "=", 
     RowBox[{"BinCounts", "[", 
      RowBox[{"nPhotonEff", ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Floor", "[", 
             FractionBox[
              RowBox[{"Min", "[", "nPhotonEff", "]"}], "binFract"], "]"}], 
            "-", 
            FractionBox["1", "2"]}], ")"}], "*", "binFract"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Ceiling", "[", 
             FractionBox[
              RowBox[{"Max", "[", "nPhotonEff", "]"}], "binFract"], "]"}], 
            "+", 
            FractionBox["1", "2"]}], ")"}], "*", "binFract"}], ",", 
         "\[IndentingNewLine]", "binFract"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"binCtr", "=", 
     FractionBox[
      RowBox[{
       RowBox[{"Most", "[", "binEdge", "]"}], " ", "+", " ", 
       RowBox[{"Rest", "[", "binEdge", "]"}]}], "2"]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"pairCnt", "=", 
     RowBox[{"pair", "[", 
      RowBox[{"binCtr", ",", "binCnt"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"pairCntPlot", "=", 
     RowBox[{"pair", "[", 
      RowBox[{"binCtr", ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
            "binCnt", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
            "<", "0.5"}], ",", "0.5", ",", 
           RowBox[{
           "binCnt", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}],
           "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "binCnt", "]"}]}], "}"}]}], "]"}]}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"p17", "=", 
     RowBox[{"ListLogPlot", "[", 
      RowBox[{"pairCntPlot", ",", "\[IndentingNewLine]", 
       RowBox[{"PlotLabel", "\[Rule]", 
        RowBox[{"\"\<Effective photon number histogram (bin width \>\"", "<>", 
         RowBox[{"TextString", "[", "binFract", "]"}], "<>", "\"\<)\>\""}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<Photon number\>\"", ",", "\"\<counts\>\""}], "}"}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "\[Rule]", "outputImageSize"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{
     "p17", ",", "iNPhotonAvgList", ",", "\"\<Effective Photon Numbers\>\""}],
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", 
      "\"\<Numerical \!\(\*SubscriptBox[\(n\), \(eff\)]\) Bin Counts\>\"", 
      ",", "\"\<First element is bin center; second is bin count.\>\""}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{
     "pairCnt", ",", "iNPhotonAvgList", ",", 
      "\"\<Numerical \!\(\*SubscriptBox[\(n\), \(eff\)]\) Bin Counts\>\""}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", 
