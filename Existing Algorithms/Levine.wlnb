  3.667091017931377*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"initialSetup", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SetOptions", "[", 
     RowBox[{"$Output", ",", 
      RowBox[{"PageWidth", "\[Rule]", "110"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"SetOptions", "[", 
     RowBox[{"ListPlot", ",", 
      RowBox[{"Joined", "\[Rule]", "True"}], ",", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"SetOptions", "[", 
     RowBox[{"ListLogPlot", ",", 
      RowBox[{"Joined", "\[Rule]", "True"}], ",", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"tStart", "=", 
     RowBox[{"TimeUsed", "[", "]"}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{"useInputFile", ",", 
      RowBox[{"Get", "[", "pikaInput", "]"}]}], "]"}], ";", "     ", 
    RowBox[{"(*", " ", 
     RowBox[{"user", " ", "defined", " ", "override"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"tAnnealOrig", "=", "tAnneal"}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", "\"\<Options read; now running\>\"", "]"}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"fileInfo", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"partialFilePath", ",", "fileExt"}], "}"}], ",", 
       "nSamplePerTrace", ",", "nTracePerFile"}], "}"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"outputCreateTabs", "[", 
     RowBox[{"Length", "[", "nPhotonAvgList", "]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"print", "[", 
     RowBox[{
     "0", ",", "\"\<dataset number (iNPhoton): \>\"", ",", "iNPhoton"}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"print", "[", 
     RowBox[{"0", ",", "\"\<file range (iDataSet): \>\"", ",", "iDataSet"}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   ")"}]}]], "Input",
 InitializationGroup->True,
