   3.645186177622529*^9}, {3.64587059725043*^9, 3.6458706000428295`*^9}, {
   3.646150089304368*^9, 3.646150098898368*^9}, {3.646150856863568*^9, 
   3.646150871387168*^9}, 3.647166180154133*^9, {3.647168327807966*^9, 
   3.6471683283851624`*^9}, 3.662130123881493*^9, {3.665246596715766*^9, 
   3.6652465978091717`*^9}}],

Cell["\<\
Loop 2 repeats a preset number of times, randomly ordering the waveforms, \
running Loop 3 on each one, and then decreasing the annealing temperature in \
each iteration.\
\>", "Text",
 CellChangeTimes->{{3.6458818488392296`*^9, 3.6458818908188295`*^9}, {
  3.64588209970283*^9, 3.6458821799648294`*^9}}]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ". Data Analysis and Output (Loop 1)"
}], "Subsection",
 CellChangeTimes->{{3.6452032551323338`*^9, 3.6452032593131337`*^9}, {
   3.6452033691193333`*^9, 3.645203375062934*^9}, {3.645271925505392*^9, 
   3.645271931012192*^9}, {3.645271985830592*^9, 3.645271993209392*^9}, {
   3.6452720347677917`*^9, 3.6452720401965923`*^9}, 3.6452790354622397`*^9, {
   3.64528002026764*^9, 3.64528003772604*^9}, 3.64587103961963*^9, {
   3.6458711157788296`*^9, 3.64587111662123*^9}, {3.64587273121743*^9, 
   3.64587273240303*^9}, 3.6461333326077595`*^9, 3.646134376622159*^9, {
   3.6615189819150267`*^9, 3.661518985130248*^9}, {3.661520518623702*^9, 
   3.6615205350393877`*^9}, {3.6621293525768833`*^9, 3.6621293526290827`*^9}, 
   3.662223385608892*^9},
 CellTags->"ImplOutput"],

Cell[TextData[{
 "When Loop 2 is finished, PIKA has run for many rounds on the data and the \
observations should be arranged into optimal clusters. This subsection \
concerns itself primarily with creating graphical and numerical outputs to \
understand and visualize the clustering. Now that the optimization is \
finished, ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 " (the list of lists) is a more useful format than ",
 Cell[BoxData["iClustOfObs"], "MCode"],
 " (the simple list). In order to compare the new clustering to the old, we \
generate ",
 Cell[BoxData["iObsOfClustNew"], "MCode"],
 " from ",
 Cell[BoxData["iClustOfObs"], "MCode"],
 ", which reflects the optimized clusters, and simply copy ",
 Cell[BoxData["iObsOfClustOld"], "MCode"],
 " from ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 ", which has not been changed since before Loop 2. ",
 Cell[BoxData["freqNew"], "MCode"],
 " and ",
 Cell[BoxData["freqOld"], "MCode"],
 " are lists of the new and old cluster sizes, respectively, and ",
 Cell[BoxData["nPhotonAvgNew"], "MCode"],
 " is an estimate of the actual mean photon number based on the results of \
PIKA."
}], "Text",
 CellChangeTimes->{{3.6458822086376295`*^9, 3.64588221776363*^9}, 
   3.6458823356060295`*^9, {3.64588328049963*^9, 3.64588330929723*^9}, {
   3.64588342306803*^9, 3.64588375316403*^9}, {3.6460465348807287`*^9, 
   3.6460465754875283`*^9}, {3.6460467607843285`*^9, 
   3.6460467612367287`*^9}, {3.6460474167011285`*^9, 3.646047422535528*^9}, {
   3.6623260325715227`*^9, 3.662326032783915*^9}, {3.667141721609417*^9, 
   3.667141758740312*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"prepareAnalysisAndOutput", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"print", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<final \>\"", ",", "nCool", ",", 
      "\"\< kMove \>\"", ",", "kMove", ",", "\"\< logLikeProb \>\"", ",", 
      "logLikeProb", ",", "\"\< objFtn \>\"", ",", "objFtn", ",", 
      "\"\< TimeUsed \>\"", ",", 
      RowBox[{
       RowBox[{"TimeUsed", "[", "]"}], "-", "tStart"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"iObsOfClustNew", "=", 
     RowBox[{"getIObsOfClust", "[", "iClustOfObs", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"iObsOfClustOld", "=", "iObsOfClust"}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{
     "not", " ", "changed", " ", "since", " ", "before", " ", "the", " ", 
      "optimization", " ", "loop"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{"freqNew", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"Length", ",", "iObsOfClustNew"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"freqOld", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"Length", ",", "iObsOfClustOld"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"nPhotonAvgNew", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"nPhotonOfClust", ".", "freqNew"}], 
       RowBox[{"Total", "[", "freqNew", "]"}]], "//", "N"}]}], ";", 
    RowBox[{"print", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<nPhotonAvg \>\"", ",", "nPhotonAvg", ",", 
      "\"\< nPhotonAvgNew \>\"", ",", "nPhotonAvgNew"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<\>\"", ",", 
      "\"\<Optimized mean photon number: \>\"", ",", "nPhotonAvgNew"}], "]"}],
     ";", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<\>\"", ",", 
      "\"\<Optimized objective function: \>\"", ",", "objFtn"}], "]"}], ";"}],
    "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.645186534328661*^9, 3.645186655528945*^9}, 
   3.6452035032101336`*^9, 3.645203552211134*^9, {3.645796306512595*^9, 
