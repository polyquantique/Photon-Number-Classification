Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[CapitalDelta]", "\[InvisibleSpace]", "ln", " ", 
    SubscriptBox["\[ScriptCapitalL]", "C"]}], "=", 
   RowBox[{
    RowBox[{"ln", "(", 
     FractionBox[
      SubscriptBox["m", "b"], 
      RowBox[{
       SubscriptBox["m", "a"], "+", "1"}]], ")"}], "."}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.643648180892543*^9, 3.6436482075635433`*^9}, {
  3.6436487122545433`*^9, 3.643648723086543*^9}, {3.662136977263308*^9, 
  3.662136996900744*^9}, {3.662207741945588*^9, 3.662207750057315*^9}}],

Cell["\<\
The algorithm only considers moves to adjacent clusters, so we only need to \
calculate the change due to transfers to immediately preceding and succeeding \
clusters. These two functions give the change in the \
probabilistic/combinatorial component of the objective function for moves to \
higher and lower photon numbers.\
\>", "Text",
 CellChangeTimes->{{3.6436485068725433`*^9, 3.643648507816543*^9}, {
  3.6436489363215427`*^9, 3.6436489970045433`*^9}, {3.643649136532543*^9, 
  3.6436491371885433`*^9}, {3.6441479063603516`*^9, 3.6441479324923515`*^9}, {
  3.6464813856849813`*^9, 3.646481389725356*^9}, {3.6464947175469522`*^9, 
  3.646494745665168*^9}, {3.6472494288492126`*^9, 3.6472494646915836`*^9}, {
  3.647249539690303*^9, 3.6472497045176463`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"from", " ", "n", " ", "to", " ", "n"}], "+", "1"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"deltaPoissonUp", "=", 
    RowBox[{"Compile", "[", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"nDel", ",", "_Integer"}], "}"}], ",", 
        RowBox[{"(*", " ", 
         RowBox[{
         "cluster", " ", "number", " ", "from", " ", "which", " ", "to", " ", 
          "remove", " ", "the", " ", "waveform"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"freqAdd", ",", "_Integer"}], "}"}], ",", 
        RowBox[{"(*", " ", 
         RowBox[{
         "size", " ", "of", " ", "the", " ", "cluster", " ", "to", " ", "be", 
          " ", "added", " ", "to"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"freqDel", ",", "_Integer"}], "}"}], ",", 
        RowBox[{"(*", " ", 
         RowBox[{
         "size", " ", "of", " ", "the", " ", "cluster", " ", "to", " ", "be", 
          " ", "removed", " ", "from"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"mu", ",", "_Real"}], "}"}]}], " ", 
       RowBox[{"(*", " ", 
        RowBox[{"mean", " ", "photon", " ", "number"}], " ", "*)"}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Log", "[", 
       FractionBox[
        RowBox[{"mu", "*", "freqDel"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"nDel", "+", "1"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{"freqAdd", "+", "1"}], ")"}]}]], "]"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.643649384281543*^9, 3.643649429590543*^9}, {
   3.6437159563065305`*^9, 3.64371595769493*^9}, {3.6461500901467676`*^9, 
   3.646150099912368*^9}, {3.646150851699968*^9, 3.6461508665667677`*^9}, {
   3.6464814115340157`*^9, 3.6464814139988003`*^9}, {3.646490416594927*^9, 
   3.6464904356424046`*^9}, {3.6464904769821396`*^9, 3.646490479868121*^9}, {
   3.6464954392459183`*^9, 3.6464954642369585`*^9}, {3.646495519413804*^9, 
   3.6464955434064507`*^9}, 3.6464968509064655`*^9, {3.6472494841778584`*^9, 
   3.6472495139640675`*^9}, {3.647249738559628*^9, 3.647249742787201*^9}, 
   3.662129887632722*^9, {3.662130708621805*^9, 3.662130712141787*^9}, 
   3.662220546912264*^9, 3.6623296454200563`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"from", " ", "n", " ", "to", " ", "n"}], "-", "1"}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{"deltaPoissonDn", "=", 
    RowBox[{"Compile", "[", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"nDel", ",", "_Integer"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"freqAdd", ",", "_Integer"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"freqDel", ",", "_Integer"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"mu", ",", "_Real"}], "}"}]}], "\[IndentingNewLine]", "}"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{"Log", "[", 
       FractionBox[
        RowBox[{"nDel", "*", "freqDel"}], 
        RowBox[{"mu", "*", 
         RowBox[{"(", 
          RowBox[{"freqAdd", "+", "1"}], ")"}]}]], "]"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.643649384281543*^9, 3.643649429590543*^9}, {
   3.6437159563065305`*^9, 3.64371595769493*^9}, {3.6461500901467676`*^9, 
   3.646150099912368*^9}, {3.646150851699968*^9, 3.6461508665667677`*^9}, {
   3.6464814115340157`*^9, 3.646481415059593*^9}, {3.646490442459561*^9, 
   3.6464905071483526`*^9}, {3.6464954779180703`*^9, 3.646495512815047*^9}, {
   3.6464955483360195`*^9, 3.6464955587099524`*^9}, 3.6464968553056374`*^9, {
   3.647249748889762*^9, 3.6472497514949455`*^9}, 3.662129887640671*^9, 
   3.6622205485884523`*^9, 3.662329646230054*^9}],

Cell[TextData[{
 "Bear in mind that the term that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalL]", 
    RowBox[{"P", "\[InvisibleSpace]", "C"}]], TraditionalForm]], "Math"],
 " contributes to the overall objective function is the negation of its \
logarithm, so a positive ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]", "\[InvisibleSpace]", "ln", " ", 
    SubscriptBox["\[ScriptCapitalL]", 
     RowBox[{"P", "\[InvisibleSpace]", "C"}]]}], TraditionalForm]], "Math"],
 " decreases ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", 
    RowBox[{"K", "\[InvisibleSpace]", "P", "\[InvisibleSpace]", "C"}]], 
   TraditionalForm]], "Math"],
 "."
}], "Text",
 CellChangeTimes->{{3.643728754766393*^9, 3.643728785825794*^9}, {
  3.6437288159024014`*^9, 3.643728988187697*^9}, {3.643729045922927*^9, 
  3.6437290725363564`*^9}, {3.6615198963324623`*^9, 3.661519955814164*^9}}],

Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 
 CounterBox["Subsubsection"],
 ".",
 " ",
 "Example: The Poisson Update"
}], "Subsubsection",
 CellChangeTimes->{{3.6437135971099305`*^9, 3.6437136125267305`*^9}, {
   3.64373358348419*^9, 3.64373358520019*^9}, {3.6458728228266296`*^9, 
   3.64587282343503*^9}, 3.6461344729833593`*^9, {3.646568108252391*^9, 
   3.6465681104674206`*^9}, {3.647095535685319*^9, 3.647095536824112*^9}, {
   3.6470956419518375`*^9, 3.6470956422950354`*^9}, 3.6471650468278055`*^9, 
   3.662129353007949*^9}],

Cell[TextData[{
 "Suppose we have a set of clusters, among them an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2"}], TraditionalForm]], "Math"],
 " cluster with five waveforms and an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "3"}], TraditionalForm]], "Math"],
 " cluster with seven waveforms, with a mean of 4.4 photons. We are \
interested in moving a waveform from the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2"}], TraditionalForm]], "Math"],
 " cluster to the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "3"}], TraditionalForm]], "Math"],
 " cluster. Then the change in the Poisson log-likelihood is given by ",
 Cell[BoxData["deltaPoissonUp"], "MCode"],
 "."
}], "Text",
 CellChangeTimes->{{3.6437139955723305`*^9, 3.6437139983511305`*^9}, {
   3.6437142872193303`*^9, 3.6437143749923306`*^9}, 3.6437144137683306`*^9, {
   3.6437146413975306`*^9, 3.6437146526939306`*^9}, {3.6437147368977304`*^9, 
   3.6437148052431307`*^9}, {3.6437150174783306`*^9, 
