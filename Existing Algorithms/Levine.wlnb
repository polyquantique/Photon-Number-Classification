Cell[TextData[{
 Cell[BoxData["print"], "MCode"],
 " takes any number of arguments (",
 Cell[BoxData["args"], "MCode"],
 "), turns them into strings, concatenates them, and prints the result to the \
log. ",
 Cell[BoxData["printSp"], "MCode"],
 " prints to an arbitrary section of output, not just the log. ",
 Cell[BoxData["iRun"], "MCode"],
 " and ",
 Cell[BoxData["name"], "MCode"],
 " indicate the run number and tab name, respectively, to which to print."
}], "Text",
 CellChangeTimes->{{3.6461544593686485`*^9, 3.646154546775449*^9}, {
  3.6473395979439554`*^9, 3.64733962366819*^9}, {3.6473566669183292`*^9, 
  3.647356717664804*^9}, {3.6617029566972227`*^9, 3.661702973090699*^9}}],

