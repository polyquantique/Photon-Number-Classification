          RowBox[{"nPhotonOfClust", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "-", "1"}], 
           "\[RightDoubleBracket]"}], "]"}], "<>", "\"\< (red) to n=\>\"", "<>",
          "\[IndentingNewLine]", 
         RowBox[{"ToString", "[", 
          RowBox[{"nPhotonOfClust", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "+", "1"}], 
           "\[RightDoubleBracket]"}], "]"}], "<>", "\"\< (blue)\>\""}]}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Time (input units)\>\"", ",", "\"\<Voltage (input units)\>\""}],
          "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"DisplayFunction", "\[Rule]", "$DisplayFunction"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "\[Rule]", "outputImageSize"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<Sample Traces\>\"", ",", 
      "\"\<After optimization:\>\""}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{"p8", ",", "iNPhotonAvgList", ",", "\"\<Sample Traces\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
