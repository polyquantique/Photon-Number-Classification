   3.6472687132372284`*^9, 3.64726872091078*^9}, {3.6472689982804027`*^9, 
   3.6472690379543486`*^9}, {3.6472771714954185`*^9, 
   3.6472772008432302`*^9}, {3.6472774249017935`*^9, 
   3.6472774374199133`*^9}, {3.647277989702177*^9, 3.6472779985221205`*^9}, {
   3.6472782407809687`*^9, 3.6472782426861567`*^9}}],

Cell[TextData[{
 Cell[BoxData["outputAdd"], "MCode"],
 " adds some expression to the content list for a particular name and run, \
creating the name\[CloseCurlyQuote]s content list if it has no content \
already. A run number of 0 indicates output to the general information tab, \
and a blank name indicates output to the top space of a \
run\[CloseCurlyQuote]s tab."
}], "Text",
 CellChangeTimes->{{3.6473573540939245`*^9, 3.647357464837614*^9}, {
  3.661702921488529*^9, 3.661702931851571*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"outputAdd", "[", 
   RowBox[{"expr_", ",", "iRun_", ",", "name_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "iName", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"iRun", "\[Equal]", "0"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"name", "\[Equal]", "\"\<Log\>\""}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"outputGeneralLog", "=", 
          RowBox[{"Append", "[", 
           RowBox[{"outputGeneralLog", ",", "expr"}], "]"}]}], ";"}], 
        "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"outputGeneralGraphics", "=", 
          RowBox[{"Append", "[", 
           RowBox[{"outputGeneralGraphics", ",", "expr"}], "]"}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"name", "\[Equal]", "\"\<\>\""}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
          "outputTopList", "\[LeftDoubleBracket]", "iRun", 
           "\[RightDoubleBracket]"}], "=", 
          RowBox[{"Append", "[", 
           RowBox[{
            RowBox[{
            "outputTopList", "\[LeftDoubleBracket]", "iRun", 
             "\[RightDoubleBracket]"}], ",", "expr"}], "]"}]}], ";"}], 
        "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{"outputNameList", ",", "name"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"iName", "=", 
            RowBox[{"First", "[", 
             RowBox[{"First", "[", 
              RowBox[{"Position", "[", 
               RowBox[{"outputNameList", ",", "name"}], "]"}], "]"}], "]"}]}],
            ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"outputContentTable", "\[LeftDoubleBracket]", 
             RowBox[{"iRun", ",", "iName"}], "\[RightDoubleBracket]"}], "=", 
            RowBox[{"Append", "[", 
             RowBox[{
              RowBox[{"outputContentTable", "\[LeftDoubleBracket]", 
               RowBox[{"iRun", ",", "iName"}], "\[RightDoubleBracket]"}], ",",
               "expr"}], "]"}]}], ";"}], "\[IndentingNewLine]", ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"outputNameList", "=", 
            RowBox[{"Append", "[", 
             RowBox[{"outputNameList", ",", "name"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"outputContentTable", "=", 
            RowBox[{"Map", "[", 
             RowBox[{
              RowBox[{"Append", "[", 
               RowBox[{"{", "}"}], "]"}], ",", "outputContentTable"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"outputContentTable", "\[LeftDoubleBracket]", 
             RowBox[{"iRun", ",", 
              RowBox[{"-", "1"}]}], "\[RightDoubleBracket]"}], "=", 
            RowBox[{"{", "expr", "}"}]}], ";"}]}], "\[IndentingNewLine]", 
         "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
     "]"}]}], " ", "\[IndentingNewLine]", "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"end", " ", "Module"}], " ", "*)"}]}]], "Input",
