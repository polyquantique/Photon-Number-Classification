Cell[TextData[{
 Cell[BoxData["pika"], "MCode"],
 " creates a form with a field for each constant and option that needs to be \
set for PIKA to run. It then uses ",
 Cell[BoxData["runFromAssociation"], "MCode"],
 " to assign the proper values to the proper variables and run PIKA."
}], "Text",
 CellChangeTimes->{{3.647855451732788*^9, 3.6478554638539104`*^9}, {
  3.6478565350525885`*^9, 3.6478566234572215`*^9}, {3.64787103210046*^9, 
  3.64787103210046*^9}, {3.6478716410649543`*^9, 3.647871641376952*^9}, {
  3.661702984375947*^9, 3.661702989598434*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"pika", "[", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "form", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"form", "=", 
      RowBox[{"FormObject", "[", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<General\>\"", ",", "Bold"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<iNPhoton\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Index of the dataset to read in\>\"", ",", "16"}], "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<iDataSet\>\"", ",", "ToExpression", ",", 
           "\"\<Parts of dataset to use\>\"", ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], ",", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Normal expressions (e.g., Range[0,3]) will work \
here\>\""}]}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nTime\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Number of time points after filtration\>\"", ",", "512"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<mSample\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Number of traces to randomly sample\>\"", ",", "100", ",", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Actually a maximum number to sample, only reached if the \
population is large enough\>\""}]}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nDatUse\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Number of traces to use (if 0, use all)\>\"", ",", "0"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<\\nBackground Radiation Rejection\>\"", ",", "Bold"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<backgroundReject\>\"", ",", "\"\<Boolean\>\"", ",", 
           "\"\<Reject background traces\>\"", ",", "False"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<peakValCut\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Voltage cutoff\>\"", ",", "275"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<peakPosCut\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Time cutoff\>\"", ",", "17"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<peakNumCut\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Cutoff for number of peaks\>\"", ",", "2"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Style", "[", 
          RowBox[{
          "\"\<\\nIteration and Simulated Annealing\>\"", ",", "Bold"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nCool\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Total number of optimization rounds\>\"", ",", "60", ",", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Includes both greedy and simulated annealing rounds\>\""}]}],
           "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nGreedy\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Number of greedy rounds\>\"", ",", "60", ",", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Greedy rounds come before simulated annealing; simulated \
annealing will not run if nCool\[Equal]nGreedy\>\""}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<coolConst\>\"", ",", "\"\<Number\>\"", ",", 
           "\"\<Simulated annealing cooling constant\>\"", ",", "0.99"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<tAnneal\>\"", ",", "\"\<Number\>\"", ",", 
           "\"\<Simulated annealing starting temperature\>\"", ",", "0.02"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<\\nProbability\>\"", ",", "Bold"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<probDistName\>\"", ",", "\"\<String\>\"", ",", 
           "\"\<Name of the probability distribution\>\"", ",", 
           "\"\<Poisson\>\""}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nSigma\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Extent of probability distribution\>\"", ",", "10", ",", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Number of standard deviations away from the mean to generate\
\>\""}]}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<\\nOutput\>\"", ",", "Bold"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<binFract\>\"", ",", "\"\<Number\>\"", ",", 
           "\"\<Histogram bin width (fraction of a photon)\>\"", ",", 
           "0.05"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<outputImageSize\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Default image size for plots\>\"", ",", "400"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<\\nInput\>\"", ",", "Bold"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nPhotonAvgList\>\"", ",", "ToExpression", ",", 
           "\"\<List of mean photon numbers to test\>\"", ",", 
           RowBox[{"{", "1.49608", "}"}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         "\"\<The data filenames should be of the form data-1.daq01, with the \
\\\"data-\\\" and \\\".daq\\\" being an arbitrary prefix and file extension, \
the first number being iNPhoton, and the second number being a two-digit form \
of iDataSet.\>\"", ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<partialFilePath\>\"", ",", "\"\<String\>\"", ",", 
           "\"\<Path to data files\>\"", ",", 
           "\"\<[directory]\\\\TES_E0019-\>\"", ",", "\[IndentingNewLine]", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Should include the first (generic) part of the filenames of \
the data files, without iNPhoton or iDataSet specifications\>\""}]}], "]"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<fileExt\>\"", ",", "\"\<String\>\"", ",", 
           "\"\<File extension of data files\>\"", ",", "\"\<.daq\>\"", ",", 
           RowBox[{
           "\"\<Help\>\"", "\[Rule]", 
            "\"\<Should not include iDataSet specification\>\""}]}], "]"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nSamplePerTrace\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Number of samples per trace\>\"", ",", "8192"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<nTracePerFile\>\"", ",", "\"\<Integer\>\"", ",", 
           "\"\<Number of traces per file\>\"", ",", "512"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<useInputFile\>\"", ",", "\"\<Boolean\>\"", ",", 
           "\"\<Use separate input file\>\"", ",", "False"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"makeField", "[", 
          RowBox[{
          "\"\<pikaInput\>\"", ",", "\"\<String\>\"", ",", 
           "\"\<Separate input file\>\"", ",", "\"\<\>\"", ",", 
           RowBox[{"\"\<Control\>\"", "\[Rule]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"FileNameSetter", "[", 
               RowBox[{"#", ",", "\"\<Open\>\"", ",", 
                RowBox[{"{", 
                 RowBox[{"\"\<Mathematica packages\>\"", "\[Rule]", 
                  RowBox[{"{", "\"\<*.m\>\"", "}"}]}], "}"}]}], "]"}], "&"}], 
             ")"}]}], ",", 
           RowBox[{"\"\<Required\>\"", "\[Rule]", "False"}]}], "]"}]}], 
        "\[IndentingNewLine]", "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"FormFunction", "[", 
       RowBox[{"form", ",", "runFromAssociation"}], "]"}], "[", "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.6477741232527847`*^9, 3.6477741296713433`*^9}, {
   3.6477742102342277`*^9, 3.647774252456357*^9}, {3.647776580184718*^9, 
