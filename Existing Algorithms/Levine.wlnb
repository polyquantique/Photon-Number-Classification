Cell[TextData[{
 Cell[BoxData["outputShowTabView"], "MCode"],
 " is called at the end of PIKA, taking the name and content lists and \
formatting them into a nested ",
 Cell[BoxData["TabView"], "MCode"],
 "."
}], "Text",
 CellChangeTimes->{{3.6473574788775244`*^9, 3.6473575500910683`*^9}, {
  3.661702944746031*^9, 3.661702949384733*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"outputShowTabView", "[", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "columnsNames", ",", "labelTableNames", ",", "viewsRuns", ",", 
      "columnsRuns", ",", "labelTableRuns", ",", "generalTabView", ",", 
      "labelTableRunsGeneral"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"columnsNames", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"Column", ",", "outputContentTable", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"labelTableNames", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
         "outputNameList", "\[LeftDoubleBracket]", "jName", 
          "\[RightDoubleBracket]"}], "\[Rule]", " ", 
         RowBox[{"columnsNames", "\[LeftDoubleBracket]", 
          RowBox[{"jRun", ",", "jName"}], "\[RightDoubleBracket]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"jRun", ",", 
          RowBox[{"Length", "[", "outputContentTable", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"jName", ",", 
          RowBox[{"Length", "[", "outputNameList", "]"}]}], "}"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"viewsRuns", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"TabView", "[", 
          RowBox[{"#", ",", 
           RowBox[{"Appearance", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"\"\<Limited\>\"", ",", "5"}], "}"}]}], ",", 
           RowBox[{"ImageSize", "\[Rule]", "Automatic"}]}], "]"}], "&"}], ",",
         "labelTableNames"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"columnsRuns", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"Column", ",", 
        RowBox[{"MapThread", "[", 
         RowBox[{"Append", ",", 
          RowBox[{"{", 
           RowBox[{"outputTopList", ",", "viewsRuns"}], "}"}]}], "]"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"labelTableRuns", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\"\<Run \>\"", "<>", 
          RowBox[{"ToString", "[", "jRun", "]"}]}], "\[Rule]", " ", 
         RowBox[{
         "columnsRuns", "\[LeftDoubleBracket]", "jRun", 
          "\[RightDoubleBracket]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"jRun", ",", 
          RowBox[{"Length", "[", "outputContentTable", "]"}]}], "}"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"generalTabView", "=", 
      RowBox[{"TabView", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<Log\>\"", "\[Rule]", 
           RowBox[{"Column", "[", "outputGeneralLog", "]"}]}], ",", 
          RowBox[{"\"\<Graphics\>\"", "\[Rule]", 
           RowBox[{"Column", "[", "outputGeneralGraphics", "]"}]}], ",", 
          RowBox[{"\"\<Options\>\"", "\[Rule]", 
           RowBox[{"TableForm", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                "varNames", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}], ",", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{
                   "varNames", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}], "\[Equal]", 
                   "\"\<tAnneal\>\""}], ",", "tAnnealOrig", ",", 
                  RowBox[{"ToExpression", "[", 
                   RowBox[{
                   "varNames", "\[LeftDoubleBracket]", "i", 
                    "\[RightDoubleBracket]"}], "]"}]}], "]"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "[", "varNames", "]"}]}], "}"}]}], "]"}], 
            "]"}]}]}], "}"}], ",", 
        RowBox[{"Appearance", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"\"\<Limited\>\"", ",", "15"}], "}"}]}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "Automatic"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"labelTableRunsGeneral", "=", 
      RowBox[{"Prepend", "[", 
       RowBox[{"labelTableRuns", ",", 
        RowBox[{"\"\<General\>\"", "\[Rule]", "generalTabView"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"TabView", "[", 
      RowBox[{"labelTableRunsGeneral", ",", 
       RowBox[{"Appearance", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<Limited\>\"", ",", "15"}], "}"}]}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "Automatic"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.6472733931080265`*^9, 3.64727343481036*^9}, {
