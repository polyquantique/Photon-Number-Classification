Cell[TextData[{
 "We can also filter the data as we read it in. ",
 Cell[BoxData["readTES"], "MCode"],
 " applies a \[OpenCurlyDoubleQuote]short\[CloseCurlyDoubleQuote] filter to a \
list, one that omits half of the frequency domain."
}], "Text",
 CellChangeTimes->{{3.6465645010231047`*^9, 3.6465645353116846`*^9}, 
   3.66282905180903*^9, {3.662829196114709*^9, 3.662829208312714*^9}, {
   3.6657888905597057`*^9, 3.665788908847027*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"applyFilterShort", "[", 
   RowBox[{"x_", ",", "filterShort_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ft", ",", "ftShort", ",", "nFT"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ft", "=", 
      RowBox[{"Fourier", "[", 
       RowBox[{"x", ",", 
        RowBox[{"FourierParameters", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nFT", "=", 
      RowBox[{"Length", "[", "ft", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ftShort", "=", 
      RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Take", "[", 
          RowBox[{"ft", ",", 
           RowBox[{"nFT", "/", "4"}]}], "]"}], ",", "\[IndentingNewLine]", 
         "0", ",", "\[IndentingNewLine]", 
         RowBox[{"Take", "[", 
          RowBox[{"ft", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"3", "/", "4"}], ")"}], "*", "nFT"}], "+", "2"}], ",",
              "nFT"}], "}"}]}], "]"}]}], "}"}], "\[IndentingNewLine]", 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"InverseFourier", "[", 
        RowBox[{
         RowBox[{"ftShort", "*", "filterShort"}], ",", 
         RowBox[{"FourierParameters", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}]}]}], "]"}], "/", "2"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.646134240465359*^9, 3.646134259200959*^9}, {
   3.6461420531329217`*^9, 3.6461421211957216`*^9}, {3.646150092049968*^9, 
   3.646150101846768*^9}, {3.646150855022768*^9, 3.646150869702368*^9}, {
   3.6465614080890226`*^9, 3.6465614089158173`*^9}, {3.646565152433573*^9, 
   3.64656515302635*^9}, {3.6621298879255657`*^9, 3.662129887931011*^9}, {
