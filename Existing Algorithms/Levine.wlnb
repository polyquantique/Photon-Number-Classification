   3.6471679798521967`*^9}, {3.661700030854096*^9, 3.661700048718153*^9}, 
   3.6623251956471663`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getObjFtn", "[", 
   RowBox[{"sqDevOfClust_", ",", "sigmaObjFtn_", ",", "logLikeProb_"}], "]"}],
   ":=", 
  RowBox[{
   RowBox[{"Total", "[", 
    FractionBox["sqDevOfClust", 
     RowBox[{"2", "*", 
      SuperscriptBox["sigmaObjFtn", "2"]}]], "]"}], "-", 
   "logLikeProb"}]}]], "Input",
 CellChangeTimes->{
  3.646134211589759*^9, {3.6461414684449215`*^9, 3.6461414693653216`*^9}, {
