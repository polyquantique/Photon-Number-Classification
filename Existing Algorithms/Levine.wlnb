Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 " ",
 "Effective Photon Number"
}], "Subsection",
 CellChangeTimes->{{3.646130878470959*^9, 3.6461308828857594`*^9}, {
   3.646133214702959*^9, 3.646133215295759*^9}, {3.646134343456559*^9, 
   3.6461343645009594`*^9}, 3.646407736959944*^9, 3.662129353117299*^9},
 CellTags->"FDefEffPhot"],

Cell[TextData[{
 "The three-argument version of ",
 Cell[BoxData["getNPhotonEff"], "MCode"],
 " takes a list of observations, a list of photon numbers associated with \
clusters, and a list of cluster means. It returns a list specifying the \
effective photon number of each observation, found via a linear interpolation \
between the two cluster means closest to a given observation."
}], "Text",
 CellChangeTimes->{{3.6463901942579827`*^9, 3.646390202838928*^9}, {
   3.646391291655551*^9, 3.646391311601223*^9}, {3.6463919515899177`*^9, 
   3.646392076972514*^9}, {3.64639220562709*^9, 3.646392264407913*^9}, {
   3.6463958505384398`*^9, 3.6463959753768396`*^9}, {3.650025758863442*^9, 
   3.650025813918439*^9}, 3.662129353171671*^9, {3.6623291094439907`*^9, 
   3.662329111127388*^9}, {3.662329145391398*^9, 3.6623291493261633`*^9}, {
   3.66714212446854*^9, 3.667142124471508*^9}}],

Cell[TextData[{
 Cell[BoxData["alphaByClustPair"], "MCode"],
 " is a list that gives the value of the interpolation parameter ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]], "Math"],
 " for each observation, organized by the two cluster means to which each \
observation is closest. ",
 Cell[BoxData["getNPhotonEff"], "MCode"],
 " (the two-argument version) takes that information and finds the effective \
photon number for each observation."
}], "Text",
 CellChangeTimes->{{3.6463901942579827`*^9, 3.646390202838928*^9}, {
   3.646391291655551*^9, 3.646391311601223*^9}, {3.6463919515899177`*^9, 
   3.646392076972514*^9}, {3.64639220562709*^9, 3.646392264407913*^9}, {
   3.6463958505384398`*^9, 3.6463959753768396`*^9}, {3.650025758863442*^9, 
   3.650025813918439*^9}, 3.662129353171671*^9, {3.6623291094439907`*^9, 
   3.662329111127388*^9}, 3.662329145391398*^9, {3.662329219094757*^9, 
   3.6623292228562317`*^9}, {3.667142134154956*^9, 3.667142139796599*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getNPhotonEff", "[", 
   RowBox[{"dat_", ",", "nPhotonList_", ",", "clustMeanTrace_"}], "]"}], ":=",
   "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "alphaByClustPair", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"alphaByClustPair", "=", 
      RowBox[{"getAlphaByClustPair", "[", 
       RowBox[{"dat", ",", "clustMeanTrace"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"getNPhotonEff", "[", 
      RowBox[{"alphaByClustPair", ",", "nPhotonList"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.646133844100559*^9, 3.6461338652229595`*^9}, {
   3.646136209544359*^9, 3.646136236813159*^9}, {3.646150090692768*^9, 
   3.646150100442768*^9}, {3.6461508526515675`*^9, 3.646150867487168*^9}, 
   3.66212988764701*^9, {3.662220610330814*^9, 3.662220613897242*^9}, {
   3.662329655668778*^9, 3.662329657477179*^9}, {3.662329796969894*^9, 
   3.662329798272953*^9}, {3.662329961610036*^9, 3.662329962652274*^9}}],

Cell[TextData[{
 Cell[BoxData["getAlphaByClustPair"], "MCode"],
 " returns a list of ordered triples that give the cluster means closest to a \
group of observations and the alpha values for those observations. ",
 Cell[BoxData[
  RowBox[{"msDev", "\[LeftDoubleBracket]", 
   RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], "MCode"],
 " is the mean square deviation of observation ",
 Cell[BoxData["i"], "MCode"],
 " to cluster mean ",
 Cell[BoxData["j"], "MCode"],
 ", and ",
 Cell[BoxData[
  RowBox[{
  "twoMinIndex", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
  "MCode"],
 " is a pair of indices giving the two cluster means with the lowest mean \
square deviations to observation ",
 Cell[BoxData["i"], "MCode"],
 " (",
 "i.e.",
 " a pair of indices giving the two columns with the smallest elements in row \
",
 Cell[BoxData["i"], "MCode"],
 " of ",
 Cell[BoxData["msDev"], "MCode"],
 "). ",
 Cell[BoxData["iObsTwoMinIndex"], "MCode"],
 " pairs the relevant observation index with each pair in ",
 Cell[BoxData["twoMinIndex"], "MCode"],
 ". In the next line, the ",
 Cell[BoxData["GatherBy"], "MCode"],
 " groups the elements of ",
 Cell[BoxData["iObsTwoMinIndex"], "MCode"],
 " by their lowest-deviation index pairs, so that each element of ",
 Cell[BoxData["iObsTwoMinIndexGroup"], "MCode"],
 " is a list of elements of ",
 Cell[BoxData["iObsTwoMinIndex"], "MCode"],
 " that all have the same pair of nearest cluster means. Mapping ",
 Cell[BoxData["groupCommon"], "MCode"],
 " onto each of these lists in ",
 Cell[BoxData["iObsTwoMinIndexGroup"], "MCode"],
 " converts them into a more useful form; each element of ",
 Cell[BoxData["twoMinIndexIObsList"], "MCode"],
 " is now a list of length two, with the first entry being a pair of \
nearest-mean indices and the second being a list of observation indices whose \
nearest two means correspond to the pair in the first entry. The output is a \
list with an entry for each distinct ordered pair of nearest means. Each \
entry contains a pair of nearest-mean indices, a list of observations whose \
nearest means are those two, and a list giving the alpha value for each of \
those observations."
}], "Text",
 CellChangeTimes->{{3.646393499100277*^9, 3.646393554071725*^9}, {
   3.646393606491027*^9, 3.646393617973553*^9}, {3.646393656185708*^9, 
