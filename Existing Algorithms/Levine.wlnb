Cell[TextData[{
 "Now we read in the data and apply a noise filter. ",
 Cell[BoxData["readTESandFilter"], "MCode"],
 ", defined in Section ",
 
 CounterBox["Section", "FDefReading"],
 ".",
 
 CounterBox["Subsection", "FDefReading"],
 ", takes the data from the set of files specified in the options above and \
applies a Hanning filter to it. We can then take a random sample and reduce \
the dataset to a smaller size, if desired, but by default we keep all of the \
observations. ",
 Cell[BoxData["dat"], "MCode"],
 " is a list of lists\[LongDash]each sublist corresponds to a waveform in the \
data and lists its values at regular time points."
}], "Text",
 CellChangeTimes->{{3.6452843219248075`*^9, 3.6452843701070075`*^9}, {
   3.6452844536054077`*^9, 3.645284453621008*^9}, {3.6452844886116076`*^9, 
   3.6452845136998076`*^9}, {3.645284576278208*^9, 3.6452846177932076`*^9}, {
   3.6452851829024076`*^9, 3.645285189956608*^9}, {3.6452857704796076`*^9, 
   3.6452858291046076`*^9}, {3.6453525605354385`*^9, 
   3.6453525613934383`*^9}, {3.645797442994195*^9, 3.6457974656453953`*^9}, {
   3.646562310448186*^9, 3.6465623590125685`*^9}, {3.6478779410758653`*^9, 
   3.647877952690191*^9}, 3.6478781697719994`*^9, {3.6622232197377167`*^9, 
   3.6622232342348623`*^9}, {3.662223266161454*^9, 3.6622232665214777`*^9}, 
   3.665785658246607*^9, 3.665789077908453*^9, {3.667091028249202*^9, 
   3.667091039756093*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"readAndFilterData", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"print", "[", 
     RowBox[{
     "0", ",", "\"\<PIKA: about to read data. iNPhoton \>\"", ",", 
      "iNPhoton"}], "]"}], ";", 
    RowBox[{"dat", "=", 
     RowBox[{"readTESandFilter", "[", 
      RowBox[{"iNPhoton", ",", "iDataSet", ",", "nTime", ",", "fileInfo"}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"print", "[", 
     RowBox[{"0", ",", "\"\<PIKA: {nObs,nTime} \>\"", ",", 
      RowBox[{"Dimensions", "[", "dat", "]"}]}], "]"}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"nDatUse", " ", ">", " ", "0"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dat", "=", 
        RowBox[{"randomSample", "[", 
         RowBox[{"dat", ",", "nDatUse"}], "]"}]}], ";", 
       RowBox[{"print", "[", 
        RowBox[{
        "0", ",", 
         "\"\<PIKA: nDatUse \[Ellipsis] reduced to {nObs, nTime} \>\"", ",", 
         RowBox[{"Dimensions", "[", "dat", "]"}]}], "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
