   3.662758398769432*^9, 3.6627584071987333`*^9}, 3.662759564524029*^9}],

Cell[TextData[{
 Cell[BoxData["getIObsKeepA"], "MCode"],
 " takes the list of waveforms rejected because of misplaced peaks and \
too-large endpoints and combines that with the information on each waveform\
\[CloseCurlyQuote]s number of maxima to return a list of the indices of all \
of the waveforms that should be rejected due to background radiation."
}], "Text",
 CellChangeTimes->{{3.64641159239674*^9, 3.6464117097823887`*^9}, {
  3.661699432899012*^9, 3.661699432906385*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getIObsKeepA", "[", 
   RowBox[{"datPeakNum_", ",", "iObsDrop_", ",", "datPeakNumCut_"}], "]"}], ":=",
   "\[IndentingNewLine]", 
  RowBox[{"Complement", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Pick", "[", 
     RowBox[{
      RowBox[{"Range", "[", 
       RowBox[{"Length", "[", "datPeakNum", "]"}], "]"}], ",", 
      RowBox[{"Thread", "[", 
       RowBox[{"datPeakNum", "<", "datPeakNumCut"}], "]"}]}], "]"}], ",", 
    "\[IndentingNewLine]", "iObsDrop"}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.645283295053608*^9, {3.646132180116559*^9, 3.646132206979759*^9}, {
