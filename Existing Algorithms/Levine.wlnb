Cell["\<\
The following code graphs samples of waveforms from the middle three clusters.\
\>", "Text",
 CellChangeTimes->{{3.6453581492865877`*^9, 3.645358175135788*^9}, {
  3.647882710588572*^9, 3.6478827218772993`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"graphSampleMiddleClusters", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p4a", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"randomSample", "[", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iObsOfClust", "\[LeftDoubleBracket]", " ", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "-", "1"}], " ", 
           "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
         "mSample"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p4b", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"randomSample", "[", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iObsOfClust", "\[LeftDoubleBracket]", " ", 
           RowBox[{"Round", "[", 
            RowBox[{"nClust", "/", "2"}], "]"}], " ", 
           "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
         "mSample"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", "Green"}], ",", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p4c", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"randomSample", "[", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iObsOfClust", "\[LeftDoubleBracket]", " ", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "+", "1"}], " ", 
           "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
         "mSample"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p4", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"p4c", ",", "p4b", ",", "p4a", ",", "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Time (input units)\>\"", ",", "\"\<Voltage (input units)\>\""}],
          "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotLabel", "\[Rule]", 
        RowBox[{
         RowBox[{"ToString", "[", "mSample", "]"}], "<>", 
         "\"\< traces for three clusters n=\>\"", "<>", "\[IndentingNewLine]", 
         RowBox[{"ToString", "[", 
          RowBox[{"nPhotonOfClust", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "-", "1"}], 
           "\[RightDoubleBracket]"}], "]"}], "<>", "\"\< (red) to n=\>\"", "<>",
          "\[IndentingNewLine]", 
         RowBox[{"ToString", "[", 
          RowBox[{"nPhotonOfClust", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "+", "1"}], 
           "\[RightDoubleBracket]"}], "]"}], "<>", "\"\< (blue)\>\""}]}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"DisplayFunction", "\[Rule]", "$DisplayFunction"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "\[Rule]", "outputImageSize"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<Sample Traces\>\"", ",", 
      "\"\<Before optimization:\>\""}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{"p4", ",", "iNPhotonAvgList", ",", "\"\<Sample Traces\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.6451819233573217`*^9, 3.645181935478522*^9}, {
