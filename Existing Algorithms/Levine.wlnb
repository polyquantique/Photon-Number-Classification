Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ". Updating the Poisson Log-Likelihood"
}], "Subsection",
 CellChangeTimes->{{3.6436460678713627`*^9, 3.643646101066245*^9}, {
   3.6436462332744102`*^9, 3.643646240030994*^9}, {3.6458727497522297`*^9, 
   3.64587275042303*^9}, 3.646134428616959*^9, {3.6464814940418873`*^9, 
   3.646481495461478*^9}, {3.6470955295389585`*^9, 3.647095530693351*^9}, 
   3.662129352951083*^9}],

Cell[TextData[{
 "From equation (",
 
 CounterBox["DisplayFormulaNumbered", "eqPoisson"],
 "), the Poisson log-likelihood is"
}], "Text",
 CellChangeTimes->{{3.643646551269812*^9, 3.6436465630275364`*^9}, {
   3.646150090037568*^9, 3.646150099771968*^9}, {3.6461508515439677`*^9, 
   3.646150866395168*^9}, {3.6464814794715805`*^9, 3.64648150920499*^9}, {
   3.647616502011145*^9, 3.647616512016681*^9}, 3.6657860336131277`*^9, {
   3.669472828368482*^9, 3.669472830192533*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"ln", " ", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalL]", "P"], "(", 
      RowBox[{
       SubscriptBox["m", "0"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["m", "a"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["m", "b"], ",", "\[Ellipsis]", ",", 
       RowBox[{
        SubscriptBox["m", 
         RowBox[{
          SubscriptBox["n", "0"], "+", "K", "-", "1"}]], ";", "\[Mu]"}]}], 
      ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[Mu]"}], " ", "M"}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", 
        SubscriptBox["n", "0"]}], 
       RowBox[{
        SubscriptBox["n", "0"], "+", "K", "-", "1"}]], 
      RowBox[{
       SubscriptBox["m", "n"], "[", 
       RowBox[{
        RowBox[{"n", " ", "ln", " ", "\[Mu]"}], "-", 
        RowBox[{"ln", "(", 
         RowBox[{"n", "!"}], ")"}]}], "]"}]}]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.643646646958799*^9, 3.6436466986662674`*^9}, {
   3.643646738551612*^9, 3.6436468238754654`*^9}, {3.643647114552143*^9, 
   3.6436472187779427`*^9}, {3.643647260407743*^9, 3.6436472665923433`*^9}, {
   3.646150090037568*^9, 3.646150099787568*^9}, {3.6461508515751677`*^9, 
   3.6461508664263678`*^9}, {3.6464816680063686`*^9, 3.646481673793931*^9}, 
   3.6464941540161643`*^9, {3.662327581946355*^9, 3.66232759017931*^9}, 
   3.662327632266526*^9, {3.6623276843416977`*^9, 3.662327702663125*^9}}],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"\[Sum]", 
     SubscriptBox["m", "n"]}]}], TraditionalForm]], "Math"],
 ". If some waveform is transferred from the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "b"}], TraditionalForm]], "Math"],
 " to the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "a"}], TraditionalForm]], "Math"],
 " cluster, then the change in the objective function consists of a term from \
the Poisson factor and a term from the combinatorial factor from equation (",
 
 CounterBox["DisplayFormulaNumbered", "eqCombo"],
 "). The term due to the Poisson factor is"
}], "Text",
 CellChangeTimes->{{3.6436472906691427`*^9, 3.6436473134385433`*^9}, {
   3.643647380209943*^9, 3.643647467227543*^9}, {3.643647499918543*^9, 
   3.643647515905943*^9}, {3.643728643149109*^9, 3.6437286444907002`*^9}, {
   3.6461500901155677`*^9, 3.646150099849968*^9}, {3.6461508516375675`*^9, 
   3.6461508664887676`*^9}, {3.6464816765395136`*^9, 3.646481696569785*^9}, {
   3.6476166276101403`*^9, 3.6476166388118687`*^9}, {3.66224324672261*^9, 
   3.6622432488894053`*^9}, 3.665786037485977*^9, {3.6689235746973133`*^9, 
   3.668923576520687*^9}, {3.669472855984435*^9, 3.66947285736833*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[CapitalDelta]", "\[InvisibleSpace]", "ln", " ", 
    SubscriptBox["\[ScriptCapitalL]", "P"]}], "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"ln", " ", 
      RowBox[{
       SubscriptBox["\[ScriptCapitalL]", "P"], "(", 
       RowBox[{
        SubscriptBox["m", "0"], ",", "\[Ellipsis]", ",", 
        RowBox[{
         SubscriptBox["m", "a"], "+", "1"}], ",", "\[Ellipsis]", ",", 
        RowBox[{
         SubscriptBox["m", "b"], "-", "1"}], ",", "\[Ellipsis]", ",", 
        RowBox[{
         SubscriptBox["m", 
          RowBox[{
           SubscriptBox["n", "0"], "+", "K", "-", "1"}]], ";", "\[Mu]"}]}], 
       ")"}]}], "-", 
     RowBox[{"ln", " ", 
      RowBox[{
       SubscriptBox["\[ScriptCapitalL]", "P"], "(", 
       RowBox[{
        SubscriptBox["m", "0"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["m", "a"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["m", "b"], ",", "\[Ellipsis]", ",", 
        RowBox[{
         SubscriptBox["m", 
          RowBox[{
           SubscriptBox["n", "0"], "+", "K", "-", "1"}]], ";", "\[Mu]"}]}], 
       ")"}]}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "-", "b"}], ")"}], "ln", " ", "\[Mu]"}], "-", 
     RowBox[{"ln", "(", 
      RowBox[{"a", "!"}], ")"}], "+", 
     RowBox[{
      RowBox[{"ln", "(", 
       RowBox[{"b", "!"}], ")"}], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.643647554330543*^9, 3.643647575804143*^9}, {
   3.643647620551743*^9, 3.643647697845343*^9}, {3.643647739397543*^9, 
   3.643647791273943*^9}, {3.643647986329543*^9, 3.6436480670125427`*^9}, 
   3.6458747551524296`*^9, {3.6461500901155677`*^9, 3.6461500998655677`*^9}, {
   3.6461508516531677`*^9, 3.646150866519968*^9}, {3.646482563975416*^9, 
   3.646482564381014*^9}, {3.646486489699877*^9, 3.646486490058675*^9}, 
   3.646487982906705*^9, {3.646488133664139*^9, 3.646488137486114*^9}, 
   3.6464941973058867`*^9, {3.6464943989501944`*^9, 3.646494436639553*^9}, {
   3.662137019765456*^9, 3.662137028556858*^9}, 3.662207665067608*^9, {
   3.662327634563281*^9, 3.66232763892689*^9}, {3.66232773903016*^9, 
   3.6623277440537863`*^9}}],

Cell[TextData[{
 "(The notation suggests ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", ">", "a"}], TraditionalForm]], "Math"],
 ", but the same formula applies for the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "<", "a"}], TraditionalForm]], "Math"],
 " case.)"
}], "Text",
 CellChangeTimes->{{3.643647814905343*^9, 3.643647875356743*^9}, {
   3.643648084528543*^9, 3.643648155581543*^9}, {3.6464807958227663`*^9, 
   3.646480807460292*^9}, 3.6464814605957017`*^9, {3.6464826056427493`*^9, 
   3.6464826149870896`*^9}}],

Cell["\<\
The combinatorial factor\[CloseCurlyQuote]s treatment is similar. The \
logarithm of the factor is\
\>", "Text",
 CellChangeTimes->{{3.643647814905343*^9, 3.643647875356743*^9}, {
   3.643648084528543*^9, 3.643648155581543*^9}, {3.6464807958227663`*^9, 
   3.646480807460292*^9}, {3.6464814605957017`*^9, 3.646481462779688*^9}, 
   3.662128810920076*^9}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"ln", " ", 
    SubscriptBox["\[ScriptCapitalL]", "C"]}], "=", 
   RowBox[{
    RowBox[{"ln", "(", 
     RowBox[{"M", "!"}], ")"}], "-", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", 
       SubscriptBox["n", "0"]}], 
      RowBox[{
       SubscriptBox["n", "0"], "+", "K", "-", "1"}]], 
     RowBox[{
      RowBox[{"ln", "(", 
       RowBox[{
        SubscriptBox["m", "n"], "!"}], ")"}], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.646480830376545*^9, 3.646480948764186*^9}, 
   3.6464816319606028`*^9, 3.6464823594607277`*^9, {3.6464879695531907`*^9, 
   3.6464879956362233`*^9}},
 CellTags->"eqLogCombo"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["M", TraditionalForm]], "Math"],
 " does not change with a transfer, so only the second term contributes to \
the change:"
}], "Text",
 CellChangeTimes->{{3.643647814905343*^9, 3.643647875356743*^9}, {
  3.643648084528543*^9, 3.643648155581543*^9}, {3.6464807958227663`*^9, 
  3.6464808104398727`*^9}, {3.646481007591409*^9, 3.6464810434087796`*^9}, {
