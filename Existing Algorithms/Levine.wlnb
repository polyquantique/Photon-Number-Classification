Cell[CellGroupData[{

Cell["About the Authors", "SectionAboutAuthor",
 CellChangeTimes->{{3.6471890927015123`*^9, 3.6471891073296185`*^9}}],

Cell["\<\
Brian P. M. Morris is a senior in the Science, Mathematics, and Computer \
Science Magnet Program at Montgomery Blair High School in Silver Spring, \
Maryland, was in the Summer High School Intern Program at the National \
Institute of Standards and Technology, and is a 2016 Intel Science Talent \
Search Semifinalist.\
\>", "TextAboutAuthor",
 CellChangeTimes->{{3.6471892480913553`*^9, 3.647189269940615*^9}, {
   3.6471893195291986`*^9, 3.647189337346285*^9}, {3.64718953145063*^9, 
   3.647189532199425*^9}, 3.647862507986754*^9, 3.661703134410681*^9, 
   3.6621293538522997`*^9, {3.664882484476225*^9, 3.6648825215965347`*^9}, 
   3.6648825767965527`*^9, {3.664882649900388*^9, 3.664882692428445*^9}, 
   3.664882820028309*^9, {3.665135407025343*^9, 3.665135439633168*^9}, 
   3.665337429224201*^9, {3.665789130151642*^9, 3.665789131207584*^9}, {
   3.668923413274055*^9, 3.668923413649234*^9}}],

Cell["\<\
Zachary H. Levine is a physicist at the National Institute of Standards and \
Technology in the Infrared Technology Group and is a Fellow of the American \
Physical Society.\[NonBreakingSpace]He is a graduate of MIT and the \
University of Pennsylvania.\
\>", "TextAboutAuthor",
 CellChangeTimes->{{3.647189159378685*^9, 3.6471891742819896`*^9}, 
   3.6617031296834583`*^9, {3.6651354754577217`*^9, 3.665135479952873*^9}, {
   3.6651358702566433`*^9, 3.665135874209683*^9}, {3.665137054322845*^9, 
   3.665137055058692*^9}, 3.6653374362932253`*^9, {3.665789139911121*^9, 
   3.665789153942748*^9}}],

Cell[TextData[{
 StyleBox["Brian P. M. Morris", "AboutAuthorB"],
 "\n",
 StyleBox["Montgomery Blair High School\nSilver Spring, Maryland 20901", 
  "AboutAuthorI"]
}], "TextAboutAuthor",
 CellChangeTimes->{{3.6472558623399982`*^9, 3.647255923725605*^9}, {
  3.647255989796164*^9, 3.647256015659831*^9}, {3.6617030889870577`*^9, 
  3.661703089306899*^9}}],

