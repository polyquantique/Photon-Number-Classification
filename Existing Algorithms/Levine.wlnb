   RowBox[{
    RowBox[{"-", "mu"}], "*", 
    RowBox[{"Total", "[", "freqList", "]"}]}], " ", "+", " ", 
   RowBox[{
    RowBox[{"nList", ".", "freqList"}], "*", 
    RowBox[{"Log", "[", "mu", "]"}]}], "-", 
   RowBox[{"freqList", " ", ".", 
    RowBox[{"LogGamma", "[", 
     RowBox[{"nList", "+", "1."}], "]"}]}]}]}]], "Input",
