   3.665789078193612*^9, 3.665789078268126*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getIObsKeep", "[", 
   RowBox[{
   "dat_", ",", "peakPosCut_", ",", "peakValCut_", ",", "peakNumCut_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "datPeakLoc", ",", "iObsDropA", ",", "datPeakLocVal", ",", 
      "datPeakLocValBig", ",", "datPeakNum", ",", "iObsDrop", ",", "iObsKeep",
       ",", "peakPosList", ",", "peakValList"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"peakPosList", ",", "peakValList"}], "}"}], "=", 
      RowBox[{"getMaxAndPosList", "[", "dat", "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "peak", " ", "position", " ", "and", " ", "value", " ", "for", " ", 
       "each", " ", "obs"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"iObsDrop", "=", 
      RowBox[{"getIObsDrop", "[", 
       RowBox[{
       "peakPosList", ",", "peakValList", ",", "peakPosCut", ",", 
        "peakValCut"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"iObsDropA", "=", 
      RowBox[{"getIObsDropA", "[", 
       RowBox[{"dat", ",", "peakValCut"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"iObsDrop", "=", 
      RowBox[{"Union", "[", 
       RowBox[{"iObsDrop", ",", "iObsDropA"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"datPeakLoc", "=", 
      RowBox[{"getDatPeakLoc", "[", "dat", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"datPeakLocVal", "=", 
      RowBox[{"getDatPeakLocVal", "[", 
       RowBox[{"datPeakLoc", ",", "dat"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"datPeakLocValBig", "=", 
      RowBox[{"getDatPeakLocValBig", "[", 
       RowBox[{"datPeakLocVal", ",", "peakValCut"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"datPeakNum", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"First", ",", 
        RowBox[{"Map", "[", 
         RowBox[{"Dimensions", ",", "datPeakLocValBig"}], "]"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"iObsKeep", "=", 
      RowBox[{"getIObsKeepA", "[", 
       RowBox[{"datPeakNum", ",", "iObsDrop", ",", "peakNumCut"}], 
       "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
