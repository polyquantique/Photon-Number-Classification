        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], "n"]}]}], "+", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        SubscriptBox["m", "n"], "2"]], 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        RowBox[{"i", ",", 
         RowBox[{"j", "\[Element]", 
          SubscriptBox["C", "n"]}]}]], 
       RowBox[{
        SubscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "i"], "\[CenterDot]", 
        RowBox[{
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "j"], "."}]}]}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
