Cell[TextData[{
 
 CounterBox["Section"],
 ". Terminology and Main Loop (",
 Cell[BoxData["runPika"], "MCode"],
 ")"
}], "Section",
 CellChangeTimes->{{3.647358487140662*^9, 3.647358512911697*^9}, {
   3.6476159813702855`*^9, 3.647615982665077*^9}, {3.650789729831324*^9, 
   3.65078975783117*^9}, {3.650789828262252*^9, 3.6507898448281775`*^9}, {
   3.6507899458928027`*^9, 3.650789956343999*^9}, 3.662207515326564*^9},
 CellTags->"Section3"],

Cell[TextData[{
 "The code and documentation are written in the context of \
few-photon-counting with a TES, so variables and functions are often named \
for physical quantities and concepts specific to the original purpose of the \
algorithm instead of more abstract ones (e.g. ",
 Cell[BoxData["readTES"], "MCode"],
 " instead of ",
 Cell[BoxData["readData"], "MCode"],
 "). In addition, the terms \[OpenCurlyDoubleQuote]trace,\
\[CloseCurlyDoubleQuote] \[OpenCurlyDoubleQuote]observation,\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]waveform\
\[CloseCurlyDoubleQuote] are used interchangeably and synonymously to mean a \
single detector response in the set of signals\[LongDash]that is, a regular \
sampling of voltage over time that records the response to a single optical \
pulse fired at the TES. In the program a trace is a list of voltage values."
}], "Text",
 CellChangeTimes->{{3.6473590568958097`*^9, 3.6473590663649487`*^9}, {
  3.647359113585846*^9, 3.647359133382119*^9}, {3.6473591756110487`*^9, 
