Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 " ",
 "Background Rejection"
}], "Subsection",
 CellChangeTimes->{{3.6461309265033593`*^9, 3.6461309305749593`*^9}, {
   3.6461332160289593`*^9, 3.646133216387759*^9}, {3.6461343443457594`*^9, 
   3.6461343653277593`*^9}, {3.646411714540358*^9, 3.646411714649557*^9}, 
   3.6621293532282677`*^9}],

Cell[TextData[{
 "If background rejection is enabled, ",
 Cell[BoxData["getIObsKeep"], "MCode"],
 " returns the indices of the observations that should stay in the dataset, \
based on the preset parameters for rejection. ",
 Cell[BoxData["peakPosList"], "MCode"],
 " and ",
 Cell[BoxData["peakValList"], "MCode"],
 " are lists specifying the position and value of the maximum in each \
waveform in ",
 Cell[BoxData["dat"], "MCode"],
 ". ",
 Cell[BoxData["getIObsDrop"], "MCode"],
 " returns the indices of the waveforms that should be removed because their \
peak positions and values exceed their respective cutoff values, and ",
 Cell[BoxData["getIObsDropA"], "MCode"],
 " lists those whose endpoints are greater than the value cutoff, indicating \
that the sensor was registering a background photon at the beginning or end \
of the pulse. These two lists to remove are combined into ",
 Cell[BoxData["iObsDrop"], "MCode"],
 ". Each element of ",
 Cell[BoxData["datPeakLoc"], "MCode"],
 " lists the positions of the local maxima of a waveform in ",
 Cell[BoxData["dat"], "MCode"],
 ", ",
 Cell[BoxData["datPeakLocVal"], "MCode"],
 " pairs each of those positions with the waveform\[CloseCurlyQuote]s value \
there, and ",
 Cell[BoxData["datPeakLocValBig"], "MCode"],
 " reduces ",
 Cell[BoxData["datPeakLocVal"], "MCode"],
 " to the maxima that exceed the peak value cutoff. ",
 Cell[BoxData["datPeakNum"], "MCode"],
 " gives the number of maxima in each waveform, and ",
 Cell[BoxData["getIObsKeepA"], "MCode"],
 " returns the indices that should stay in the ",
 "dataset",
 " (i.e. those that are not in ",
 Cell[BoxData["iObsDrop"], "MCode"],
 " and that have fewer maxima than ",
 Cell[BoxData["peakNumCut"], "MCode"],
 ")."
}], "Text",
 CellChangeTimes->{{3.6464076832282877`*^9, 3.6464076940198183`*^9}, {
   3.646407732069175*^9, 3.646407797515356*^9}, {3.6464079943096957`*^9, 
   3.6464080772745647`*^9}, {3.6464081399587593`*^9, 3.646408147510111*^9}, {
   3.6464082439536934`*^9, 3.646408477175*^9}, {3.6464089654502735`*^9, 
