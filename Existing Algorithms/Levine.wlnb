Cell[TextData[{
 "The Poisson-Influenced ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-means Algorithm (PIKA) was first described in [",
 
 CounterBox["Reference", "RefOrigPaper"],
 "] as a way of calibrating a transition edge sensor (TES), a superconducting \
few-photon detector. A TES can discern the number of photons in a very weak \
pulse of light, but it must be calibrated in order to do so. Our \
implementation deals with photon counting, but many of its features are \
applicable to more general probability-assisted ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-means clustering situations."
}], "Text",
 CellChangeTimes->{{3.647358452040887*^9, 3.647358452274885*^9}, {
   3.6473612000568714`*^9, 3.647361200540468*^9}, {3.6473612914098854`*^9, 
   3.647361318506912*^9}, {3.647361373855357*^9, 3.647361390250852*^9}, {
   3.6473614276126127`*^9, 3.6473614364109564`*^9}, {3.6473615224936595`*^9, 
   3.6473615617898073`*^9}, {3.6473616827046323`*^9, 3.6473618117314053`*^9}, 
   3.6473618456143885`*^9, {3.6473619061264005`*^9, 3.647361959852456*^9}, {
   3.6473620081341467`*^9, 3.6473620143117065`*^9}, {3.6475955954466343`*^9, 
   3.64759566935896*^9}, {3.6476124455187635`*^9, 3.6476126032857633`*^9}, {
   3.6479457994816*^9, 3.6479458483036966`*^9}, {3.650378126852861*^9, 
   3.6503781509811087`*^9}, {3.650378561829425*^9, 3.650378590633957*^9}, {
   3.650378737573924*^9, 3.650378809893718*^9}, {3.6503790121537733`*^9, 
