Cell[BoxData[
 RowBox[{
  RowBox[{"graphNewSampleMiddleClusters", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p8a", "=", 
     RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"randomSample", "[", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iObsOfClustNew", "\[LeftDoubleBracket]", " ", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "-", "1"}], " ", 
           "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
         "mSample"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", "\[IndentingNewLine]", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p8b", "=", 
     RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"randomSample", "[", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iObsOfClustNew", "\[LeftDoubleBracket]", " ", 
           RowBox[{"Round", "[", 
            RowBox[{"nClust", "/", "2"}], "]"}], " ", 
           "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
         "mSample"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", "Green"}], ",", "\[IndentingNewLine]", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p8c", "=", 
     RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"randomSample", "[", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iObsOfClustNew", "\[LeftDoubleBracket]", " ", 
           RowBox[{
            RowBox[{"Round", "[", 
             RowBox[{"nClust", "/", "2"}], "]"}], "+", "1"}], " ", 
           "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
         "mSample"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", "\[IndentingNewLine]", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p8", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"p8c", ",", "p8b", ",", "p8a", ",", "\[IndentingNewLine]", 
