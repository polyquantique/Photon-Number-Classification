       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
       RowBox[{
       "PlotLabel", "\[Rule]", "\"\<Optimized cluster mean traces\>\""}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "outputImageSize"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p9", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"p6", ",", "p9a", ",", 
       RowBox[{"DisplayFunction", "\[Rule]", "$DisplayFunction"}], ",", 
       RowBox[{
       "PlotLabel", "\[Rule]", 
        "\"\<Initial (green) and optimized (blue) cluster mean \
traces\>\""}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
