Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 " ",
 "Output Organization"
}], "Subsection",
 CellChangeTimes->{{3.6472591665932355`*^9, 3.647259182157336*^9}, 
   3.662129353614595*^9}],

Cell[TextData[{
 Cell[BoxData["outputCreateTabs"], "MCode"],
 " creates several list structures (global variables) of the appropriate \
dimensions to accommodate output from the specified number of runs of PIKA. \
The output is organized into a ",
 Cell[BoxData["TabView"], "MCode"],
 ", with each run receiving a tab that contains a nested view with graphical \
and textual output. ",
 Cell[BoxData["outputNameList"], "MCode"],
 " stores the names of the labels in the subview (which are the same for all \
runs), and ",
 Cell[BoxData["outputContentTable"], "MCode"],
 " stores the output content for each run and sublabel. (Content is stored as \
a list that later becomes a ",
 Cell[BoxData["Column"], "MCode"],
 ".) Each run\[CloseCurlyQuote]s tab also has a space above its subview for \
other information, which is stored in ",
 Cell[BoxData["outputTopList"], "MCode"],
 ". Finally, there is another tab on the level of the runs with general \
textual (",
 Cell[BoxData["outputGeneralLog"], "MCode"],
 ") and graphical (",
 Cell[BoxData["outputGeneralGraphics"], "MCode"],
 ") information about the data read in."
}], "Text",
 CellChangeTimes->{{3.647356755915759*^9, 3.647357341645204*^9}, {
  3.661700838091805*^9, 3.661700871145792*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"outputCreateTabs", "[", "nRuns_", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"outputContentTable", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "nRuns"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"outputNameList", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputTopList", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "nRuns"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"outputGeneralLog", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputGeneralGraphics", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 CellChangeTimes->{{3.6472672350633106`*^9, 3.6472672416202683`*^9}, {
   3.647267300536891*^9, 3.647267319858567*^9}, {3.647267464959237*^9, 
   3.6472674741183786`*^9}, {3.6472677552501774`*^9, 
   3.6472677807202144`*^9}, {3.647267880228177*^9, 3.647267937155612*^9}, {
