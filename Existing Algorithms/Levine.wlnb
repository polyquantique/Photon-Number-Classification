   3.662327044341461*^9}, {3.66232709089226*^9, 3.662327111386965*^9}}],

Cell[TextData[{
 "(Note the summation over ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "n"], "'"}], TraditionalForm]], "Math"],
 ", not ",
 Cell[BoxData[
  FormBox[
