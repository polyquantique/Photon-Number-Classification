   3.662329658286209*^9, 3.662329666572529*^9}, {3.662329799068647*^9, 
   3.662329805538623*^9}, {3.6623299632124662`*^9, 3.662329967144216*^9}, 
   3.662759554400324*^9, {3.665321728002413*^9, 3.66532175734651*^9}}],

Cell[TextData[{
 Cell[BoxData["getAlpha"], "MCode"],
 " takes a list of observations and a pair of ideal waveforms and finds the \
value of alpha for each observation. Alpha for a waveform ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["V",
     FontWeight->"Bold",
     FontSlant->"Plain"], "i"], TraditionalForm]], "Math"],
 " is the value ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "i"], TraditionalForm]], "Math"],
 " that minimizes the RMS deviations of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       SubscriptBox["\[Alpha]", "i"]}], ")"}], 
     SubscriptBox[
      OverscriptBox[
       StyleBox["V",
        FontWeight->"Bold",
        FontSlant->"Plain"], "-"], "n"]}], "+", 
    RowBox[{
     SubscriptBox["\[Alpha]", "i"], 
     SubscriptBox[
      OverscriptBox[
       StyleBox["V",
        FontWeight->"Bold",
        FontSlant->"Plain"], "-"], 
      RowBox[{"n", "'"}]]}]}], TraditionalForm]], "Math"],
 " from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["V",
     FontWeight->"Bold",
     FontSlant->"Plain"], "i"], TraditionalForm]], "Math"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Plain"], "-"],
     FontWeight->"Bold"], "n"], TraditionalForm]], "Math"],
 " is the closest mean waveform (the first entry in the second argument of ",
 Cell[BoxData["getAlpha"], "MCode"],
 ") and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontWeight->"Bold",
      FontSlant->"Plain"], "-"], 
    RowBox[{"n", "'"}]], TraditionalForm]], "Math"],
 " is the second closest. ",
 Cell[BoxData["getAlpha"], "MCode"],
 " finds the minimizing value ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "i"], "=", 
    FractionBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox[
         OverscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "-"], "n"], "-", 
        SubscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "i"]}], ")"}], " ", "\[CenterDot]", " ", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox[
         OverscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "-"], "n"], "-", 
        SubscriptBox[
         OverscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "-"], 
         RowBox[{"n", "'"}]]}], ")"}]}], 
     RowBox[{"||", 
      RowBox[{
       SubscriptBox[
        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], "n"], "-", 
       SubscriptBox[
        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], 
        RowBox[{"n", "'"}]]}], 
      SuperscriptBox["||", "2"]}]]}], TraditionalForm]], "Math"],
 " from equation (",
 
 CounterBox["DisplayFormulaNumbered", "eqAlpha"],
 ") for each observation in ",
 Cell[BoxData["traces"], "MCode"],
 ". A value of 0 indicates perfect agreement with the first ideal trace, and \
a value of 1 indicates perfect agreement with the second."
}], "Text",
 CellChangeTimes->{{3.646399427206321*^9, 3.646399492226904*^9}, {
