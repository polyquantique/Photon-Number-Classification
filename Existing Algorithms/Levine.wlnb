   3.647164482843425*^9, 3.6471645221083727`*^9}, {3.662222311398439*^9, 
   3.6622223198384037`*^9}, 3.662326939377057*^9, {3.662327098332253*^9, 
   3.6623271615935497`*^9}}],

Cell["By the second lemma, we have", "Text",
 CellChangeTimes->{{3.6471638502163134`*^9, 3.647163857595066*^9}, {
  3.650025601762369*^9, 3.6500256139179564`*^9}}],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["J", "n"], "'"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      SubscriptBox["m", "n"], 
      RowBox[{
       SubscriptBox["m", "n"], "'"}]], 
     SubscriptBox["J", "n"]}], "\[PlusMinus]", 
    RowBox[{
     FractionBox[
      SubscriptBox["m", "n"], 
      RowBox[{
       RowBox[{
        SubscriptBox["m", "n"], "'"}], 
       SubscriptBox["N", "t"]}]], 
     RowBox[{"(", 
      RowBox[{"||", 
       RowBox[{
        SubscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "p"], "-", 
        FormBox[
         StyleBox[
          SubscriptBox[
           OverscriptBox[
            StyleBox["V",
             FontWeight->"Bold",
             FontSlant->"Plain"], "-"], "n"],
          FontSlant->"Plain"],
         TraditionalForm]}], 
       SuperscriptBox["||", "2"], 
       RowBox[{"+", 
        FractionBox[
         RowBox[{
          SubscriptBox["N", "t"], 
          SubscriptBox["J", "n"]}], 
         SubscriptBox["m", "n"]]}]}], ")"}]}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         SubscriptBox["m", "n"], 
         RowBox[{
          SubscriptBox["m", "n"], "'"}]], "\[PlusMinus]", 
        FractionBox["1", 
         RowBox[{
          SubscriptBox["m", "n"], "'"}]]}], ")"}], 
      SubscriptBox["J", "n"]}], "\[PlusMinus]", 
     RowBox[{
      FractionBox[
       SubscriptBox["m", "n"], 
       RowBox[{
        SubscriptBox["m", "n"], "'"}]], 
      FractionBox[
       RowBox[{"||", 
        RowBox[{
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "p"], "-", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["V",
            FontWeight->"Bold",
            FontSlant->"Plain"], "-"], "n"]}], 
        SuperscriptBox["||", "2"]}], 
       SubscriptBox["N", "t"]]}]}]}], ","}], 
  TraditionalForm]}], "DisplayFormula",
 CellChangeTimes->{{3.6471643765805097`*^9, 3.647164385020056*^9}, {
  3.647164571996853*^9, 3.647164576692423*^9}, {3.647164611012203*^9, 
  3.6471647114143553`*^9}, {3.66222232186213*^9, 3.662222327318143*^9}, {
  3.66232717108156*^9, 3.662327218575644*^9}}],

Cell["and the theorem follows. \[EmptySquare]", "Text",
 CellChangeTimes->{{3.6471647265306587`*^9, 3.647164738214984*^9}}]
}, Open  ]]
}, Open  ]],

