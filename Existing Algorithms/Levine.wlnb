   3.662329979851527*^9, 3.6623299805566797`*^9}, {3.662758207848867*^9, 
   3.662758216669025*^9}}],

Cell[TextData[{
 Cell[BoxData["getDatPeakLocValBig"], "MCode"],
 " finds the maxima that exceed the cutoff among those returned by ",
 Cell[BoxData["getDatPeakLocVal"], "MCode"],
 "."
}], "Text",
 CellChangeTimes->{{3.6464114354945445`*^9, 3.6464114397427173`*^9}, {
