   3.646390919302537*^9, 3.6463909515207305`*^9}, {3.646391041159556*^9, 
   3.646391044965932*^9}, {3.646399412728614*^9, 3.646399415645795*^9}, {
   3.646401932080892*^9, 3.646401972171835*^9}, 3.646402025586893*^9, {
