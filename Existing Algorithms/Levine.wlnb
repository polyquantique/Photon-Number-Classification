   3.64587058239923*^9, {3.646150093297968*^9, 3.6461501030323677`*^9}, {
   3.6461508565983677`*^9, 3.646150871199968*^9}, {3.646567039934509*^9, 
   3.646567040652109*^9}, 3.6471661686258073`*^9, {3.6471670497081594`*^9, 
   3.647167057851307*^9}, {3.647250386824273*^9, 3.6472504320533834`*^9}, {
   3.647339706784457*^9, 3.647339729800706*^9}, 3.6473402376410427`*^9, {
   3.6473405778984575`*^9, 3.647340603341895*^9}, 3.647340668970674*^9, {
   3.6473544246175013`*^9, 3.647354461034068*^9}, 3.662129352310804*^9, {
   3.662129887460176*^9, 3.662129887474234*^9}, {3.6621299606892843`*^9, 
   3.6621299848586493`*^9}, 3.662220342075123*^9, {3.66232959496599*^9, 
   3.662329598934608*^9}, {3.662329742196024*^9, 3.662329745557775*^9}, {
   3.662329930436318*^9, 3.6623299325272017`*^9}, {3.662330144490456*^9, 
   3.662330149112915*^9}, {3.662761024399578*^9, 3.662761048384282*^9}, {
   3.665320364559754*^9, 3.665320366830823*^9}}],

Cell["\<\
This graphs the root mean square (RMS) deviations of each cluster to its mean.\
\>", "Text",
 CellChangeTimes->{{3.6457891633211975`*^9, 3.6457891900439973`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"graphClusterDeviationsFromMean", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p7", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"pair", "[", 
        RowBox[{"nPhotonOfClust", ",", 
         SqrtBox[
          FractionBox[
           RowBox[{" ", "sqDevOfClust", " "}], "nOfClust"]]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"AxesOrigin", "\[Rule]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Floor", "[", 
           RowBox[{
            RowBox[{"Min", "[", "nPhotonOfClust", "]"}], ",", "10"}], "]"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"Floor", "[", 
           RowBox[{
            RowBox[{"Min", "[", 
             SqrtBox[
              FractionBox[
               RowBox[{" ", "sqDevOfClust", " "}], "nOfClust"]], "]"}], ",", 
            "10"}], "]"}]}], "\[IndentingNewLine]", "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Joined", "\[Rule]", "False"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"PointSize", "[", "0.015", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Number of photons n\>\"", ",", 
          "\"\<RMS deviation (Voltage input units)\>\""}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
       "PlotLabel", "\[Rule]", 
        "\"\<RMS deviations of clusters to their means\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "\[Rule]", "outputImageSize"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<Cluster Deviations\>\"", ",", 
      "\"\<Before optimization:\>\""}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{
     "p7", ",", "iNPhotonAvgList", ",", "\"\<Cluster Deviations\>\""}], "]"}],
     ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.6451831665409393`*^9, 3.645183346941084*^9}, {
   3.6458947444051533`*^9, 3.645894750614953*^9}, {3.645964229850102*^9, 
   3.645964245465702*^9}, 3.646146137381168*^9, 3.646147141605568*^9, 
   3.6461471848019676`*^9, {3.646149892759968*^9, 3.6461498986411676`*^9}, {
   3.646149935769168*^9, 3.646149946829568*^9}, {3.646150025344368*^9, 
   3.646150037418768*^9}, {3.646150093360368*^9, 3.646150098617568*^9}, {
   3.6461504189403677`*^9, 3.6461504312019677`*^9}, {3.646150823666768*^9, 
   3.646150871246768*^9}, {3.64725057552846*^9, 3.6472506256683393`*^9}, {
   3.647339706815657*^9, 3.647339729800706*^9}, {3.647342486342613*^9, 
   3.6473425183068085`*^9}, {3.6473425649661093`*^9, 
   3.6473426232317357`*^9}, {3.647349602192381*^9, 3.6473496025979786`*^9}, 
   3.662129352318883*^9, 3.662129887478755*^9, {3.662220345585458*^9, 
   3.662220347644268*^9}, {3.6623296000893707`*^9, 3.662329600881051*^9}, {
   3.662329746297594*^9, 3.662329748628175*^9}, {3.662329932856221*^9, 
   3.6623299341381407`*^9}, {3.665246419089816*^9, 3.665246423520529*^9}}],

Cell[TextData[{
 "The optimization loop (Loop 2) is now ready to begin, apart from a few \
organizational tasks. First, since the optimization moves waveforms between \
clusters many times, we need a more convenient way to keep track of the \
clusters. ",
 Cell[BoxData["getIClustOfObs"], "MCode"],
 " converts ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 ", a list of lists, into ",
 Cell[BoxData["iClustOfObs"], "MCode"],
 ", a one-dimensional list, each element of which corresponds to an \
observation in ",
 Cell[BoxData["dat"], "MCode"],
 " and gives the index of the cluster to which that observation belongs."
}], "Text",
 CellChangeTimes->{{3.645789454602397*^9, 3.645789719880397*^9}, {
  3.6457899199347973`*^9, 3.645790068774397*^9}, {3.6457901046231976`*^9, 
  3.645790133529997*^9}, {3.6457903864995975`*^9, 3.645790405609597*^9}, {
  3.645790518881197*^9, 3.645790584643197*^9}, {3.645790622772689*^9, 
  3.645790663644825*^9}, {3.6457907625426073`*^9, 3.645790769809458*^9}, {
  3.6457915410824966`*^9, 3.645791543204056*^9}, {3.662243147174576*^9, 
  3.6622431500048723`*^9}, {3.667141401675829*^9, 3.667141409879896*^9}, {
  3.667141528682611*^9, 3.667141528685532*^9}}],

Cell[TextData[{
 "Next, for each cluster, ",
 Cell[BoxData["neighborOfClust"], "MCode"],
 " lists the acceptable clusters to transfer to during the optimization loop. \
By default, the neighbors for cluster ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]], "Math"],
 " are the clusters ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "+", "1"}], TraditionalForm]], "Math"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "1"}], TraditionalForm]], "Math"],
 ", since the initial clustering (from the dot-product method or the previous \
round of PIKA) is expected to be at least a somewhat accurate arrangement, \
and so long-distance transfers should not be necessary."
}], "Text",
 CellChangeTimes->{
  3.6457907738951125`*^9, {3.662325282414027*^9, 3.6623252917149878`*^9}, 
   3.665785902237414*^9, {3.667141541335346*^9, 3.6671415413381777`*^9}}],

Cell[TextData[{
 "Finally, a system for keeping track of transfer history lets us reduce \
unnecessary computation. ",
 Cell[BoxData["kMove"], "MCode"],
 " counts the number of transfers that have been made in the loop. ",
 Cell[BoxData["birthOfClust"], "MCode"],
 " is a table that records the move number when each cluster was last \
changed, and ",
 Cell[BoxData["birthOfObsClust"], "MCode"],
 " is a two-dimensional table that records, for each observation-cluster \
pair, the last time that the deviation from the observation to the cluster \
mean was calculated. ",
 Cell[BoxData["sqDevOfObsClust"], "MCode"],
 " is a table with the same dimensions that records the actual deviations so \
that they can be used later in the loop if they are still up to date."
}], "Text",
 CellChangeTimes->{{3.6457907801483464`*^9, 3.6457907817857265`*^9}, {
   3.645790999459344*^9, 3.6457911876324096`*^9}, {3.6457912750039153`*^9, 
   3.6457914750493383`*^9}, 3.646410330898821*^9, {3.662243160005657*^9, 
   3.662243166444378*^9}, {3.662325330199768*^9, 3.66232533060001*^9}, {
   3.667141557907873*^9, 3.667141574065879*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"prepareOptimizationLoop", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Sort", "[", 
        RowBox[{"Flatten", "[", "iObsOfClust", "]"}], "]"}], "!=", " ", 
       RowBox[{"Range", "[", 
        RowBox[{"Length", "[", "dat", "]"}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"print", "[", 
       RowBox[{
       "iNPhotonAvgList", ",", 
        "\"\<PIKA: WARNING: iObsOfClust does not map each observation to a \
cluster\>\""}], "]"}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"iClustOfObs", "=", 
     RowBox[{"getIClustOfObs", "[", "iObsOfClust", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Min", "[", "iClustOfObs", "]"}], "<=", " ", "0"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"print", "[", 
       RowBox[{
       "iNPhotonAvgList", ",", 
        "\"\<PIKA: WARNING: iClustOfObs does not map each observation to a \
cluster\>\""}], "]"}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"neighborOfClust", "=", 
     RowBox[{"pair", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Range", "[", "nClust", "]"}], "-", "1"}], ",", 
       RowBox[{
        RowBox[{"Range", "[", "nClust", "]"}], "+", "1"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
     "neighborOfClust", "\[LeftDoubleBracket]", "1", 
      "\[RightDoubleBracket]"}], "=", 
     RowBox[{"Drop", "[", 
      RowBox[{
       RowBox[{
       "neighborOfClust", "\[LeftDoubleBracket]", " ", "1", 
        "\[RightDoubleBracket]"}], ",", "1"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"neighborOfClust", "\[LeftDoubleBracket]", 
      RowBox[{"-", "1"}], "\[RightDoubleBracket]"}], "=", 
     RowBox[{"Drop", "[", 
      RowBox[{
       RowBox[{"neighborOfClust", "\[LeftDoubleBracket]", 
        RowBox[{"-", "1"}], "\[RightDoubleBracket]"}], ",", 
       RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"kMove", "=", "0"}], ";", 
    RowBox[{"(*", " ", 
     RowBox[{"count", " ", "of", " ", "moves", " ", "made"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"birthOfClust", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", "nClust", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"birthOfObsClust", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{"{", "nObs", "}"}], ",", 
       RowBox[{"{", "nClust", "}"}]}], "]"}]}], ";", 
    RowBox[{"(*", " ", 
     RowBox[{"older", " ", "than", " ", "birthOfClust"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"sqDevOfObsClust", "=", "birthOfObsClust"}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"dummy", " ", "array", " ", "of", " ", "correct", " ", "shape"}], 
    " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGCQAWIQXcqRummRxmvHV/dPgunHR7YcBdELzgmdBdEVF2+x
