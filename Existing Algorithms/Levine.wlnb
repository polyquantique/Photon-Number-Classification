  3.6471678720880876`*^9, 3.647167879045643*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"poissonLogLikelihood", "[", 
   RowBox[{"nList_", ",", "freqList_", ",", "mu_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
