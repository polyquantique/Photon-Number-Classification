Cell[TextData[{
 Cell[BoxData["nClust"], "MCode"],
 " is then the number of clusters, which ",
 Cell[BoxData["groupProbability"], "MCode"],
 " decides based on which photon numbers we expect to see in at least one \
observation."
}], "Text",
 CellChangeTimes->{{3.6453573797541876`*^9, 3.645357400018588*^9}, 
