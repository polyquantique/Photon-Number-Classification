  "]],

Cell[TextData[{
 Cell[BoxData["runFromAssociation"], "MCode"],
 " takes an association between variable names (strings) and the values that \
should be assigned to them and assigns the proper value to the symbolic \
variable associated with each name. It then runs PIKA (using the main \
function from Section ",
 
 CounterBox["Section", "Section3"],
 ") with those global variables set."
}], "Text",
 CellChangeTimes->{{3.6478554949445114`*^9, 3.6478555900415015`*^9}, {
   3.6478561025450163`*^9, 3.6478561193305087`*^9}, {3.661703029519845*^9, 
   3.6617030295271673`*^9}, 3.665788989612135*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"runFromAssociation", "[", "formAssoc_", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"varNames", "=", 
     RowBox[{"Keys", "[", "formAssoc", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"varValues", "=", 
     RowBox[{"Values", "[", "formAssoc", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Clear", "[", 
        RowBox[{"Evaluate", "[", 
         RowBox[{
         "varNames", "\[LeftDoubleBracket]", "iVar", 
          "\[RightDoubleBracket]"}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"ToExpression", "[", 
          RowBox[{
          "varNames", "\[LeftDoubleBracket]", "iVar", 
           "\[RightDoubleBracket]"}], "]"}], "]"}], "=", 
        RowBox[{
        "varValues", "\[LeftDoubleBracket]", "iVar", 
         "\[RightDoubleBracket]"}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"iVar", ",", 
        RowBox[{"Length", "[", "varNames", "]"}]}], "}"}]}], 
     "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"runPIKA", "[", "]"}]}], "\[IndentingNewLine]", ")"}]}]], "Input",
 CellChangeTimes->{{3.647795546949069*^9, 3.647795579096663*^9}, {
   3.64779566075694*^9, 3.6477956625977287`*^9}, {3.6477957870721316`*^9, 
   3.647795879653339*^9}, {3.6477959257180443`*^9, 3.6477961076514792`*^9}, {
