Cell[BoxData[
 RowBox[{
  RowBox[{"getAlpha", "[", 
   RowBox[{"traces_", ",", "idealTraceAB_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "alpha", ",", "diffIdealTrace", ",", "idealTraceA", ",", "nObs"}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nObs", "=", 
      RowBox[{"Length", "[", "traces", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"diffIdealTrace", "=", 
      RowBox[{"Apply", "[", 
       RowBox[{"Subtract", ",", "idealTraceAB"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"idealTraceA", "=", 
      RowBox[{"First", "[", "idealTraceAB", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"alpha", "=", 
      RowBox[{"getDotToIdeal", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"idealTraceA", "-", 
           RowBox[{
           "traces", "\[LeftDoubleBracket]", "iObs", 
            "\[RightDoubleBracket]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"iObs", ",", "nObs"}], "}"}]}], "]"}], ",", 
        "diffIdealTrace"}], "]"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.6461363106323595`*^9, 3.646136364561559*^9}, {
   3.646136408101159*^9, 3.646136450891959*^9}, {3.6461452042359676`*^9, 
   3.6461452110063677`*^9}, {3.6461461383483677`*^9, 3.646146138363968*^9}, {
   3.6461471427443676`*^9, 3.646147142759968*^9}, {3.6461471857535677`*^9, 
   3.646147185769168*^9}, {3.646149893851968*^9, 3.646149899686368*^9}, {
   3.6461499367675676`*^9, 3.646149947874768*^9}, {3.6461500262335677`*^9, 
   3.646150038323568*^9}, {3.6461500907239676`*^9, 3.6461501004895678`*^9}, {
   3.6461504198139677`*^9, 3.6461504320911674`*^9}, {3.6461508232611675`*^9, 
