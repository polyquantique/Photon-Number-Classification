Cell[TextData[{
 "Suppose that cluster ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]], "Math"],
 " has nine waveforms and cluster ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]], "Math"],
 " has 14 (and each has some mean waveform in addition), and we want to move \
a waveform from ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]], "Math"],
 " to ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]], "Math"],
 ". When we make this transfer, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "K"], TraditionalForm]], "Math"],
 " changes by the following amount."
}], "Text",
 CellChangeTimes->{{3.64373375403419*^9, 3.6437338531367903`*^9}, {
