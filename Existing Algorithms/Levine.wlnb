   3.662220633304269*^9}, {3.662329667490953*^9, 3.662329668998412*^9}, {
   3.662329806802165*^9, 3.6623298095792923`*^9}, {3.662329967495821*^9, 
   3.6623299682788353`*^9}, {3.6627564247784224`*^9, 3.6627564368324413`*^9}}],

Cell[TextData[{
 "The two-argument ",
 Cell[BoxData["getNPhotonEff"], "MCode"],
 " takes the formatted list of triples ",
 Cell[BoxData["alphaByClustPair"], "MCode"],
 " and a list of cluster photon numbers and determines the effective photon \
number of each observation. ",
 Cell[BoxData["alpha"], "MCode"],
 " is a list of alpha values for the observations, ",
 Cell[BoxData["iObs"], "MCode"],
 " is a list of observation indices corresponding to those alpha values, and ",
 Cell[BoxData["clustPair"], "MCode"],
 " is a list of nearest-mean-index pairs for those observations. ",
 Cell[BoxData["alpha"], "MCode"],
 " and ",
 Cell[BoxData["clustPair"], "MCode"],
 " are in the same order as ",
 Cell[BoxData["iObs"], "MCode"],
 ", but we want them in the same order as the waveforms from the original ",
 "dataset",
 ", so we reorder them with ",
 Cell[BoxData["iiObs"], "MCode"],
 ". ",
 Cell[BoxData["nPhotonPair"], "MCode"],
 " takes the cluster indices in ",
 Cell[BoxData["clustPair"], "MCode"],
 " and converts them to the actual photon numbers associated with those \
clusters. The output is a list specifying the effective photon number for \
each observation, derived from a linear interpolation between the closest (",
 Cell[BoxData[
  RowBox[{"nPhotonPair", "\[LeftDoubleBracket]", 
   RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]], "MCode"],
 ") and second-closest (",
 Cell[BoxData[
  RowBox[{"nPhotonPair", "\[LeftDoubleBracket]", 
   RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}]], "MCode"],
 ") photon numbers."
}], "Text",
 CellChangeTimes->{{3.6464024248255386`*^9, 3.646402530697261*^9}, {
   3.6464027664815507`*^9, 3.6464029417998285`*^9}, {3.6464030274464808`*^9, 
   3.646403252549839*^9}, 3.6464104228630323`*^9, {3.661697888682749*^9, 
   3.661697917737672*^9}, {3.661698742996256*^9, 3.661698854056746*^9}, 
   3.665788551115295*^9, {3.6657886459217157`*^9, 3.665788664376548*^9}, 
   3.665789078116214*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getNPhotonEff", "[", 
   RowBox[{"alphaByClustPair_", ",", "nPhotonList_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "alpha", ",", "clustPair", ",", "iiObs", ",", "iObs", ",", "nObs", ",", 
      "nPhotonPair"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"alpha", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"alphaByClustPair", "\[LeftDoubleBracket]", 
        RowBox[{"All", ",", "3"}], "\[RightDoubleBracket]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"iObs", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"alphaByClustPair", "\[LeftDoubleBracket]", 
        RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"clustPair", "=", 
      RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"alphaByClustPair", "\[LeftDoubleBracket]", 
             RowBox[{"iClustPair", ",", "1"}], "\[RightDoubleBracket]"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"Length", "[", 
              RowBox[{"alphaByClustPair", "\[LeftDoubleBracket]", 
               RowBox[{"iClustPair", ",", "3"}], "\[RightDoubleBracket]"}], 
              "]"}], "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"iClustPair", ",", 
            RowBox[{"Length", "[", "alphaByClustPair", "]"}]}], "}"}]}], 
         "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "1"}], " ",
        "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"iiObs", "=", 
      RowBox[{"Ordering", "[", "iObs", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"alpha", "=", 
      RowBox[{
      "alpha", " ", "\[LeftDoubleBracket]", " ", "iiObs", " ", 
       "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"clustPair", "=", 
      RowBox[{
      "clustPair", " ", "\[LeftDoubleBracket]", " ", "iiObs", " ", 
       "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nObs", "=", 
      RowBox[{"Length", "[", "alpha", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nPhotonPair", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"nPhotonList", " ", "\[LeftDoubleBracket]", " ", 
         RowBox[{
         "clustPair", "\[LeftDoubleBracket]", " ", "jObs", " ", 
          "\[RightDoubleBracket]"}], " ", "\[RightDoubleBracket]"}], ",", 
        RowBox[{"{", 
         RowBox[{"jObs", ",", "nObs"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "alpha"}], ")"}], "*", 
       RowBox[{"nPhotonPair", "\[LeftDoubleBracket]", 
        RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}], " ", "+", " ", 
      RowBox[{"alpha", "*", 
       RowBox[{"nPhotonPair", "\[LeftDoubleBracket]", 
        RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}]}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
