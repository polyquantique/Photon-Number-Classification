      RowBox[{"Length", "[", "clustMeanTrace", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"iObs", ",", 
      RowBox[{"Length", "[", "dat", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
