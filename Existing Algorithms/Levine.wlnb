   SubscriptBox["C", "n"], TraditionalForm]], "Math"],
 ", forming a cluster ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "n"], "'"}], TraditionalForm]], "Math"],
 ". Then,"
}], "Theorem",
