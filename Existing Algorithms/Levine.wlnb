Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"||", 
    RowBox[{
     SubscriptBox[
      StyleBox["V",
       FontWeight->"Bold",
       FontSlant->"Plain"], "k"], "-", 
     FormBox[
      StyleBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], "n"],
       FontSlant->"Plain"],
      TraditionalForm]}], 
    SuperscriptBox["||", "2"], 
    RowBox[{"+", 
     FractionBox[
      RowBox[{
       SubscriptBox["N", "t"], 
       SubscriptBox["J", "n"]}], 
      SubscriptBox["m", "n"]]}]}], "=", 
   RowBox[{"||", 
    SubscriptBox[
     StyleBox["V",
      FontWeight->"Bold",
      FontSlant->"Plain"], "k"], 
    SuperscriptBox["||", "2"], 
    RowBox[{
     RowBox[{
      RowBox[{"-", "2"}], 
      RowBox[{
       SubscriptBox[
        StyleBox["V",
         FontWeight->"Bold",
         FontSlant->"Plain"], "k"], "\[CenterDot]", 
       SubscriptBox[
        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], "n"]}]}], "+", 
     RowBox[{
      FractionBox["1", 
       SubscriptBox["m", "n"]], 
      UnderscriptBox["\[Sum]", 
       RowBox[{"i", "\[Element]", 
        SubscriptBox["C", "n"]}]]}]}], "||", 
    SubscriptBox[
     StyleBox["V",
      FontWeight->"Bold",
      FontSlant->"Plain"], "i"], 
    SuperscriptBox["||", "2"], "."}]}], TraditionalForm]], "DisplayFormula",
