  3.650025529022086*^9, 3.6500255303821898`*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["J", "n"], "=", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["N", "t"]], 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        RowBox[{"i", "\[Element]", 
         SubscriptBox["C", "n"]}]], 
