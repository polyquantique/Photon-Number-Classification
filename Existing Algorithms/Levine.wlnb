Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"||", 
    RowBox[{
     SubscriptBox[
      StyleBox["V",
       FontWeight->"Bold",
       FontSlant->"Plain"], "k"], "-", 
     FormBox[
      StyleBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], "n"],
       FontSlant->"Plain"],
      TraditionalForm]}], 
    SuperscriptBox["||", "2"]}], "=", 
   RowBox[{"||", 
