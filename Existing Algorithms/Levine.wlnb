Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 " ",
 "Probability and Log-Likelihood"
}], "Subsection",
 CellChangeTimes->{{3.646131121581359*^9, 3.6461311269945593`*^9}, {
   3.646132860806959*^9, 3.6461328634745593`*^9}, {3.6461332186653595`*^9, 
   3.6461332191645594`*^9}, {3.646134347309759*^9, 3.646134366778559*^9}, {
   3.6464983517856255`*^9, 3.6464983519416246`*^9}, 3.662129353386382*^9}],

Cell[TextData[{
 "This is the combinatorial term of the log-likelihood objective function. \
From equation (",
 
 CounterBox["DisplayFormulaNumbered", "eqLogCombo"],
 ") above, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"ln", " ", 
     SubscriptBox["\[ScriptCapitalL]", "C"]}], "=", 
    RowBox[{
     RowBox[{"ln", " ", 
      RowBox[{"M", "!"}]}], "-", 
     RowBox[{"\[Sum]", 
      RowBox[{"ln", " ", 
       RowBox[{
        SubscriptBox["m", "n"], "!"}]}]}]}]}], TraditionalForm]], "Math"],
 ", where the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "i"], TraditionalForm]], "Math"],
 " are the cluster sizes and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"\[Sum]", 
     SubscriptBox["m", "n"]}]}], TraditionalForm]], "Math"],
 "."
}], "Text",
 CellChangeTimes->{{3.6464799125640326`*^9, 3.6464799729668455`*^9}, {
   3.646480043353594*^9, 3.6464800493595552`*^9}, {3.6464801139743414`*^9, 
   3.646480302701932*^9}, {3.6464803444784636`*^9, 3.646480431580702*^9}, {
   3.6464805075522146`*^9, 3.646480571090607*^9}, {3.6464811419689474`*^9, 
   3.646481174822337*^9}, {3.646496059092345*^9, 3.6464960791070166`*^9}, {
   3.647616866005613*^9, 3.6476168772747407`*^9}, {3.6627603324565*^9, 
   3.662760332670678*^9}, 3.665786040516438*^9, {3.6694729943674173`*^9, 
   3.669472995887308*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"comboLogLikelihood", "[", "freqList_", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"LogGamma", "[", 
    RowBox[{
     RowBox[{"Total", "[", "freqList", "]"}], "+", "1."}], "]"}], " ", "-", 
   " ", 
   RowBox[{"Total", "[", 
    RowBox[{"LogGamma", "[", 
     RowBox[{"freqList", "+", "1."}], "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.6443322207830315`*^9, 3.644332245204031*^9}, {
   3.6443338535400314`*^9, 3.644333854304431*^9}, {3.6460421919503284`*^9, 
