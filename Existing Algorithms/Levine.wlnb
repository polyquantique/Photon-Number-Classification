  3.647100146546591*^9, {3.6471039031695185`*^9, 3.6471039039651136`*^9}}],

Cell[TextData[{
 "Suppose we add or remove a waveform ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["V",
     FontWeight->"Bold",
     FontSlant->"Plain"], "p"], TraditionalForm]], "Math"],
