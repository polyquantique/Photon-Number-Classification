   3.6621310763472157`*^9}, {3.6623295309529257`*^9, 3.66232953204307*^9}, {
   3.6623298653594913`*^9, 3.6623298666002007`*^9}, {3.6623299958390512`*^9, 
   3.6623299963199377`*^9}, {3.662760522451685*^9, 3.662760563951064*^9}}],

Cell[TextData[{
 Cell[BoxData["poisson"], "MCode"],
 " generates about ",
 Cell[BoxData["nSigma"], "MCode"],
 " standard deviations of a Poisson distribution on either side of the given \
mean. The output is a list of ordered pairs of photon numbers and associated \
values of the Poisson probability mass function. The output is normalized so \
that it sums to one."
}], "Text",
 CellChangeTimes->{{3.646497211045757*^9, 3.6464972157725267`*^9}, 
   3.646497357809616*^9, {3.6464977265804377`*^9, 3.646497777186513*^9}, {
   3.646497835233741*^9, 3.646497873250697*^9}, {3.6464980545527353`*^9, 
   3.6464980674226522`*^9}, {3.6464983054695225`*^9, 
   3.6464983140962677`*^9}, {3.646498375591073*^9, 3.64649837609027*^9}, {
   3.661699724723288*^9, 3.661699728615666*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"poisson", "[", 
   RowBox[{"mu_", ",", "nSigma_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sigma", ",", "tab"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"sigma", "=", 
      RowBox[{"Sqrt", "[", "mu", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tab", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"N", "[", 
              RowBox[{"Exp", "[", 
               RowBox[{"-", "mu"}], "]"}], "]"}], "*", 
             RowBox[{"mu", "^", "n"}]}], ")"}], "/", 
           RowBox[{"n", "!"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"Max", "[", 
           RowBox[{
            RowBox[{"Floor", "[", 
             RowBox[{"mu", "-", 
              RowBox[{"sigma", "*", "nSigma"}]}], "]"}], ",", "0"}], "]"}], 
          ",", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"mu", "+", 
            RowBox[{"sigma", "*", "nSigma"}]}], "]"}]}], "}"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"First", "[", "#", "]"}], ",", 
          RowBox[{
           RowBox[{"Last", "[", "#", "]"}], "/", 
           RowBox[{"Total", "[", 
            RowBox[{"tab", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], "}"}], 
        "&"}], ",", "tab"}], "]"}]}]}], "\n", "]"}]}]], "Input",
 CellChangeTimes->{{3.662760960992647*^9, 3.662761294967291*^9}}]
}, Open  ]],

