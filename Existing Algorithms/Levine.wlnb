   3.646150089179568*^9, 3.646150098757968*^9}, {3.646150419018368*^9, 
   3.646150431326768*^9}, {3.6461508236979675`*^9, 3.646150871324768*^9}, {
   3.662129887525428*^9, 3.662129887533835*^9}, {3.662329612682502*^9, 
   3.662329615438163*^9}, {3.662329761400567*^9, 3.6623297643222713`*^9}, {
   3.662329940997867*^9, 3.662329941367949*^9}, {3.662758771576397*^9, 
   3.662758772602024*^9}, {3.6627588286193533`*^9, 3.66275882934023*^9}, {
   3.665246527926587*^9, 3.665246529598454*^9}}],

Cell[TextData[{
 "We need to know how a proposed move would change the objective function \
before deciding whether to accept it. Section ",
 
 CounterBox["Section", "ObjFtnUpdate"],
 " gives more detail on the functions called here that efficiently compute \
the change in the objective function."
}], "Text",
 CellChangeTimes->{
  3.64587084798923*^9, 3.64587205635943*^9, {3.64587334734523*^9, 
   3.64587338233803*^9}, {3.6458734357564297`*^9, 3.64587347952163*^9}, {
   3.64587351683883*^9, 3.6458735499284296`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"findChangeInObjectiveFunction", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"deltaI", "=", 
     RowBox[{"deltaKMeansDel", "[", 
      RowBox[{
       RowBox[{
       "nOfClust", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}], ",", 
       RowBox[{"sqDevOfObsClust", "\[LeftDoubleBracket]", 
        RowBox[{"iObs", ",", "iClust"}], "\[RightDoubleBracket]"}]}], "]"}]}],
     ";", "\[IndentingNewLine]", 
    RowBox[{"deltaJ", "=", 
     RowBox[{"deltaKMeansAdd", "[", 
      RowBox[{
       RowBox[{
       "nOfClust", "\[LeftDoubleBracket]", "jClust", 
        "\[RightDoubleBracket]"}], ",", 
       RowBox[{"sqDevOfObsClust", "\[LeftDoubleBracket]", 
        RowBox[{"iObs", ",", "jClust"}], "\[RightDoubleBracket]"}]}], "]"}]}],
     ";", "\[IndentingNewLine]", 
    RowBox[{"deltaKMeansScaled", "=", 
     RowBox[{
      FractionBox["deltaJ", 
       RowBox[{"2", "*", 
        SuperscriptBox[
         RowBox[{
         "sigmaObjFtn", "\[LeftDoubleBracket]", "jClust", 
          "\[RightDoubleBracket]"}], "2"]}]], " ", "-", " ", 
      FractionBox["deltaI", 
       RowBox[{"2", "*", 
        SuperscriptBox[
         RowBox[{
         "sigmaObjFtn", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], "2"]}]]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"deltaProb", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"jClust", "<", "iClust"}], ",", "\[IndentingNewLine]", 
       RowBox[{"deltaPoissonDn", "[", 
        RowBox[{
         RowBox[{
         "nPhotonOfClust", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "nOfClust", "\[LeftDoubleBracket]", "jClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "nOfClust", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], ",", "nPhotonAvg"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"deltaPoissonUp", "[", 
        RowBox[{
         RowBox[{
         "nPhotonOfClust", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "nOfClust", "\[LeftDoubleBracket]", "jClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "nOfClust", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], ",", "nPhotonAvg"}], "]"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"deltaObjFtn", "=", 
     RowBox[{"deltaKMeansScaled", " ", "-", " ", "deltaProb"}]}], ";"}], 
   "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.6451849027027225`*^9, 3.6451849088179226`*^9}, {
   3.6451849539955225`*^9, 3.6451852804707546`*^9}, {3.645185322574439*^9, 
   3.6451853243526564`*^9}, {3.6451853614768486`*^9, 3.645185380350912*^9}, {
   3.64587083235803*^9, 3.6458708428256297`*^9}, {3.646146137599568*^9, 
   3.6461461376775675`*^9}, {3.646147141823968*^9, 3.646147141901968*^9}, {
   3.646147184973568*^9, 3.646147185051568*^9}, {3.646149892993968*^9, 
   3.6461498989219675`*^9}, {3.6461499359563675`*^9, 3.646149947110368*^9}, {
   3.646150025500368*^9, 3.646150037652768*^9}, {3.6461500892107677`*^9, 
   3.646150098820368*^9}, {3.6461504190807676`*^9, 3.646150431404768*^9}, {
   3.6461508237135677`*^9, 3.6461508713559675`*^9}, {3.647077256886305*^9, 
   3.6470774466746883`*^9}, {3.6471653307295823`*^9, 
   3.6471653839664373`*^9}, {3.647166015949586*^9, 3.647166018726368*^9}, {
   3.647167141201573*^9, 3.647167207766346*^9}, {3.647251089701765*^9, 
   3.6472511503767767`*^9}, {3.647251227515071*^9, 3.6472512328864365`*^9}, {
   3.662129887538166*^9, 3.6621298875493793`*^9}, 3.662329616237445*^9, {
   3.6623297649544153`*^9, 3.662329766419053*^9}, {3.662329941734975*^9, 
   3.662329943201825*^9}, 3.662330158552291*^9, 3.662758774999905*^9, 
   3.662758831092402*^9, {3.665320392386229*^9, 3.6653203943067207`*^9}}],

Cell["\<\
If the transfer would decrease the objective function, we automatically \
accept it, and if we use the greedy algorithm, we reject any transfer that \
does not decrease the objective function. If we use simulated annealing, \
however, we may accept a transfer that increases the objective function for \
the purpose of exploring a greater number of assignments and possibly \
avoiding local minima that would trap the greedy algorithm. In simulated \
annealing, it grows harder for a disadvantageous transfer to occur as time \
goes on and the \[OpenCurlyDoubleQuote]temperature\[CloseCurlyDoubleQuote] \
drops.\
\>", "Text",
 CellChangeTimes->{{3.6458737907424297`*^9, 3.64587399520703*^9}, {
   3.6458742804544296`*^9, 3.6458743249320297`*^9}, 3.650030440227388*^9, {
   3.661518936564043*^9, 3.661518953658492*^9}, {3.6622431834849873`*^9, 
   3.6622431837155237`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"decideWhetherToMove", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{"acceptMove", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"deltaObjFtn", "<", "0"}], ",", "\[IndentingNewLine]", "True", 
      ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"iCool", " ", ">", " ", "nGreedy"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"RandomReal", "[", "]"}], "<", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "deltaObjFtn"}], "/", "tAnneal"}], "]"}]}], ",", 
        "\[IndentingNewLine]", "False"}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.645185401003194*^9, 3.645185509871253*^9}, {
   3.6451859219984617`*^9, 3.6451859239484367`*^9}, {3.646150089257568*^9, 
   3.6461500988515677`*^9}, {3.646150856847968*^9, 3.6461508713559675`*^9}, {
   3.6479402002184525`*^9, 3.6479402037752295`*^9}, 3.662129887553734*^9, {
   3.662329616980783*^9, 3.662329618039624*^9}, {3.662329767204103*^9, 
   3.6623297679497538`*^9}, {3.662758778560046*^9, 3.662758779811837*^9}, {
   3.662758832255299*^9, 3.662758833482237*^9}, {3.665246554263813*^9, 
   3.665246555591954*^9}}],

Cell[TextData[{
 "If the move is accepted, then we need to move the observation from one \
cluster to the other and update the clusters\[CloseCurlyQuote] deviations and \
mean traces. Both clusters have been changed in this move, so we update ",
 Cell[BoxData["birthOfClust"], "MCode"],
 " accordingly."
}], "Text",
 CellChangeTimes->{{3.64588095502163*^9, 3.64588104027563*^9}, {
  3.64588117760243*^9, 3.64588123906643*^9}, {3.6671417081379433`*^9, 
  3.667141708141079*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"updateIfMoving", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{"If", "[", 
    RowBox[{"acceptMove", ",", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "transfer", " ", "a", " ", "trace", " ", "from", " ", "cluster", " ", 
       "i", " ", "to", " ", "cluster", " ", "j"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"printSp", "[", 
       RowBox[{
       "iNPhotonAvgList", ",", "\"\<Detailed Log\>\"", ",", 
        "\"\<   Round \>\"", ",", "iCool", ",", "\"\<, observation \>\"", ",",
         "iObs", ",", "\"\<: deltaObjFtn \>\"", ",", "deltaObjFtn", ",", 
        "\"\< from \>\"", ",", "iClust", ",", "\"\< to \>\"", ",", "jClust"}],
        "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"kMove", "++"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "birthOfClust", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}], "=", "kMove"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "clustMeanTrace", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}], "=", 
       RowBox[{"newMeanTraceDel", "[", 
        RowBox[{
         RowBox[{
         "nOfClust", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "clustMeanTrace", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "dat", "\[LeftDoubleBracket]", "iObs", "\[RightDoubleBracket]"}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "nOfClust", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}], "--"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "birthOfClust", "\[LeftDoubleBracket]", "jClust", 
        "\[RightDoubleBracket]"}], "=", "kMove"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "clustMeanTrace", "\[LeftDoubleBracket]", "jClust", 
        "\[RightDoubleBracket]"}], "=", 
       RowBox[{"newMeanTraceAdd", "[", 
        RowBox[{
         RowBox[{
         "nOfClust", "\[LeftDoubleBracket]", "jClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "clustMeanTrace", "\[LeftDoubleBracket]", "jClust", 
          "\[RightDoubleBracket]"}], ",", 
         RowBox[{
         "dat", "\[LeftDoubleBracket]", "iObs", "\[RightDoubleBracket]"}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "nOfClust", "\[LeftDoubleBracket]", "jClust", 
        "\[RightDoubleBracket]"}], "++"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "iClustOfObs", "\[LeftDoubleBracket]", "iObs", 
        "\[RightDoubleBracket]"}], "=", "jClust"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "sqDevOfClust", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}], " ", "-=", " ", "deltaI"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "sqDevOfClust", "\[LeftDoubleBracket]", "jClust", 
        "\[RightDoubleBracket]"}], " ", "+=", " ", "deltaJ"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"objFtn", " ", "+=", " ", "deltaObjFtn"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.6451855355948286`*^9, 3.6451855419282255`*^9}, {
