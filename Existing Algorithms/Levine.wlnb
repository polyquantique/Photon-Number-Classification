   3.6623295077384157`*^9}, {3.662329840460527*^9, 3.662329842844885*^9}, {
   3.6623299822969313`*^9, 3.66232998374616*^9}, {3.662758727553041*^9, 
   3.662758741371723*^9}, 3.662758784179235*^9, 3.6627588399094973`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 " ",
 "Cluster Organization"
}], "Subsection",
 CellChangeTimes->{{3.6461309565489593`*^9, 3.646130959450559*^9}, {
   3.6461332172145596`*^9, 3.646133217542159*^9}, {3.6461343451413593`*^9, 
   3.646134366014159*^9}, {3.6464784360217876`*^9, 3.646478436193387*^9}, 
   3.6621293533078337`*^9},
 CellTags->"FDefClustOrg"],

Cell[TextData[{
 "These two functions convert between ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 " and ",
 Cell[BoxData["iClustOfObs"], "MCode"],
 ", two different ways of organizing clusters of waveforms. ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 " is a list of lists. Each sublist is associated with a cluster and has the \
indices (in ",
 Cell[BoxData["dat"], "MCode"],
 ") of the traces in that cluster. ",
 Cell[BoxData["iClustOfObs"], "MCode"],
 " is a simple list, each of whose entries corresponds to a trace and states \
what cluster that trace is in (0 if the trace is not in any cluster). ",
 Cell[BoxData["getIClustOfObs"], "MCode"],
 " takes ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 " and returns ",
 Cell[BoxData["iClustOfObs"], "MCode"],
 ", and ",
 Cell[BoxData["getIObsOfClust"], "MCode"],
 " is its inverse function."
}], "Text",
 CellChangeTimes->{{3.6464741030115623`*^9, 3.6464742822376137`*^9}, {
  3.661699444752121*^9, 3.661699484405175*^9}}],

Cell[TextData[{
 Cell[BoxData["getIClustOfObs"], "MCode"],
 " creates a table with an entry for each observation and then iterates \
through the clusters. In the table, it assigns the contents of each cluster \
to the appropriate cluster number."
}], "Text",
 CellChangeTimes->{{3.6464745858254642`*^9, 3.6464746674611406`*^9}, {
  3.661699489482428*^9, 3.66169948948909*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getIClustOfObs", "[", "iObsOfClust_", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"iClustOfObs", ",", "nClust", ",", "nObs"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nClust", "=", 
      RowBox[{"Length", "[", "iObsOfClust", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nObs", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"Flatten", "[", "iObsOfClust", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"iClustOfObs", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "nObs", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"iClustOfObs", "\[LeftDoubleBracket]", 
         RowBox[{
         "iObsOfClust", "\[LeftDoubleBracket]", "iClust", 
          "\[RightDoubleBracket]"}], "\[RightDoubleBracket]"}], "=", 
        "iClust"}], ",", 
       RowBox[{"{", 
        RowBox[{"iClust", ",", "nClust"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "iClustOfObs"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{3.66523289972099*^9}],

Cell[TextData[{
 Cell[BoxData["getIObsOfClust"], "MCode"],
 " creates a list of observation number/cluster number pairs and then applies \
a ",
 Cell[BoxData["GatherBy"], "MCode"],
 " to group waveforms in the same clusters together. Mapping ",
 Cell[BoxData["groupCommon"], "MCode"],
 " onto the list creates a list of lists, each of whose first element is a \
cluster number and each of whose second element is a list of the indices of \
the waveforms in that cluster. We then sort the overall list by cluster \
number and extract the second entries in the sublists to create a list of \
lists of observation indices."
}], "Text",
 CellChangeTimes->{{3.6464746846220307`*^9, 3.6464746898167973`*^9}, {
  3.6464747208801985`*^9, 3.6464749971904273`*^9}, {3.661699497301873*^9, 
  3.661699505945829*^9}, {3.665788697038145*^9, 3.665788707054041*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getIObsOfClust", "[", "iClustOfObs_", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "iObsGroup", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"iObsGroup", "=", 
      RowBox[{"GatherBy", "[", 
       RowBox[{
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{"Length", "[", "iClustOfObs", "]"}], "]"}], ",", 
           "iClustOfObs"}], "}"}], "]"}], ",", 
        RowBox[{
         RowBox[{"Last", "[", "#", "]"}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Sort", "[", 
       RowBox[{"Map", "[", 
        RowBox[{"groupCommon", ",", "iObsGroup"}], "]"}], "]"}], " ", 
      "\[LeftDoubleBracket]", 
      RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{
  3.646134055964159*^9, {3.646140668102522*^9, 3.646140692407322*^9}, 
   3.646146138582368*^9, 3.6461471430095677`*^9, 3.6461471859563675`*^9, {
   3.646149894070368*^9, 3.646149899904768*^9}, {3.646149936970368*^9, 
   3.646149948077568*^9}, {3.646150026436368*^9, 3.646150038510768*^9}, {
   3.6461500913791676`*^9, 3.646150101160368*^9}, {3.646150420001168*^9, 
   3.646150432278368*^9}, {3.6461508233859677`*^9, 3.646150868610368*^9}, {
   3.662129887804427*^9, 3.6621298878097143`*^9}, {3.6621308016771193`*^9, 
   3.662130805509028*^9}, {3.662329511704967*^9, 3.6623295141394253`*^9}, {
   3.6623298464158287`*^9, 3.662329848513447*^9}, {3.6623299857001123`*^9, 
   3.6623299869587*^9}, {3.662759069785812*^9, 3.662759072882287*^9}, {
   3.662759115076338*^9, 3.662759163461411*^9}, {3.6627591943657312`*^9, 
   3.662759210316263*^9}, 3.662759532619141*^9}],

Cell[TextData[{
 Cell[BoxData["groupProbability"], "MCode"],
 " takes the data, the hypothesized mean photon number for the current round, \
and the effective-photon-number ordering of the data, and returns a list of \
four things: the Poisson probability distribution (ordered pairs of photon \
numbers and probabilities), a list of photon numbers for the clustering it \
creates, a list of lists of constituent waveforms\[CloseCurlyQuote] indices \
for the clusters (",
 Cell[BoxData["iObsOfClust"], "MCode"],
 "), and a list containing the average waveform in each cluster. ",
 Cell[BoxData["groupProbability"], "MCode"],
 " finds the photon number/value pairs for the Poisson distribution with the \
given mean photon number and then calls ",
 Cell[BoxData["groupProb"], "MCode"],
 " to organize the clusters."
}], "Text",
 CellChangeTimes->{{3.646475524474848*^9, 3.646475532461997*^9}, {
  3.6464756764066744`*^9, 3.6464756772490687`*^9}, {3.64647573317671*^9, 
  3.646475735033098*^9}, {3.6464757820113974`*^9, 3.6464758708658276`*^9}, {
  3.6464759107285724`*^9, 3.6464762273913436`*^9}, {3.647165589713518*^9, 
  3.6471655905715127`*^9}, {3.6471665333982687`*^9, 3.6471665567981186`*^9}, {
  3.6471665973578587`*^9, 3.6471666177313285`*^9}, {3.6471677262290225`*^9, 
  3.6471677279606113`*^9}, {3.661699515441691*^9, 3.661699528602542*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"groupProbability", "[", 
   RowBox[{"dat_", ",", "nPhotonAvg_", ",", "nPhotonEff_", ",", "nSigma_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "prob", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"prob", "=", 
      RowBox[{"poisson", "[", 
       RowBox[{"nPhotonAvg", ",", "nSigma"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Prepend", "[", 
      RowBox[{
       RowBox[{"groupProb", "[", 
        RowBox[{"dat", ",", "prob", ",", "nPhotonEff"}], "]"}], ",", "prob"}],
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.644659001059011*^9, 3.644659079324211*^9}, {
   3.644660133336611*^9, 3.644660148421811*^9}, {3.6447457014536247`*^9, 
   3.6447457046360245`*^9}, {3.644745832368825*^9, 3.6447458518376245`*^9}, {
   3.644746112576025*^9, 3.644746147785225*^9}, {3.644748098176425*^9, 
   3.644748239200425*^9}, {3.6447501340610247`*^9, 3.6447501443060246`*^9}, {
   3.644753666447974*^9, 3.644753674450774*^9}, {3.6447538239611745`*^9, 
   3.6447538250219746`*^9}, {3.6447587526559744`*^9, 
   3.6447587619847746`*^9}, {3.644758799424774*^9, 3.6447588020767746`*^9}, {
   3.644758893211974*^9, 3.6447588976735744`*^9}, {3.6447609850327744`*^9, 
   3.6447609868267746`*^9}, 3.6447643176973743`*^9, {3.6447643523761744`*^9, 
   3.6447644715521746`*^9}, 3.64587064323923*^9, {3.6460420156859283`*^9, 
   3.6460420161227283`*^9}, 3.646131223355759*^9, 3.646132408063759*^9, {
   3.6461340116913595`*^9, 3.646134019928159*^9}, {3.646137285058408*^9, 
   3.6461373731343145`*^9}, {3.6461401751269217`*^9, 
   3.6461401862497215`*^9}, {3.646150091129568*^9, 3.6461501009107676`*^9}, {
   3.6461508534627676`*^9, 3.646150868267168*^9}, {3.646412136910653*^9, 
   3.646412138330244*^9}, {3.646472643803047*^9, 3.6464726438810463`*^9}, 
   3.646475192735174*^9, {3.646478419984091*^9, 3.646478420436488*^9}, {
   3.6464976357218347`*^9, 3.6464976418837953`*^9}, {3.64656647828603*^9, 
   3.6465664834184628`*^9}, 3.647165777551914*^9, {3.647167780267076*^9, 
   3.6471678414654837`*^9}, 3.6471683541561975`*^9, 3.662129887815907*^9, {
   3.6621307872451143`*^9, 3.662130793237084*^9}, {3.6622206729059877`*^9, 
   3.6622206743009872`*^9}, {3.662329514837276*^9, 3.662329516109911*^9}, {
   3.662329849112596*^9, 3.6623298495863047`*^9}, 3.66232998724571*^9, {
   3.6627596468024693`*^9, 3.6627596562851057`*^9}}],

Cell[TextData[{
 Cell[BoxData["groupProb"], "MCode"],
 " processes the data into clusters based on the given effective photon \
number list and the Poisson distribution. First we find the proper ordering \
of the effective photon numbers by size (",
 Cell[BoxData["nPhotonEffSortIndex"], "MCode"],
 "); this will be needed once we have determined the sizes of the clusters to \
be created. The probability distribution ",
 Cell[BoxData["prob"], "MCode"],
 " is broken up into its component parts: ",
 Cell[BoxData["nPhoton"], "MCode"],
 " lists photon numbers, and ",
 Cell[BoxData["probList"], "MCode"],
 " lists their corresponding probabilities. ",
 Cell[BoxData["probCum"], "MCode"],
 " is the cumulative distribution function of ",
 Cell[BoxData["probList"], "MCode"],
 ", which we normalize to ensure that the final element is one. ",
 Cell[BoxData[
  RowBox[{
  "probIndexStart", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
  "MCode"],
 " gives the index (in the sorted list of effective photon numbers, ",
 Cell[BoxData["nPhotonEffSortIndex"], "MCode"],
 ") where cluster ",
 Cell[BoxData["i"], "MCode"],
 " should start; ",
 Cell[BoxData[
  RowBox[{
  "probIndexStop", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
  "MCode"],
 " gives the index where it should stop. Both indices are inclusive, which is \
why ",
 Cell[BoxData["probIndexStart"], "MCode"],
 " is offset by one from ",
 Cell[BoxData["probIndexStop"], "MCode"],
 ". (",
 Cell[BoxData["boundList"], "MCode"],
 " ensures that the starting and stopping indices stay within the confines of \
the number of observations available to group.) ",
 Cell[BoxData["keep"], "MCode"],
 " weeds out the zero-length bins, and we use it to reduce ",
 Cell[BoxData["nPhoton"], "MCode"],
 ", ",
 Cell[BoxData["probIndexStart"], "MCode"],
 ", and ",
 Cell[BoxData["probIndexStop"], "MCode"],
 " down to only the nontrivial clusters. We then form ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 " by finding the range of ",
 StyleBox["sorted",
  FontSlant->"Italic"],
 " effective photon numbers that each cluster should encompass and then using \
",
 Cell[BoxData["nPhotonEffSortIndex"], "MCode"],
 " to find the observation numbers to which that range corresponds. ",
 Cell[BoxData["clustMeanTrace"], "MCode"],
 " is formed by taking the waveforms in ",
 Cell[BoxData["dat"], "MCode"],
 " of each cluster in ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 " and averaging them. We then return ",
 Cell[BoxData["nPhotonUse"], "MCode"],
 " (the photon numbers of the nonempty clusters), ",
 Cell[BoxData["iObsOfClust"], "MCode"],
 ", and ",
 Cell[BoxData["clustMeanTrace"], "MCode"],
 "."
}], "Text",
 CellChangeTimes->{{3.6464764917640495`*^9, 3.6464765400173397`*^9}, {
  3.646476601611745*^9, 3.64647681471198*^9}, {3.6464769295366435`*^9, 
  3.646477045080903*^9}, {3.6464770817848682`*^9, 3.646477084873648*^9}, {
  3.64647716565993*^9, 3.646477323158321*^9}, {3.6464773924610767`*^9, 
  3.646477421136693*^9}, {3.646477458439054*^9, 3.6464775087361317`*^9}, {
  3.6464775515472574`*^9, 3.6464776335317316`*^9}, {3.6464778159145627`*^9, 
  3.6464778655252447`*^9}, {3.646477898372034*^9, 3.6464780669741535`*^9}, {
  3.646478275949814*^9, 3.646478337283021*^9}, {3.647166633799225*^9, 
  3.6471666353436155`*^9}, {3.661699541034079*^9, 3.6616996528274393`*^9}, {
  3.665788744774487*^9, 3.6657887831107473`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"groupProb", "[", 
   RowBox[{"dat_", ",", "prob_", ",", "nPhotonEff_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "nPhotonEffSortIndex", ",", "keep", ",", "nObs", ",", "nPhoton", ",", 
      "nPhotonUse", ",", "probCum", ",", "probIndex", ",", "probIndexStart", 
      ",", "probIndexStop", ",", "probList", ",", "probNPhotonUse", ",", 
      "probIndexStartUse", ",", "probIndexStopUse"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nPhotonEffSortIndex", "=", 
      RowBox[{"Ordering", "[", "nPhotonEff", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nPhoton", ",", "probList"}], "}"}], "=", 
      RowBox[{"Transpose", "[", "prob", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nObs", "=", 
      RowBox[{"Length", "[", "dat", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"probCum", "=", 
      RowBox[{"Prepend", "[", 
       RowBox[{
        RowBox[{"Accumulate", "[", "probList", "]"}], ",", "0"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"probCum", " ", "/=", " ", 
      RowBox[{"Last", "[", "probCum", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"probIndexStart", "=", 
      RowBox[{"boundList", "[", 
       RowBox[{
        RowBox[{"1", " ", "+", " ", 
         RowBox[{"Round", "[", 
          RowBox[{"Most", "[", 
           RowBox[{"nObs", "*", "probCum"}], "]"}], "]"}]}], ",", "1", ",", 
        RowBox[{"nObs", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"probIndexStop", "=", 
      RowBox[{"boundList", "[", 
       RowBox[{
        RowBox[{"Round", "[", 
         RowBox[{"Rest", "[", 
          RowBox[{"nObs", "*", "probCum"}], "]"}], "]"}], ",", "0", ",", 
        "nObs"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"keep", "=", 
      RowBox[{"Thread", "[", 
       RowBox[{"probIndexStart", "<=", " ", "probIndexStop"}], "]"}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{"no", " ", "zero", " ", "length", " ", "bins"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"nPhotonUse", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"nPhoton", ",", "keep"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"probIndexStartUse", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"probIndexStart", ",", "keep"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"probIndexStopUse", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"probIndexStop", ",", "keep"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nClust", "=", 
      RowBox[{"Length", "[", "probIndexStartUse", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"iObsOfClust", "=", 
