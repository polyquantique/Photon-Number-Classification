Cell[TextData[{
 StyleBox["Figure ",
  FontWeight->"Bold"],
 StyleBox[
 CounterBox["NumberedFigure"],
  FontWeight->"Bold"],
 StyleBox[".",
  FontWeight->"Bold"],
 " ",
 "Peak visibility for the dot product method (blue) and PIKA (red) through ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "23"}], TraditionalForm]], "Math"],
 " (both lose visibility altogether after that point). Uncertainties are \
given at two standard deviations and are purely statistical."
}], "NumberedFigureCaption",
 CellChangeTimes->{{3.6476096689885783`*^9, 3.6476098155382395`*^9}, {
   3.6476105557030897`*^9, 3.647610574603568*^9}, {3.647610708097763*^9, 
   3.647610709441763*^9}, {3.6476114657517633`*^9, 3.647611501155763*^9}, {
   3.6476117537027636`*^9, 3.6476117907397633`*^9}, {3.647611865104763*^9, 
   3.6476118661437635`*^9}, {3.6500202186172113`*^9, 3.6500202410808773`*^9}, 
   3.662129351883494*^9, 3.662129517701166*^9},
 CellTags->"FigPerf3"],

Cell[TextData[{
 "Figure ",
 
 CounterBox["NumberedFigure", "FigPerf4"],
 " illustrates the loss of visibility with high photon numbers. As ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]], "Math"],
 " increases, cluster means become closer to each other (saturation in the \
normal regime) and individual waveforms overlap with each other more and \
more, making it more difficult to differentiate between adjacent photon \
numbers."
}], "Text",
 CellChangeTimes->{{3.647612146047763*^9, 3.647612287703763*^9}, {
  3.6614674972755527`*^9, 3.661467498477232*^9}}],

