  3.6471028384463406`*^9}, {3.647164111197425*^9, 3.647164112788615*^9}}],

Cell[TextData[{
 "which is equivalent to the first expression. (The final step is valid \
because ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"i", "\[Element]", 
       SubscriptBox["C", "n"]}]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["V",
         FontWeight->"Bold",
         FontSlant->"Plain"], "i"], "-", 
       SubscriptBox[
        OverscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "-"], "n"]}], ")"}]}], "=", "0"}], 
   TraditionalForm]], "Math"],
 ".) \[EmptySquare]"
}], "Text",
 CellChangeTimes->{{3.6471013410967345`*^9, 3.6471013582012253`*^9}, {
  3.647101388478031*^9, 3.647101463659149*^9}, {3.647101529435128*^9, 
  3.647101593308919*^9}, {3.6615197194776287`*^9, 3.661519720197178*^9}}],

Cell[TextData[StyleBox["Lemma:",
 FontWeight->"Bold",
 FontSlant->"Plain"]], "Text",
 CellChangeTimes->{3.647100146546591*^9}],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["V",
     FontWeight->"Bold",
     FontSlant->"Plain"], "i"], TraditionalForm]], "Math"],
 ", ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontWeight->"Bold",
       FontSlant->"Plain"], "-"], "n"],
    FontSlant->"Plain"], TraditionalForm]], "Math"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "n"], TraditionalForm]], "Math"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "n"], TraditionalForm]], "Math"],
 " be as before. Then,"
}], "Theorem",
 CellChangeTimes->{{3.6470973259606404`*^9, 3.6470973291274204`*^9}, {
