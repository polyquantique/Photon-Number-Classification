   3.662829123103819*^9, 3.66282913792523*^9}}],

Cell["This generates a Hanning filter of a given length.", "Text",
 CellChangeTimes->{{3.6465651665510297`*^9, 3.6465651928204193`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"hanningFilter", "[", "n_", "]"}], ":=", 
  RowBox[{"Chop", "[", 
   SuperscriptBox[
    RowBox[{"Cos", "[", 
     FractionBox[
      RowBox[{
       RowBox[{"N", "[", "Pi", "]"}], "*", 
       RowBox[{"Range", "[", 
        RowBox[{"0", ",", 
         RowBox[{"n", "-", "1"}]}], "]"}], " "}], "n"], "]"}], "2"], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.646134240465359*^9, 3.646134261010559*^9}, {
   3.6461421303217216`*^9, 3.6461421458437214`*^9}, {3.646142179134122*^9, 
   3.6461421796957216`*^9}, {3.646150092096768*^9, 3.646150101877968*^9}, {
   3.646150855100768*^9, 3.6461508697647676`*^9}, {3.6465612713419046`*^9, 
   3.646561283306721*^9}, {3.6472509687377405`*^9, 3.647250990642*^9}, 
   3.6621298879371157`*^9, 3.662329542862482*^9, {3.662329885952652*^9, 
   3.662329886719808*^9}, 3.662759777846901*^9, 3.662760198888829*^9, {
   3.662829281855846*^9, 3.662829299928906*^9}}],

Cell[TextData[{
 Cell[BoxData["readTESandFilter"], "MCode"],
 " reads in the ",
 "dataset",
 ", applying a filter to each file\[CloseCurlyQuote]s data before it is \
stored. This halves the memory consumption of the reading process, since \
filtration reduces the amount of information to store by half."
}], "Text",
 CellChangeTimes->{{3.646565368894065*^9, 3.6465655031439066`*^9}, {
   3.6617008302388906`*^9, 3.661700830249511*^9}, 3.665789078796496*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"readTESandFilter", "[", 
   RowBox[{"iNPhoton_", ",", "iDataSet_", ",", "nTime_", ",", "fileInfo_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "datUse", ",", "dat", ",", "datFilt", ",", "nTimeUse", ",", 
      "nSamplePerTrace", ",", "nTracePerFile", ",", "nFile"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nSamplePerTrace", ",", "nTracePerFile"}], "}"}], "=", 
      RowBox[{"fileInfo", "\[LeftDoubleBracket]", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}], "\[RightDoubleBracket]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nFile", "=", 
      RowBox[{"Length", "[", "iDataSet", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"datUse", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"nTracePerFile", "*", "nFile"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"dat", "=", 
         RowBox[{"readTES", "[", 
          RowBox[{"iNPhoton", ",", 
           RowBox[{"{", 
            RowBox[{
            "iDataSet", "\[LeftDoubleBracket]", "iFile", 
             "\[RightDoubleBracket]"}], "}"}], ",", "fileInfo"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"hanning", "=", 
         RowBox[{"hanningFilter", "[", 
          RowBox[{
           RowBox[{"Last", "[", 
            RowBox[{"Dimensions", "[", "dat", "]"}], "]"}], " ", "/", " ", 
           "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"datFilt", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"applyFilterShort", "[", 
             RowBox[{"#", ",", "hanning"}], "]"}], "&"}], ",", "dat"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"nTimeUse", "=", 
         RowBox[{"Min", "[", 
          RowBox[{"nTime", ",", 
           RowBox[{"Length", "[", "hanning", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"datUse", "\[LeftDoubleBracket]", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"iFile", "-", "1"}], ")"}], "*", "nTracePerFile"}], "+",
             "1"}], ";;", 
           RowBox[{"iFile", "*", "nTracePerFile"}]}], 
          "\[RightDoubleBracket]"}], "=", 
         RowBox[{"datFilt", "\[LeftDoubleBracket]", " ", 
          RowBox[{"All", ",", 
           RowBox[{"Range", "[", "nTimeUse", "]"}]}], " ", 
          "\[RightDoubleBracket]"}]}]}], "\[IndentingNewLine]", ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"iFile", ",", "nFile"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"datUse", " ", "-=", " ", 
      RowBox[{"Mean", "[", 
       RowBox[{"datUse", "\[LeftDoubleBracket]", 
        RowBox[{"All", ",", "10"}], "\[RightDoubleBracket]"}], "]"}]}]}]}], 
   "      ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "zeroes", " ", "the", " ", "signal", " ", "at", " ", "an", " ", "early", 
      " ", "point"}], ",", " ", 
     RowBox[{
     "before", " ", "any", " ", "photons", " ", "have", " ", "arrived"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.646134240465359*^9, 3.646134261010559*^9}, {
   3.6461421927061214`*^9, 3.6461422999249215`*^9}, {3.6461424357853217`*^9, 
