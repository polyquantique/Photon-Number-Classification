        RowBox[{
        "datPeakLoc", "\[LeftDoubleBracket]", "iObs", 
         "\[RightDoubleBracket]"}]}], " ", "\[RightDoubleBracket]"}]}], "]"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"iObs", ",", 
      RowBox[{"Length", "[", "dat", "]"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
