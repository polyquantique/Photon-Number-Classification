Cell[TextData[{
 Cell[BoxData["makeField"], "MCode"],
 " creates a rule that, when used in a ",
 Cell[BoxData["FormObject"], "MCode"],
 ", generates a field to set the variable with name ",
 Cell[BoxData["name"], "MCode"],
 " and type ",
 Cell[BoxData["type"], "MCode"],
 " to the entered value, with descriptive text ",
 Cell[BoxData["labelPart"], "MCode"],
 " and default value ",
 Cell[BoxData["defaultContents"], "MCode"],
 ". ",
 Cell[BoxData["args"], "MCode"],
 " takes optional extra arguments that specify additional options for the \
field."
}], "Text",
 CellChangeTimes->{{3.6478566286987877`*^9, 3.647856905677408*^9}, {
  3.661702997895727*^9, 3.661703023069646*^9}, {3.662243288114293*^9, 
  3.662243290319916*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"makeField", "[", 
   RowBox[{
   "name_", ",", "type_", ",", "labelPart_", ",", "defaultContents_", ",", 
    "args___"}], "]"}], ":=", 
  RowBox[{"name", "\[Rule]", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<Interpreter\>\"", "\[Rule]", "type"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<Label\>\"", "\[Rule]", 
      RowBox[{"Overlay", "[", 
       RowBox[{"{", 
        RowBox[{"name", ",", 
         RowBox[{"\"\<\\t\\t  |  \>\"", "<>", "labelPart"}]}], "}"}], "]"}]}],
      ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<Input\>\"", "\[Rule]", "defaultContents"}], ",", 
     "\[IndentingNewLine]", "args"}], "\[IndentingNewLine]", 
    "|>"}]}]}]], "Input",
 CellChangeTimes->CompressedData["
1:eJwlzk0ow3EAh/F5WQ5mm5rEwZq3IhalSSlWs5aRWjGlFIWDMc3LCaFIqM17
bdREeblYU4YVNq8Hr4u1A8MOY1ve87Is+X9/Dk+f68OrVspqgmk0WhwVbA8c
