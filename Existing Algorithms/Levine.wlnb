Cell[TextData[{
 "For the first mean photon number in ",
 Cell[BoxData["nPhotonAvgList"], "MCode"],
 ", the effective photon number ",
 Cell[BoxData[
  RowBox[{
  "nPhotonEff", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
  "MCode"],
 " for observation ",
 Cell[BoxData["i"], "MCode"],
 " is found via the dot-product method. For subsequent means, the optimized \
effective photon number from the previous item on ",
 Cell[BoxData["nPhotonAvgList"], "MCode"],
 " serves as the initial estimate for the next mean, since the elements of ",
 Cell[BoxData["nPhotonAvgList"], "MCode"],
 " are expected to be in order and close together. In the beginning of Loop \
1, we create the initial clustering based on these effective photon numbers."
}], "Text",
 CellChangeTimes->{{3.645289352811942*^9, 3.6452894462276015`*^9}, {
