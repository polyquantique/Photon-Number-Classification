   3.6622078226903057`*^9, 3.6623295367108517`*^9, 3.662329871761813*^9, 
   3.662329999718896*^9}],

Cell[TextData[{
 Cell[BoxData["getSqDevInClust"], "MCode"],
 " takes a list of observations and a mean waveform and totals up the mean \
square deviations of the observations to the mean. (It returns ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["J", "n"], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"i", "\[Element]", 
       SubscriptBox["C", "n"]}]], 
     RowBox[{
      FractionBox["1", 
       SubscriptBox["N", "t"]], 
      RowBox[{
       UnderscriptBox["\[Sum]", "t"], 
       SuperscriptBox[
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           SubscriptBox[
            StyleBox["V",
             FontWeight->"Bold",
             FontSlant->"Plain"], "i"], "(", "t", ")"}], "-", 
          RowBox[{
           SubscriptBox[
            OverscriptBox[
             StyleBox["V",
              FontWeight->"Bold",
              FontSlant->"Plain"], "-"], "n"], "(", "t", ")"}]}], "]"}], 
        "2"]}]}]}]}], TraditionalForm]], "Math"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "n"], TraditionalForm]], "Math"],
 " is the list of observations, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "t"], TraditionalForm]], "Math"],
 " is the number of time points, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["V",
     FontWeight->"Bold",
     FontSlant->"Plain"], "i"], TraditionalForm]], "Math"],
 " are the observations, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontWeight->"Bold",
      FontSlant->"Plain"], "-"], "n"], TraditionalForm]], "Math"],
 " is the mean.)"
}], "Text",
 CellChangeTimes->{{3.6465602670225635`*^9, 3.6465602796584826`*^9}, {
  3.646560445796288*^9, 3.646560488743088*^9}, {3.646560521830688*^9, 
  3.646560629985616*^9}, {3.64656076423678*^9, 3.646560769056686*^9}, {
  3.661700064746894*^9, 3.661700064755631*^9}, {3.661700108305829*^9, 
  3.661700121625256*^9}, {3.6628284700767593`*^9, 3.662828470291265*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getSqDevInClust", "[", 
   RowBox[{"datInClust_", ",", "meanTraceInClust_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Total", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"meanSquare", "[", 
      RowBox[{
       RowBox[{
       "datInClust", "\[LeftDoubleBracket]", "jObs", 
        "\[RightDoubleBracket]"}], "-", "meanTraceInClust"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"jObs", ",", 
       RowBox[{"Length", "[", "datInClust", "]"}]}], "}"}]}], "]"}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.646134211589759*^9, 3.646134213617759*^9}, {
   3.646141487383322*^9, 3.6461415235129213`*^9}, {3.6461416352869215`*^9, 
   3.6461416545373216`*^9}, 3.646145980070768*^9, 3.6461461386759677`*^9, 
   3.646147143134368*^9, 3.646147186065568*^9, {3.646149894179568*^9, 
   3.6461499000139675`*^9}, {3.646149937095168*^9, 3.6461499481867676`*^9}, {
   3.646150026529968*^9, 3.6461500386043677`*^9}, {3.646150091847168*^9, 
   3.646150101628368*^9}, {3.646150420110368*^9, 3.646150432371968*^9}, {
   3.646150823432768*^9, 3.646150869374768*^9}, 3.6465602641989813`*^9, {
   3.6465606364440575`*^9, 3.6465606368028603`*^9}, {3.662131170202629*^9, 
   3.662131174490658*^9}, {3.662329537119076*^9, 3.6623295378555326`*^9}, {
   3.662329872307385*^9, 3.6623298742604856`*^9}, {3.662329999959457*^9, 
   3.662330000207103*^9}}],

Cell[TextData[{
 Cell[BoxData["getSqDevInClust"], "MCode"],
 " returns a list that gives ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "n"], TraditionalForm]], "Math"],
 ", the total mean square deviation of a cluster to its mean, for each \
cluster ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]], "Math"],
 ". The list returned becomes the first argument of ",
 Cell[BoxData["getObjFtn"], "MCode"],
 "."
}], "Text",
