Cell[CellGroupData[{

Cell[TextData[{
 "The Poisson-Influenced ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-Means Algorithm"
}], "Title",
 CellChangeTimes->{{3.6442289430089064`*^9, 3.6442289444597063`*^9}, {
   3.646150092268368*^9, 3.646150102018368*^9}, {3.6461508553659678`*^9, 
   3.6461508699519677`*^9}, {3.647191207778393*^9, 3.647191215163145*^9}, {
   3.6472543664189663`*^9, 3.647254432879936*^9}, {3.647256616987132*^9, 
   3.6472566880115404`*^9}, {3.6473378383589654`*^9, 3.6473378405897512`*^9}, 
   3.650022849231845*^9, 3.6500230314191732`*^9, {3.650023089643715*^9, 
   3.650023091755226*^9}, 3.661618224666637*^9, {3.662323141261035*^9, 
   3.662323160552846*^9}}],

Cell["\<\
A Maximum-Likelihood Procedure for Clusters with a Known Probability \
Distribution\
\>", "Subtitle",
 CellChangeTimes->{{3.661618250129698*^9, 3.661618256388528*^9}}],

Cell["\<\
Brian P. M. Morris
Zachary H. Levine\
\>", "Author",
 CellChangeTimes->{{3.644233278719306*^9, 3.6442332815117064`*^9}, 
   3.644234698345106*^9, {3.646150092346368*^9, 3.6461501020807676`*^9}, {
   3.646150855443968*^9, 3.6461508700455675`*^9}, {3.6471868071719666`*^9, 
   3.647186816923904*^9}}],

Cell[TextData[{
 "We present an implementation of the Poisson-Influenced ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-Means Algorithm (PIKA), first developed to characterize the output of a \
superconducting transition edge sensor (TES) in the few-photon-counting \
regime. The algorithm seeks to group data into several clusters that minimize \
their distances from their means, as in classical ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-means clustering, but with the added knowledge that the cluster sizes \
should follow a Poisson distribution. "
}], "Abstract",
 CellChangeTimes->{{3.6442332940385065`*^9, 3.644233296752906*^9}, {
   3.6461500923931675`*^9, 3.6461501021431675`*^9}, {3.6461508555063677`*^9, 
   3.646150870092368*^9}, {3.6471878581134386`*^9, 3.647187922890639*^9}, 
   3.6471886519027185`*^9, {3.6471888255950108`*^9, 3.6471888555432186`*^9}, {
   3.6471896801784773`*^9, 3.6471897187176304`*^9}, {3.6471897601035957`*^9, 
   3.647189763410774*^9}, {3.6471900120064*^9, 3.6471900193287525`*^9}, 
   3.647190095632064*^9, {3.64719021962527*^9, 3.6471903889821854`*^9}, {
   3.6471904609021244`*^9, 3.6471904913181295`*^9}, {3.64719059807905*^9, 
   3.6471906188807163`*^9}, {3.6471906890054674`*^9, 3.647190716559691*^9}, {
   3.647190816891848*^9, 3.647190825475793*^9}, {3.6472542578170624`*^9, 
   3.647254260001048*^9}, {3.647254297944005*^9, 3.647254303575569*^9}, {
   3.6473373222270737`*^9, 3.6473373239898624`*^9}, 3.647337448388465*^9, 
   3.647337581132414*^9, {3.6473376295545034`*^9, 3.6473376622050943`*^9}, {
   3.647337707193606*^9, 3.6473377161479487`*^9}, 3.647337804443783*^9, {
   3.662323170377334*^9, 3.662323199827899*^9}, {3.6657843013737087`*^9, 
   3.665784301626693*^9}}],

