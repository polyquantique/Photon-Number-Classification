Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ". Updates to the Objective Function"
}], "Section",
 CellChangeTimes->{{3.64373011263439*^9, 3.64373012556679*^9}, {
   3.644234122720706*^9, 3.6442341341867065`*^9}, 3.6452804304148397`*^9, 
   3.6461344494741592`*^9},
 CellTags->{"ObjFtnUpdate", "Updates"}],

Cell["\<\
A naive implementation of the transfer of waveforms between clusters would \
recalculate the various components of the objective function from scratch \
with each change, resulting in a computationally expensive process whose \
running time would depend on the size of the clusters in question. We can \
avoid this excessive calculation by noticing that, given some basic summary \
information about the clusters and waveform to which a given transfer \
pertains, the changes to the objective function and the cluster means are \
very easy to compute without any knowledge of the other waveforms in the \
clusters. The running times of the updates in this section are independent of \
cluster size.\
\>", "Text",
 CellChangeTimes->{{3.644070877662912*^9, 3.644070907989312*^9}, {
  3.644070953057712*^9, 3.6440711374185123`*^9}, {3.644071200926112*^9, 
  3.644071312856112*^9}, {3.6440715056877117`*^9, 3.644071581082512*^9}, {
  3.644071636712112*^9, 3.644071672404912*^9}, {3.644071864695712*^9, 
  3.644071907829712*^9}, {3.644225089007938*^9, 3.6442250900219383`*^9}, {
  3.667308007097139*^9, 3.667308007713482*^9}}],

Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ". Updating the ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-Means Objective Function"
}], "Subsection",
 CellChangeTimes->{{3.6437064863508096`*^9, 3.6437064985812097`*^9}, {
   3.6458727437774296`*^9, 3.64587274504103*^9}, {3.6461344277589593`*^9, 
   3.646134452001359*^9}, 3.6621293527863894`*^9, {3.662325117658243*^9, 
   3.662325120792531*^9}}],

Cell[TextData[{
 "From equation (",
 
 CounterBox["DisplayFormulaNumbered", "eqKMeans"],
 "), we can decompose the ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-means term of the objective function as"
}], "Text",
 CellChangeTimes->{{3.6437066002308097`*^9, 3.6437066298708096`*^9}, {
   3.647616469214755*^9, 3.647616486903442*^9}, 3.6623251452173157`*^9, 
   3.665786044277986*^9, {3.669472761920992*^9, 3.669472763304997*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["O", "K"], "=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", 
       SubscriptBox["n", "0"]}], 
      RowBox[{
       SubscriptBox["n", "0"], "+", "K", "-", "1"}]], 
     SubscriptBox["J", "n"]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.6437066857188096`*^9, 3.64370674289281*^9}, {
  3.6437070416932096`*^9, 3.6437070458896093`*^9}}],

Cell["where", "Text",
 CellChangeTimes->{{3.6437069293196096`*^9, 3.6437069653936095`*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["J", "n"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"i", "\[Element]", 
      SubscriptBox["C", "n"]}]], 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["N", "t"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", "t"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           SubscriptBox["V", "i"], "(", "t", ")"}], "-", 
          RowBox[{
           SubscriptBox[
            OverscriptBox["V", "-"], "n"], "(", "t", ")"}]}], "]"}], "2"], 
       "."}]}]}]}]}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.64370699587601*^9, 3.6437072708260098`*^9}, {
  3.6437073047716093`*^9, 3.6437074134568095`*^9}, {3.644054318562665*^9, 
  3.644054318640668*^9}, {3.6457865790226974`*^9, 3.6457866581820974`*^9}, {
  3.6461500899283676`*^9, 3.646150099584768*^9}, {3.646150851294368*^9, 
  3.646150866145568*^9}}],

Cell[TextData[{
 "If we transfer a waveform ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]], "Math"],
 " into the cluster ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "a"}], TraditionalForm]], "Math"],
 ", the new cluster members form the set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["C", "a", "+"], "=", 
    RowBox[{
     SubscriptBox["C", "a"], "\[Union]", 
     RowBox[{"{", "j", "}"}]}]}], TraditionalForm]], "Math"],
 ". It can be shown that"
}], "Text",
 CellChangeTimes->{{3.6437074571836095`*^9, 3.6437075671012096`*^9}, {
  3.661519209832384*^9, 3.6615192105056133`*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubsuperscriptBox["J", "a", "+"], "=", 
   RowBox[{
    SubscriptBox["J", "a"], "+", 
    RowBox[{
     RowBox[{"(", 
      FractionBox[
       SubscriptBox["m", "a"], 
       RowBox[{
        SubscriptBox["m", "a"], "+", "1"}]], ")"}], 
     FractionBox["1", 
      SubscriptBox["N", "t"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", "t"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           SubscriptBox["V", "j"], "(", "t", ")"}], "-", 
          RowBox[{
           SubscriptBox[
            OverscriptBox["V", "-"], "a"], "(", "t", ")"}]}], "]"}], "2"], 
       "."}]}]}]}]}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.6437075967724094`*^9, 3.6437077568888097`*^9}, {
   3.64370785385561*^9, 3.6437079427756095`*^9}, {3.6440542770633345`*^9, 
   3.6440542835531425`*^9}, {3.645786695179697*^9, 3.645786717447897*^9}, {
   3.646150089943968*^9, 3.6461500996003675`*^9}, {3.646150851309968*^9, 
   3.646150866161168*^9}, 3.646586325602662*^9, {3.64709366979688*^9, 
   3.6470936703116765`*^9}},
 CellTags->"J+"],

Cell[TextData[{
 "If we transfer a waveform ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]], "Math"],
 " out of the cluster ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "b"}], TraditionalForm]], "Math"],
 ", the new cluster members form the set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["C", "b", "-"], "=", 
    RowBox[{
     SubscriptBox["C", "b"], "-", 
     RowBox[{"{", "j", "}"}]}]}], TraditionalForm]], "Math"],
 ", with"
}], "Text",
 CellChangeTimes->{{3.6437079483136096`*^9, 3.6437080330216093`*^9}, {
  3.646578314956109*^9, 3.646578319230509*^9}, {3.6615192266452503`*^9, 
  3.661519228093299*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubsuperscriptBox["J", "b", "-"], "=", 
   RowBox[{
    SubscriptBox["J", "b"], "-", 
    RowBox[{
     RowBox[{"(", 
      FractionBox[
       SubscriptBox["m", "b"], 
       RowBox[{
        SubscriptBox["m", "b"], "-", "1"}]], ")"}], 
     FractionBox["1", 
      SubscriptBox["N", "t"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", "t"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           SubscriptBox["V", "j"], "(", "t", ")"}], "-", 
          RowBox[{
           SubscriptBox[
            OverscriptBox["V", "-"], "b"], "(", "t", ")"}]}], "]"}], "2"], 
       "."}]}]}]}]}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.6437080432240095`*^9, 3.6437081331268096`*^9}, 
   3.6440542916050014`*^9, {3.6440543559258623`*^9, 3.6440543758945026`*^9}, {
   3.6457866969580975`*^9, 3.6457867208350973`*^9}, {3.646150089943968*^9, 
   3.6461500996159678`*^9}, {3.6461508513255677`*^9, 3.6461508661923676`*^9}, 
   3.646586343339862*^9, {3.6470936724800625`*^9, 3.64709367290126*^9}},
 CellTags->"J-"],

Cell[TextData[{
 "In equations (",
 
 CounterBox["DisplayFormulaNumbered", "J+"],
 ") and (",
 
 CounterBox["DisplayFormulaNumbered", "J-"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["V", "-"], "a"], "(", "t", ")"}], TraditionalForm]], 
  "Math"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["V", "-"], "b"], "(", "t", ")"}], TraditionalForm]], 
  "Math"],
 " refer to the original clusters ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "a"], TraditionalForm]], "Math"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "b"], TraditionalForm]], "Math"],
 ", before the transfer of ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]], "Math"],
 ". See below for a proof that these equations indeed give the proper changes \
in cluster deviation. Equation (",
 
 CounterBox["DisplayFormulaNumbered", "J-"],
 ") corrects equation (A4) in [",
 
 CounterBox["Reference", "RefOrigPaper"],
 "]. After the transfer, the cluster means for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "a"}], TraditionalForm]], "Math"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "b"}], TraditionalForm]], "Math"],
 " become"
}], "Text",
 CellChangeTimes->{{3.6437081618152094`*^9, 3.6437081649664097`*^9}, {
   3.64370834454101*^9, 3.6437083447906094`*^9}, {3.6437084380586095`*^9, 
   3.6437084896050096`*^9}, {3.6437086056564093`*^9, 
   3.6437087863656096`*^9}, {3.6437275452109303`*^9, 
   3.6437276069089303`*^9}, {3.6437318944165897`*^9, 
   3.6437319497023897`*^9}, {3.644054300247678*^9, 3.6440543089839582`*^9}, 
   3.646410378723115*^9, {3.6465675054853086`*^9, 3.6465675134101086`*^9}, {
   3.6470952686306305`*^9, 3.647095303387208*^9}, {3.647164910921477*^9, 
   3.6471649398748913`*^9}, {3.6476233650452175`*^9, 3.647623384144495*^9}, 
   3.6623261993802233`*^9, 3.665786021714218*^9, {3.665786069041849*^9, 
   3.665786084483163*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      OverscriptBox["V", "-"], "n", "'"], "(", "t", ")"}], "=", 
    FractionBox[
     RowBox[{
      RowBox[{
       SubscriptBox["m", "n"], 
       RowBox[{
        SubscriptBox[
         OverscriptBox["V", "-"], "n"], "(", "t", ")"}]}], "\[PlusMinus]", 
      RowBox[{
       SubscriptBox["V", "j"], "(", "t", ")"}]}], 
     RowBox[{
      SubscriptBox["m", "n"], "\[PlusMinus]", "1"}]]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.6437087992416096`*^9, 3.6437089273260098`*^9}, {
   3.6437090981846094`*^9, 3.6437091829684095`*^9}, {3.6440544278011847`*^9, 
   3.6440544278011847`*^9}, 3.662222289759061*^9}],

Cell[TextData[{
 "with plus signs for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "a"}], TraditionalForm]], "Math"],
 " and minus signs for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "b"}], TraditionalForm]], "Math"],
 ". No cluster is ever allowed to become empty (in such a case we would have \
not ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 " but ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "-", "1"}], TraditionalForm]], "Math"],
 " means), so the denominator never becomes zero. Therefore, we can determine \
the appropriate change to the means and square deviations of the clusters \
between which the transfer takes place."
}], "Text",
 CellChangeTimes->{{3.6437091850608096`*^9, 3.6437094422744093`*^9}, {
   3.6437272745821304`*^9, 3.64372727732773*^9}, {3.6437278189985476`*^9, 
   3.6437278193104897`*^9}, {3.646567627820509*^9, 3.6465676439509087`*^9}, {
   3.662326212101728*^9, 3.6623262231054296`*^9}, {3.665786100286512*^9, 
   3.665786106961438*^9}, {3.667308087018054*^9, 3.667308092070301*^9}, 
   3.667563491196694*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"deltaKMeansAdd", "[", "\[IndentingNewLine]", 
   RowBox[{"freq_", ",", 
    RowBox[{"(*", " ", 
     RowBox[{
     "size", " ", "of", " ", "the", " ", "cluster", " ", "to", " ", "be", " ",
       "added", " ", "to"}], " ", "*)"}], "\[IndentingNewLine]", 
    "meanSquareDiff_"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "mean", " ", "square", " ", "of", " ", "the", " ", "difference", " ", 
     "between", " ", "the", " ", "waveform", " ", "to", " ", "be", " ", 
     "transferred", " ", "and", " ", "the", " ", "cluster", " ", "mean", " ", 
     "waveform"}], " ", "*)"}], "\[IndentingNewLine]", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"(", 
    FractionBox["freq", 
     RowBox[{"freq", "+", "1"}]], ")"}], "*", "meanSquareDiff"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.6437310899867897`*^9, {3.64373119189799*^9, 3.64373121492659*^9}, 
