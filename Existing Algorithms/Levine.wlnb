   3.665785434073298*^9, 3.665785449496346*^9}, {3.667088854315358*^9, 
   3.667088854326679*^9}, {3.6673079807169647`*^9, 3.667307980914832*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"runPIKA", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"initialSetup", "[", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"readAndFilterData", "[", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"optionallyRejectBackgroundTraces", "[", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"graphGlobalMeanTrace", "[", "]"}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"findDotProductEffectivePhotonNumbers", "[", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Do", "[", "              ", 
     RowBox[{"(*", " ", 
      RowBox[{"Loop", " ", "1"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"createInitialClusters", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphSampleMiddleClusters", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphClusterMeans", "[", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"findInitialObjectiveFunction", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphClusterDeviationsFromMean", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"prepareOptimizationLoop", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "              ", 
        RowBox[{"(*", " ", 
         RowBox[{"Loop", " ", "2"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"prepareSubLoop", "[", "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Do", "[", "            ", 
           RowBox[{"(*", " ", 
            RowBox[{"Loop", " ", "3"}], " ", "*)"}], "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"getClusterAndNeighbors", "[", "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"updateRelevantDeviations", "[", "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"findChangeInObjectiveFunction", "[", "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"decideWhetherToMove", "[", "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"updateIfMoving", "[", "]"}], ";"}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"{", 
             RowBox[{"jObs", ",", "nObs"}], "}"}]}], "\[IndentingNewLine]", 
           "]"}], ";", 
          RowBox[{"(*", " ", 
           RowBox[{"End", " ", "Loop", " ", "3"}], " ", "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"updateAnnealingTemperature", "[", "]"}], ";"}], 
         "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"iCool", ",", "nCool"}], "}"}]}], "\[IndentingNewLine]", 
        "]"}], ";", 
       RowBox[{"(*", " ", 
        RowBox[{"End", " ", "Loop", " ", "2"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"prepareAnalysisAndOutput", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphNewSampleMiddleClusters", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphNewClusterMeans", "[", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"graphProbabilityDistribution", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphNewClusterToMeanDeviations", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphNewMeanToMeanDeviations", "[", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"graphNewEffectivePhotonNumber", "[", "]"}], ";"}], 
      "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"iNPhotonAvgList", ",", 
        RowBox[{"Length", "[", "nPhotonAvgList", "]"}]}], "}"}]}], 
     "\[IndentingNewLine]", "]"}], ";", 
    RowBox[{"(*", " ", 
     RowBox[{"End", " ", "Loop", " ", "1"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"showOutput", "[", "]"}]}], "\[IndentingNewLine]", 
   ")"}]}]], "Input",
 InitializationCell->True,
