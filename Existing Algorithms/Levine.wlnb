Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 " ",
 "Reading and Filtering Data"
}], "Subsection",
 CellChangeTimes->{{3.6461316828853593`*^9, 3.646131685006959*^9}, {
   3.646131781290159*^9, 3.646131785065359*^9}, {3.646133221005359*^9, 
   3.6461332214889593`*^9}, {3.646134349088159*^9, 3.646134368229359*^9}, {
   3.646565982552472*^9, 3.6465659827084827`*^9}, 3.662129353508328*^9},
 CellTags->"FDefReading"],

Cell[TextData[{
 Cell[BoxData["readTES"], "MCode"],
 " reads in the data from a set of files specified in the options, returning ",
 Cell[BoxData["dat"], "MCode"],
 ", a table whose rows give the values of particular waveforms at regular \
time intervals. ",
 Cell[BoxData["readTES"], "MCode"],
 " assumes that several different datasets may share a directory and that \
each dataset is split over some number of files, each of which consists of an \
equal number of unsigned 16-bit integers concatenated together in string \
form. ",
 Cell[BoxData["iNPhoton"], "MCode"],
 " gives the numeric label of the dataset to read (it is not equal to the \
mean photon number of the dataset). ",
 Cell[BoxData["iDataSet"], "MCode"],
 " lists the indices of the particular files in the dataset that should be \
read in. ",
 Cell[BoxData["fileInfo"], "MCode"],
 " is a list of three things: ",
 Cell[BoxData["fileNamePart"], "MCode"],
 ", a list of two strings that combine with the dataset label and the file \
index to create the whole filename; ",
 Cell[BoxData["nSamplePerTrace"], "MCode"],
 ", the number of time points in each waveform; and ",
 Cell[BoxData["nTracePerFile"], "MCode"],
 ", the number of waveforms in each file of the ",
 "dataset",
 "."
}], "Text",
 CellChangeTimes->{{3.646561787015973*^9, 3.6465617917588596`*^9}, {
   3.646562205861763*^9, 3.646562260417062*^9}, {3.646562474220758*^9, 
   3.646562513190307*^9}, {3.6465625469181557`*^9, 3.646562713716118*^9}, {
   3.646563019577783*^9, 3.646563053475062*^9}, {3.646563109025034*^9, 
   3.646563156713623*^9}, {3.6465631895824013`*^9, 3.6465632844603853`*^9}, {
   3.6465633254098597`*^9, 3.646563440458934*^9}, {3.6465641108594155`*^9, 
   3.646564134742403*^9}, {3.646564396316576*^9, 3.6465644182188354`*^9}, {
   3.661700629675851*^9, 3.6617006637453203`*^9}, 3.665784388694603*^9, {
   3.665789078340658*^9, 3.665789078716313*^9}}],

Cell[TextData[{
 "For example, if ",
 Cell[BoxData["iNPhoton"], "MCode"],
 " were ",
 Cell[BoxData["7"], "MCode"],
 ", ",
 Cell[BoxData["iDataSet"], "MCode"],
 " were ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"2", ",", "6", ",", "20"}], "}"}]], "MCode"],
 ", and ",
 Cell[BoxData["fileInfo"], "MCode"],
 " were ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<[directory]/TES \>\"", ",", "\"\<.daq \>\""}], "}"}], ",", 
    "200", ",", "512"}], "}"}]], "MCode"],
 ", then we would be looking for the files ",
 Cell[BoxData[
  RowBox[{"TES7", ".", "daq02"}]], "MCode"],
 ", ",
 Cell[BoxData[
  RowBox[{"TES7", ".", "daq06"}]], "MCode"],
 ", and ",
 Cell[BoxData[
  RowBox[{"TES7", ".", "daq20"}]], "MCode"],
 " in ",
 StyleBox[Cell[BoxData[
  RowBox[{"[", "directory", "]"}]], "MCode"], "MCode"],
 ", with 200 time points in each waveform and 512 waveforms in each of the \
three files."
}], "Text",
 CellChangeTimes->{{3.646563487180934*^9, 3.646563586864934*^9}, {
  3.646563622994534*^9, 3.646563655692134*^9}, {3.646563705159734*^9, 
  3.6465638107079096`*^9}, {3.6465638533862267`*^9, 3.6465638993714886`*^9}, {
  3.6465639305831256`*^9, 3.6465639324393826`*^9}, {3.6465639670375214`*^9, 
  3.646563987393955*^9}, {3.6617006748582697`*^9, 3.661700778646562*^9}}],

Cell[TextData[{
 "For each file, we import the data as a list of samples, organize the \
samples into sublists (waveforms) of length ",
 Cell[BoxData["nSamplePerTrace"], "MCode"],
 ", and assign the list of waveforms to the appropriate section of ",
 Cell[BoxData["dat"], "MCode"],
 ". When all of the files have been read, ",
 Cell[BoxData["dat"], "MCode"],
 " is full and properly formatted."
}], "Text",
 CellChangeTimes->{{3.646564158765787*^9, 3.6465643497828894`*^9}, {
  3.647180714586151*^9, 3.647180836944163*^9}, {3.64718091383607*^9, 
  3.6471809356291304`*^9}, {3.66170079862908*^9, 3.661700808306713*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"readTES", "[", 
   RowBox[{"iNPhoton_", ",", "iDataSet_", ",", "fileInfo_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "fileNameA", ",", "nSamplePerTrace", ",", "nFile", ",", "fileNamePart", 
      ",", "nTracePerFile", ",", "nTrace", ",", "dat", ",", "serialNumber", 
      ",", "fileName", ",", "dim", ",", "datImport"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"fileNamePart", ",", "nSamplePerTrace", ",", "nTracePerFile"}],
        "}"}], "=", "fileInfo"}], ";", 
     RowBox[{"fileNameA", "=", 
      RowBox[{
       RowBox[{
       "fileNamePart", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}],
        "<>", 
       RowBox[{"IntegerString", "[", "iNPhoton", "]"}], "<>", 
       RowBox[{
       "fileNamePart", "\[LeftDoubleBracket]", "2", 
        "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nFile", "=", 
      RowBox[{"Length", "[", "iDataSet", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nTrace", "=", 
      RowBox[{"nTracePerFile", "*", "nFile"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "nTrace"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"serialNumber", "=", 
         RowBox[{"IntegerString", "[", 
          RowBox[{
           RowBox[{
           "iDataSet", "\[LeftDoubleBracket]", "iFile", 
            "\[RightDoubleBracket]"}], ",", "10", ",", "2"}], "]"}]}], ";", 
        " ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "padding", " ", "to", " ", "ensure", " ", "2", " ", "digits"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"fileName", "=", 
         RowBox[{"fileNameA", "<>", "serialNumber"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"FileExistsQ", "[", "fileName", "]"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<readTESdata: \>\"", "<>", "fileName", "<>", 
             "\"\< does not exist\>\""}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Abort", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"datImport", "=", 
         RowBox[{"Partition", "[", 
          RowBox[{
           RowBox[{"Import", "[", 
            RowBox[{"fileName", ",", "\"\<UnsignedInteger16\>\""}], "]"}], 
           ",", "nSamplePerTrace"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"dat", "\[LeftDoubleBracket]", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"iFile", "-", "1"}], ")"}], "*", "nTracePerFile"}], "+",
             "1"}], ";;", 
           RowBox[{"iFile", "*", "nTracePerFile"}]}], 
          "\[RightDoubleBracket]"}], "=", "datImport"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"iFile", ",", "nFile"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"dim", "=", 
      RowBox[{"Dimensions", "[", "dat", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"dim", " ", "\[NotEqual]", 
        RowBox[{"{", 
         RowBox[{"nTrace", ",", "nSamplePerTrace"}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<readTESdata: unexpected values for dim\>\"", ",", "dim"}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<readTESdata:  expected \>\"", ",", 
          RowBox[{"{", 
           RowBox[{"nTrace", ",", "nSamplePerTrace"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Abort", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "dat"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{
  3.645263992316685*^9, {3.645264040343485*^9, 3.6452640421218853`*^9}, 
   3.645968241515902*^9, 3.6461342374701595`*^9, {3.6461416995433216`*^9, 
   3.6461420045545216`*^9}, 3.646142310033722*^9, {3.6461461387071676`*^9, 
   3.646146138738368*^9}, {3.646147143196768*^9, 3.6461471432279677`*^9}, {
   3.646147186096768*^9, 3.646147186127968*^9}, {3.646149894226368*^9, 
   3.646149900076368*^9}, {3.646149937141968*^9, 3.646149948249168*^9}, {
   3.646150026576768*^9, 3.646150038666768*^9}, {3.6461500918939676`*^9, 
   3.646150101768768*^9}, {3.646150420157168*^9, 3.646150432434368*^9}, {
   3.646150823463968*^9, 3.646150869593168*^9}, 3.646561011128256*^9, {
   3.6465614410204115`*^9, 3.646561510439966*^9}, {3.6465616187344723`*^9, 
   3.6465616215424547`*^9}, {3.646564028340805*^9, 3.646564037154127*^9}, {
