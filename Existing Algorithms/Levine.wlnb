Cell[BoxData[
 RowBox[{
  RowBox[{"graphNewClusterMeans", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"clustFreq", "=", 
     RowBox[{"pair", "[", 
      RowBox[{"nPhotonOfClust", ",", "freqNew"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<Numerical Cluster Means\>\"", ",", 
      "\"\<After optimization, \
{nPhotonAvgNew,clustFreq,clustMeanTrace}=\>\""}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nPhotonAvgNew", ",", "clustFreq", ",", "clustMeanTrace"}], 
       "}"}], ",", "iNPhotonAvgList", ",", 
      "\"\<Numerical Cluster Means\>\""}], "]"}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"p9a", "=", 
     RowBox[{"ListPlot", "[", 
