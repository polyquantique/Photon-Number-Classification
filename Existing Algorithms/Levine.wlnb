Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 
 CounterBox["Subsubsection"],
 ".",
 " ",
 "Derivation of the Update Formulas"
}], "Subsubsection",
 CellChangeTimes->{{3.647095591564161*^9, 3.647095623621955*^9}, {
   3.6470965194770107`*^9, 3.6470965358257055`*^9}, 3.647164984646604*^9, {
   3.64716502427035*^9, 3.6471650273591304`*^9}, 3.662129352893242*^9}],

Cell[TextData[{
 "The derivation for equations (",
 
 CounterBox["DisplayFormulaNumbered", "J+"],
 ") and (",
 
 CounterBox["DisplayFormulaNumbered", "J-"],
 ") is slightly involved and requires some preliminaries. Voltage signals are \
considered as vectors for the derivation, denoted ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "i"], TraditionalForm]], "Math"],
 ", where the discrete time index ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]], "Math"],
 " is not given explicitly in this section. "
}], "Text",
 CellChangeTimes->{
  3.6470959335139685`*^9, {3.647096618224377*^9, 3.647096709686591*^9}, {
   3.647096844298128*^9, 3.6470968501636906`*^9}, {3.647104836489331*^9, 
   3.647104963899506*^9}, {3.6471648521410537`*^9, 3.6471648531082473`*^9}, {
   3.661519632838357*^9, 3.661519645957901*^9}, {3.662243203405293*^9, 
   3.662243203907105*^9}, {3.664878891915268*^9, 3.6648788935447683`*^9}, {
   3.6648789727938232`*^9, 3.664879070312887*^9}, {3.6653365276301403`*^9, 
   3.6653365732226467`*^9}, 3.665786028684729*^9, {3.6657870573285418`*^9, 
   3.665787066534135*^9}, {3.668923474649605*^9, 3.668923475401157*^9}}],

Cell[TextData[StyleBox["Lemma:",
 FontWeight->"Bold",
 FontSlant->"Plain"]], "Text",
 CellChangeTimes->{3.647100146546591*^9}],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["V",
     FontWeight->"Bold",
     FontSlant->"Plain"], "i"], TraditionalForm]], "Math"],
 " be the signal vector of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]], "Math"],
 " observation, and ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontWeight->"Bold",
       FontSlant->"Plain"], "-"], "n"],
    FontSlant->"Plain"], TraditionalForm]], "Math"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "n"], TraditionalForm]], "Math"],
 " be the cluster mean vector and sum of deviations, respectively, for \
cluster ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "n"], TraditionalForm]], "Math"],
 ". Then,"
}], "Theorem",
 CellChangeTimes->{{3.6470973259606404`*^9, 3.6470973291274204`*^9}, {
   3.6470977473063245`*^9, 3.6470977507539024`*^9}, 3.6470978089887295`*^9, {
   3.6470978479344797`*^9, 3.6470978559070287`*^9}, 3.6470979886441736`*^9, 
   3.647098038703653*^9, {3.647098121328123*^9, 3.6470982082027664`*^9}, {
   3.6470982401009617`*^9, 3.6470983615691833`*^9}, {3.6470985304303017`*^9, 
   3.6470986409873934`*^9}, {3.6470987664893885`*^9, 
   3.6470987819518895`*^9}, {3.6470990169897833`*^9, 3.64709904401381*^9}, {
   3.647099083182559*^9, 3.647099083198159*^9}, {3.6471001387854404`*^9, 
   3.647100139674635*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["J", "n"], "=", 
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"i", "\[Element]", 
       SubscriptBox["C", "n"]}]], 
     FractionBox[
      RowBox[{
       StyleBox["||",
        FontWeight->"Bold"], 
       RowBox[{
        SubscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "i"], "-", 
        SubscriptBox[
         OverscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "-"], "n"]}], 
       SuperscriptBox["||", "2"]}], 
      SubscriptBox["N", "t"]]}], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "\[Element]", 
        SubscriptBox["C", "n"]}]}]], 
     RowBox[{
      FractionBox[
       RowBox[{"||", 
        RowBox[{
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "i"], "-", 
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "j"]}], 
        SuperscriptBox["||", "2"]}], 
       RowBox[{"2", 
        SubscriptBox["m", "n"], 
        SubscriptBox["N", "t"]}]], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.6470987869594574`*^9, 3.6470988354841466`*^9}, 
   3.6470988669697447`*^9, {3.647098974642655*^9, 3.6470990059410543`*^9}, {
   3.6470991060892124`*^9, 3.6470992073515596`*^9}, 3.6470997965992365`*^9, {
   3.647099843639735*^9, 3.6470999867862144`*^9}, {3.6471000867661734`*^9, 
   3.6471000874369698`*^9}, 3.6471025194281855`*^9}],

Cell[TextData[StyleBox["Proof:",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.647100122866543*^9, 3.647100125161728*^9}, {
  3.647100158439715*^9, 3.6471001597501063`*^9}}],

Cell[TextData[{
 "The first expression for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "n"], TraditionalForm]], "Math"],
 " is merely the definition; we now show that the second expression is \
equivalent."
}], "Proof",
 CellChangeTimes->{{3.647100241403183*^9, 3.6471003047747774`*^9}, {
  3.647100381376086*^9, 3.647100391898419*^9}}],

Cell[BoxData[{
 FormBox[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"i", ",", 
     RowBox[{"j", "\[Element]", 
      SubscriptBox["C", "n"]}]}]], 
   FractionBox[
    RowBox[{"||", 
     RowBox[{
      SubscriptBox[
       StyleBox["V",
        FontWeight->"Bold",
        FontSlant->"Plain"], "i"], "-", 
      SubscriptBox[
       StyleBox["V",
        FontWeight->"Bold",
        FontSlant->"Plain"], "j"]}], 
     SuperscriptBox["||", "2"]}], 
    RowBox[{"2", 
     SubscriptBox["m", "n"], 
     SubscriptBox["N", "t"]}]]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", 
      SubscriptBox["m", "n"], 
      SubscriptBox["N", "t"]}]], "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["m", "n"], 
      UnderscriptBox["\[Sum]", 
       RowBox[{"i", "\[Element]", 
        SubscriptBox["C", "n"]}]]}], "||", 
     SubscriptBox[
      StyleBox["V",
       FontWeight->"Bold",
       FontSlant->"Plain"], "i"], 
     SuperscriptBox["||", "2"], 
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        UnderscriptBox["\[Sum]", 
         RowBox[{"i", ",", 
          RowBox[{"j", "\[Element]", 
           SubscriptBox["C", "n"]}]}]], 
        RowBox[{"2", 
         RowBox[{
          SubscriptBox[
           StyleBox["V",
            FontWeight->"Bold",
            FontSlant->"Plain"], "i"], "\[CenterDot]", 
          SubscriptBox[
           StyleBox["V",
            FontWeight->"Bold",
            FontSlant->"Plain"], "j"]}]}]}]}], "+", 
      RowBox[{
       SubscriptBox["m", "n"], 
       UnderscriptBox["\[Sum]", 
        RowBox[{"j", "\[Element]", 
         SubscriptBox["C", "n"]}]]}]}], "||", 
     SubscriptBox[
      StyleBox["V",
       FontWeight->"Bold",
       FontSlant->"Plain"], "j"], 
     SuperscriptBox["||", "2"]}], "]"}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    FractionBox["1", 
     SubscriptBox["N", "t"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"i", "\[Element]", 
       SubscriptBox["C", "n"]}]], 
     RowBox[{"(", 
      RowBox[{"||", 
       SubscriptBox[
        StyleBox["V",
         FontWeight->"Bold",
         FontSlant->"Plain"], "i"], 
       SuperscriptBox["||", "2"], 
       RowBox[{
        RowBox[{"-", 
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "i"]}], "\[CenterDot]", 
        SubscriptBox[
         OverscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "-"], "n"]}]}], ")"}]}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    FractionBox["1", 
     SubscriptBox["N", "t"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"i", "\[Element]", 
       SubscriptBox["C", "n"]}]], 
     RowBox[{
      SubscriptBox[
       StyleBox["V",
        FontWeight->"Bold",
        FontSlant->"Plain"], "i"], "\[CenterDot]", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox[
         StyleBox["V",
          FontWeight->"Bold",
          FontSlant->"Plain"], "i"], "-", 
        StyleBox[
         SubscriptBox[
          OverscriptBox[
           StyleBox["V",
            FontWeight->"Bold",
            FontSlant->"Plain"], "-"], "n"],
         FontSlant->"Italic"]}], ")"}]}]}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["N", "t"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"i", "\[Element]", 
        SubscriptBox["C", "n"]}]], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "i"], "-", 
         StyleBox[
          SubscriptBox[
           OverscriptBox[
            StyleBox["V",
             FontWeight->"Bold",
             FontSlant->"Plain"], "-"], "n"],
          FontSlant->"Italic"]}], ")"}], "\[CenterDot]", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox[
          StyleBox["V",
           FontWeight->"Bold",
           FontSlant->"Plain"], "i"], "-", 
         StyleBox[
          SubscriptBox[
           OverscriptBox[
            StyleBox["V",
             FontWeight->"Bold",
             FontSlant->"Plain"], "-"], "n"],
          FontSlant->"Italic"]}], ")"}]}]}]}]}], ","}], 
  TraditionalForm]}], "DisplayFormula",
 CellChangeTimes->{{3.647100408439313*^9, 3.647100464699952*^9}, {
  3.6471005309887276`*^9, 3.6471007766827507`*^9}, {3.647100813108917*^9, 
  3.647100874266326*^9}, {3.6471009114080877`*^9, 3.6471009474890566`*^9}, {
  3.647100982277233*^9, 3.6471010225927753`*^9}, {3.647101082263193*^9, 
