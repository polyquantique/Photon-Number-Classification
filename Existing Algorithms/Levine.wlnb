       RowBox[{"outputAdd", "[", 
        RowBox[{"p1", ",", "0", ",", "\"\<\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"dat", "=", 
        RowBox[{
        "dat", " ", "\[LeftDoubleBracket]", " ", "iObsKeep", " ", 
         "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"iObsDrop", "=."}], ";", "               ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "after", " ", "dat", " ", "is", " ", "overwritten", " ", "these", " ",
          "index", " ", "sets", " ", "lose", " ", "their", " ", "meaning"}], 
        " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"iObsKeep", "=."}]}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"nObs", "=", 
     RowBox[{"Length", "[", "dat", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"print", "[", 
     RowBox[{
