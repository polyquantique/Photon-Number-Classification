Cell[BoxData[
 RowBox[{
  RowBox[{"createInitialClusters", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nPhotonAvg", "=", 
     RowBox[{
     "nPhotonAvgList", "\[LeftDoubleBracket]", "iNPhotonAvgList", 
      "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "prob", ",", "nPhotonOfClust", ",", "iObsOfClust", ",", 
       "clustMeanTrace"}], "}"}], "=", 
     RowBox[{"groupProbability", "[", 
      RowBox[{"dat", ",", "nPhotonAvg", ",", "nPhotonEff", ",", "nSigma"}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"nClust", "=", 
     RowBox[{"Length", "[", "clustMeanTrace", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"print", "[", 
     RowBox[{"iNPhotonAvgList", ",", "\"\<PIKA: nClust \>\"", ",", "nClust"}],
      "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<\>\"", ",", 
      "\"\<Initial mean photon number: \>\"", ",", "nPhotonAvg"}], "]"}], 
    ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
