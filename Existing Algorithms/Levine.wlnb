Cell[TextData[{
 "The initial, unoptimized value of the objective function, from equation (",
 
 CounterBox["DisplayFormulaNumbered", "eqObjFtn"],
 ") above, is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["O", 
     RowBox[{"K", "\[InvisibleSpace]", "P", "\[InvisibleSpace]", "C"}]], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", 
        SuperscriptBox["\[Sigma]", "2"]}]], 
      SubscriptBox["O", "K"]}], "+", 
     SubscriptBox["O", 
      RowBox[{"P", "\[InvisibleSpace]", "C"}]]}]}], TraditionalForm]], "Math"],
 ". Here, ",
 Cell[BoxData["sqDevOfClust"], "MCode"],
 " is a table containing the square deviation of each cluster from its own \
mean (each element is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"i", "\[Element]", 
      SubscriptBox["C", "n"]}]], 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["N", "t"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", "t"], 
      SuperscriptBox[
       RowBox[{"[", 
        RowBox[{
         RowBox[{
          SubscriptBox["V", "i"], "(", "t", ")"}], "-", 
         RowBox[{
          SubscriptBox[
           OverscriptBox["V", "-"], "n"], "(", "t", ")"}]}], "]"}], 
       "2"]}]}]}], TraditionalForm]], "Math"],
 " for cluster ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "n"], TraditionalForm]], "Math"],
 "), so the table\[CloseCurlyQuote]s sum is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "K"], TraditionalForm]], "Math"],
 ", the ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]], "Math"],
 "-means term of the objective function. ",
 Cell[BoxData["nOfClust"], "MCode"],
 " is a list of cluster sizes, and ",
 Cell[BoxData["logLikeProb"], "MCode"],
 " is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", 
    RowBox[{"P", "\[InvisibleSpace]", "C"}]], TraditionalForm]], "Math"],
 ", the Poisson-combinatorial term. ",
 Cell[BoxData["sigmaObjFtn"], "MCode"],
 " is ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]], "Math"],
 ", the regularization parameter for the objective function based on the \
deviations of the initial clusters (unlike ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "K"], TraditionalForm]], "Math"],
 ", ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]], "Math"],
 " does not change as the objective function is minimized)."
}], "Text",
 CellChangeTimes->{{3.645782240142897*^9, 3.645782289213297*^9}, {
   3.6457824427574973`*^9, 3.645782528567897*^9}, {3.645782647637697*^9, 
