   3.6461341356021595`*^9}, {3.6461407356349216`*^9, 
   3.6461407480213213`*^9}, {3.6461408162869215`*^9, 3.6461408205613213`*^9}, 
   3.6461409243325214`*^9, {3.646150091441568*^9, 3.6461501012071676`*^9}, {
   3.6461508539619675`*^9, 3.646150868688368*^9}, 3.646479570595001*^9, 
   3.6464800305148764`*^9, 3.6621298878660603`*^9, {3.662329528758185*^9, 
   3.662329529320695*^9}, {3.6623298616867533`*^9, 3.662329863333291*^9}, {
   3.662329993968045*^9, 3.662329994861896*^9}, 3.662760378360602*^9, {
   3.662760423447001*^9, 3.6627604331394053`*^9}, {3.664881962126968*^9, 
   3.6648820250708227`*^9}}],

Cell[TextData[{
 "The Poisson log-likelihood term is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"ln", " ", 
     SubscriptBox["\[ScriptCapitalL]", "P"]}], "=", 
    RowBox[{
     RowBox[{"-", "\[Mu]M"}], "+", 
     RowBox[{"\[Sum]", 
      RowBox[{
       SubscriptBox["m", "n"], "[", 
       RowBox[{
        RowBox[{"n", " ", "ln", " ", "\[Mu]"}], "-", 
        RowBox[{"ln", "(", 
         RowBox[{"n", "!"}], ")"}]}], "]"}]}]}]}], TraditionalForm]], "Math"],
 "."
}], "Text",
 CellChangeTimes->{{3.646480663005218*^9, 3.646480704157754*^9}, {
