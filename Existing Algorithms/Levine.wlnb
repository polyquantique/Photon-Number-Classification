   3.665788446546926*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getAlphaByClustPair", "[", 
   RowBox[{"dat_", ",", "idealTraceList_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "iObsTwoMinIndex", ",", "iObsTwoMinIndexGroup", ",", "msDev", ",", 
      "nClustPair", ",", "nObs", ",", "twoMinIndex", ",", 
      "twoMinIndexIObsList"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nObs", "=", 
      RowBox[{"Length", "[", "dat", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"msDev", "=", 
      RowBox[{"getSquareDiff", "[", 
       RowBox[{"dat", ",", "idealTraceList"}], "]"}]}], ";", 
     RowBox[{"twoMinIndex", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"twoMin", ",", " ", "msDev"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"iObsTwoMinIndex", "=", 
      RowBox[{"pair", "[", 
       RowBox[{
        RowBox[{"Range", "[", "nObs", "]"}], ",", "twoMinIndex"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"iObsTwoMinIndexGroup", "=", 
      RowBox[{"GatherBy", "[", 
       RowBox[{"iObsTwoMinIndex", ",", 
        RowBox[{
         RowBox[{"Last", "[", "#", "]"}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"twoMinIndexIObsList", "=", 
      RowBox[{"Sort", "[", 
       RowBox[{"Map", "[", 
        RowBox[{"groupCommon", ",", "iObsTwoMinIndexGroup"}], "]"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"nClustPair", "=", 
      RowBox[{"Length", "[", "twoMinIndexIObsList", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"twoMinIndexIObsList", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iClustPair", ",", "1"}], " ", "\[RightDoubleBracket]"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"twoMinIndexIObsList", "\[LeftDoubleBracket]", " ", 
          RowBox[{"iClustPair", ",", "2"}], " ", "\[RightDoubleBracket]"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"getAlpha", "[", 
          RowBox[{
           RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
            RowBox[{"twoMinIndexIObsList", "\[LeftDoubleBracket]", " ", 
             RowBox[{"iClustPair", ",", "2"}], " ", "\[RightDoubleBracket]"}],
             " ", "\[RightDoubleBracket]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"idealTraceList", "\[LeftDoubleBracket]", " ", 
            RowBox[{"twoMinIndexIObsList", "\[LeftDoubleBracket]", " ", 
             RowBox[{"iClustPair", ",", "1"}], " ", "\[RightDoubleBracket]"}],
             " ", "\[RightDoubleBracket]"}]}], "]"}]}], "\[IndentingNewLine]",
         "}"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"iClustPair", ",", "nClustPair"}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.646133844100559*^9, 3.646133849373359*^9}, {
   3.646135700609959*^9, 3.646135896062359*^9}, 3.646136109407959*^9, {
   3.646146138254768*^9, 3.646146138301568*^9}, {3.646147142557168*^9, 
   3.646147142635168*^9}, {3.646147185581968*^9, 3.6461471856443677`*^9}, {
   3.6461498936647677`*^9, 3.6461498995771675`*^9}, {3.6461499366115675`*^9, 
   3.646149947765568*^9}, {3.646150026077568*^9, 3.646150038214368*^9}, {
   3.646150090536768*^9, 3.646150100349168*^9}, {3.6461504196579676`*^9, 
   3.646150431981968*^9}, {3.6461508231207676`*^9, 3.646150867346768*^9}, {
   3.6463933382643075`*^9, 3.6463933399666967`*^9}, {3.646393390835371*^9, 
   3.6463933951877427`*^9}, {3.646398853277399*^9, 3.6463988539637947`*^9}, {
   3.646398985032954*^9, 3.646399010543791*^9}, {3.6621298876536293`*^9, 
