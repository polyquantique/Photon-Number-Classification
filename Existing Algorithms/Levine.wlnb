         "\[RightDoubleBracket]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"iClust", ",", "nClust"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"clustMeanTrace", "=", 
