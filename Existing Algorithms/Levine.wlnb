Cell[TextData[{
 StyleBox["Figure ",
  FontWeight->"Bold"],
 StyleBox[
 CounterBox["NumberedFigure"],
  FontWeight->"Bold"],
 StyleBox[".",
  FontWeight->"Bold"],
 " (a) Optimized cluster mean waveforms for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["N", "-"], "=", "22.6"}], TraditionalForm]], "Math"],
 " (solid red) and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["N", "-"], "=", "31.6"}], TraditionalForm]], "Math"],
 " (dotted blue). (b) Optimized effective photon numbers for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["N", "-"], "=", "2.00"}], TraditionalForm]], "Math"],
 " (black) and integer-centered Gaussians fitted to the data (red)."
}], "NumberedFigureCaption",
 CellChangeTimes->{{3.6476096689885783`*^9, 3.6476098155382395`*^9}, {
  3.6476105557030897`*^9, 3.647610574603568*^9}, {3.647610708097763*^9, 
  3.647610709441763*^9}, {3.662129401132656*^9, 3.6621294027086487`*^9}, {
  3.6621294656454697`*^9, 3.662129501843954*^9}},
 CellTags->"FigPerf1"],

Cell[TextData[{
 "Figure ",
 
 CounterBox["NumberedFigure", "FigPerf2"],
 " shows a similar comb structure for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["N", "-"], "=", "22.6"}], TraditionalForm]], "Math"],
 " for both the dot product method and PIKA. As the photon number ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]], "Math"],
 " increases, the teeth of the comb grow less defined\[LongDash]that is, the \
peak visibility ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"max", "-", "min"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"max", "+", "min"}], ")"}]}], TraditionalForm]], "Math"],
 " falls, and with it the photon-resolving capability. Figure ",
 
 CounterBox["NumberedFigure", "FigPerf3"],
 " shows this drop in visibility. The power of PIKA is that it retains \
nonzero visibility (i.e. the uncertainty does not include 0) through ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "23"}], TraditionalForm]], "Math"],
 ", whereas the dot product method alone loses it after ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "19"}], TraditionalForm]], "Math"],
 ". PIKA has been used to explore the regime just beyond the loss of peak \
visibility [",
 
 CounterBox["Reference", "Photon"],
 "]."
}], "Text",
 CellChangeTimes->{{3.647611553665763*^9, 3.647611631852763*^9}, {
   3.6476118075727634`*^9, 3.647611814642763*^9}, {3.647611848227763*^9, 
   3.6476118597597632`*^9}, {3.6479459556628537`*^9, 
   3.6479460247824106`*^9}, {3.6479461682634563`*^9, 3.647946170054845*^9}, 
   3.6479462288778687`*^9, 3.650023294306601*^9, {3.661467314657917*^9, 
   3.661467322065143*^9}, {3.665784789579075*^9, 3.665784797864504*^9}, 
   3.6657855255496798`*^9, {3.665787483316081*^9, 3.665787486389077*^9}, {
   3.6673077506504393`*^9, 3.667307763373618*^9}}],

