nj0G0VphX0WqgfSLlJdSILpEMnr6fp3XjnryVrNAtAXz1psgmrkZQrM4WbAc
ANLnPmSxg+hfk08LgOjOgHxBEG1exyX51eO145cyXjD9oex9NIi2UvwApn3+
fMgE0a+PrigA0Smr7TsUPYHy106A6Qkstg/CgPQlhuCHIJpl5eZPIHrJ232f
QfSqC1c4w4F0wIEkLhAtLXBDBUTf6A5QBdGvmC4qa3oB9Z2RUwXRAFfo3a0=

  "]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ". Optimization Loop (Loop 2)"
}], "Subsection",
 CellChangeTimes->{{3.6452029094157333`*^9, 3.6452029121145334`*^9}, {
   3.645271921028192*^9, 3.6452719980921917`*^9}, 3.64527902714744*^9, {
   3.6452799846352396`*^9, 3.64528003630644*^9}, 3.64587103514243*^9, 
   3.64587111072443*^9, 3.64587272909583*^9, 3.6461333310009594`*^9, 
   3.646134375748559*^9, 3.6464103464055214`*^9, {3.661518761629552*^9, 
   3.661518765179665*^9}, {3.661520514663746*^9, 3.661520530711465*^9}, {
   3.6621293524630117`*^9, 3.662129352515564*^9}, 3.6622233713609447`*^9},
 CellTags->"ImplOptim"],

Cell[TextData[{
 "Loop 2, nested inside Loop 1, begins here. Its index, ",
 Cell[BoxData["iCool"], "MCode"],
 ", specifies how many rounds of optimization have already passed. The \
optimization loop runs for a preset number of iterations (given by ",
 Cell[BoxData["nCool"], "MCode"],
 " in the initial setup), the first ",
 Cell[BoxData["nGreedy"], "MCode"],
 " of which employs the greedy algorithm. The remaining iterations are run \
with the simulated annealing algorithm. By default, ",
 Cell[BoxData["nGreedy"], "MCode"],
 " is equal to ",
 Cell[BoxData["nCool"], "MCode"],
 ", so all of the iterations use the greedy algorithm (i.e. simulated \
annealing is never used)."
}], "Text",
 CellChangeTimes->{{3.645794958630195*^9, 3.645794962483395*^9}, {
  3.645795089857395*^9, 3.645795134956995*^9}, {3.645795167670195*^9, 
  3.6457951985113955`*^9}, {3.645795366180195*^9, 3.645795522180195*^9}, {
  3.6457955550337954`*^9, 3.645795693889395*^9}, {3.6478737668855205`*^9, 
  3.6478737809480305`*^9}, {3.6478828253542366`*^9, 3.6478828258378334`*^9}, {
  3.6657859218224993`*^9, 3.665785931988181*^9}, {3.6671415846823874`*^9, 
  3.66714160290827*^9}}],

Cell[TextData[{
 "The bulk of Loop 2 is contained in the nested Loop 3, the waveform transfer \
loop that passes over all of the observations in ",
 Cell[BoxData["dat"], "MCode"],
 " and decides whether to move them to neighboring clusters. Before starting \
Loop 3, we randomly order the indices in ",
 Cell[BoxData["dat"], "MCode"],
 " of the waveforms upon which Loop 3 is to operate, so that the original \
ordering of the data does not bias the algorithm in any systematic way."
}], "Text",
 CellChangeTimes->{{3.6457959318161955`*^9, 3.6457960579109955`*^9}, 
   3.645796104196195*^9, {3.6457969540997953`*^9, 3.645796963506595*^9}, {
   3.6457969940513954`*^9, 3.645797021788195*^9}, {3.6457971706805954`*^9, 
   3.6457971749081955`*^9}, {3.645797223049795*^9, 3.645797268866995*^9}, {
   3.64587317667123*^9, 3.64587317790363*^9}, {3.667141616643034*^9, 
   3.667141628648859*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"prepareSubLoop", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"iObsAll", "=", 
     RowBox[{"RandomSample", "[", 
      RowBox[{"Range", "[", "nObs", "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<Detailed Log\>\"", ",", "\"\<Mean \>\"", 
      ",", "iNPhotonAvgList", ",", "\"\<, round \>\"", ",", "iCool", ",", 
      "\[IndentingNewLine]", "\"\<: kMove \>\"", ",", "kMove", ",", 
      "\"\< logLikeProb \>\"", ",", "logLikeProb", ",", 
      "\[IndentingNewLine]", "\"\< objFtn \>\"", ",", "objFtn", ",", 
      "\"\< TimeUsed \>\"", ",", 
      RowBox[{
       RowBox[{"TimeUsed", "[", "]"}], "-", "tStart"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.6451839152948556`*^9, 3.645184123921775*^9}, {
   3.6451958235498905`*^9, 3.6451958293062906`*^9}, {3.645796272005395*^9, 
   3.645796274189395*^9}, {3.6458730616172295`*^9, 3.64587308740503*^9}, 
   3.6461461374435678`*^9, 3.646147141667968*^9, 3.6461471848487678`*^9, {
   3.6461498928223677`*^9, 3.6461498987035675`*^9}, {3.6461499358159676`*^9, 
   3.646149946891968*^9}, {3.6461500253911676`*^9, 3.6461500374655676`*^9}, {
   3.6461500891327677`*^9, 3.646150098695568*^9}, {3.646150418971568*^9, 
   3.6461504312175674`*^9}, {3.646150823682368*^9, 3.6461508712935677`*^9}, {
   3.647339714319209*^9, 3.647339729816306*^9}, {3.6473402453629932`*^9, 
   3.647340248030576*^9}, {3.6473405777892585`*^9, 3.6473406033574944`*^9}, {
   3.6473407233831253`*^9, 3.647340780073162*^9}, {3.6473523959411044`*^9, 
   3.6473524033042574`*^9}, {3.6473526798164854`*^9, 3.647352727789178*^9}, 
   3.6473552587423563`*^9, 3.6478773998723373`*^9, 3.6621298875084867`*^9, {
   3.662130069745887*^9, 3.66213007763382*^9}, {3.6622203675236597`*^9, 
   3.662220398473695*^9}, 3.662220433847712*^9, 3.662329759085538*^9, {
   3.662329939629094*^9, 3.662329939974463*^9}, {3.6652464794372883`*^9, 
   3.665246480904332*^9}}],

Cell[CellGroupData[{

Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 
 CounterBox["Subsubsection"],
 ". Waveform Transfer Loop (Loop 3)"
}], "Subsubsection",
 CellChangeTimes->{{3.645202943064934*^9, 3.6452029691793337`*^9}, {
   3.6452029992093334`*^9, 3.6452030232021337`*^9}, {3.645271938968192*^9, 
   3.6452719428681917`*^9}, {3.645271974317792*^9, 3.645271975456592*^9}, 
   3.645272057777792*^9, {3.64527902193704*^9, 3.6452790476458397`*^9}, 
   3.64587136620563*^9, {3.64587277374703*^9, 3.64587279402703*^9}, 
   3.64588299475443*^9, {3.6458830309620295`*^9, 3.6458830314924297`*^9}, {
   3.646133333964959*^9, 3.6461333709525595`*^9}, {3.66151877233171*^9, 
   3.661518781723591*^9}, 3.6622233762011623`*^9}],

Cell[TextData[{
 "The index of Loop 3, ",
 Cell[BoxData["jObs"], "MCode"],
 ", is the current position of the loop in ",
 Cell[BoxData["iObsAll"], "MCode"],
 ", the random permutation of the observation indices. ",
 Cell[BoxData["iObs"], "MCode"],
 " is then set to the index of the observation itself, rather than the index \
of the index. ",
 Cell[BoxData["iClust"], "MCode"],
 " is the index of the associated cluster. If the cluster has only one \
observation then we skip to the next iteration of Loop 3, since no cluster is \
allowed to become empty. We then randomly pick a cluster ",
 Cell[BoxData["jClust"], "MCode"],
 " from the list of neighbors, and we consider moving the waveform from its \
current cluster to the new one."
}], "Text",
 CellChangeTimes->{{3.645809202524995*^9, 3.645809334064195*^9}, {
  3.645809372159395*^9, 3.645809462888995*^9}, {3.645809532121795*^9, 
  3.6458096111981955`*^9}, {3.64586779933343*^9, 3.64586788386983*^9}, {
  3.64586792561543*^9, 3.6458679443666296`*^9}, {3.667141638565714*^9, 
  3.6671416598590727`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getClusterAndNeighbors", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"iObs", "=", 
     RowBox[{
     "iObsAll", "\[LeftDoubleBracket]", "jObs", "\[RightDoubleBracket]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"iClust", "=", 
     RowBox[{
     "iClustOfObs", " ", "\[LeftDoubleBracket]", " ", "iObs", " ", 
      "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
       "nOfClust", "\[LeftDoubleBracket]", "iClust", 
        "\[RightDoubleBracket]"}], "<=", " ", "1"}], ",", 
      RowBox[{"Continue", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"neighbor", "=", 
     RowBox[{
     "neighborOfClust", "\[LeftDoubleBracket]", " ", "iClust", " ", 
      "\[RightDoubleBracket]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"jClust", "=", 
     RowBox[{"neighbor", "\[LeftDoubleBracket]", " ", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Length", "[", "neighbor", "]"}]}], "}"}], "]"}], " ", 
      "\[RightDoubleBracket]"}]}]}], "\[IndentingNewLine]", ")"}]}]], "Input",
