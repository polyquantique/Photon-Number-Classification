Cell[TextData[{
 Cell[BoxData["getDotToIdeal"], "MCode"],
 " takes a single trace or a set of traces and finds its or their dot product \
with an ideal trace, normalized by the square of the ideal trace\
\[CloseCurlyQuote]s magnitude. If the function is given a single trace as its \
first argument, the operation in the numerator is a simple dot product; if it \
is given a list of traces, the operation is matrix-vector multiplication, \
which returns a list of dot products."
}], "Text",
 CellChangeTimes->{{3.6463903572383385`*^9, 3.6463903574567375`*^9}, {
  3.646390535627395*^9, 3.6463907008647366`*^9}, {3.6463907312613416`*^9, 
  3.646390735056117*^9}, {3.667142043476654*^9, 3.6671420434794483`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"getDotToIdeal", "[", 
   RowBox[{"traces_", ",", "idealTrace_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{"traces", ".", "idealTrace"}], 
   RowBox[{"idealTrace", ".", "idealTrace"}]]}]], "Input",
 CellChangeTimes->{{3.6463903663194804`*^9, 3.646390424229709*^9}, {
  3.6627618947907343`*^9, 3.6627618956061487`*^9}, {3.662762168350986*^9, 
  3.662762169377021*^9}}],

