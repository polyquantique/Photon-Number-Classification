Cell[BoxData[
 RowBox[{
  RowBox[{"graphProbabilityDistribution", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p10", "=", 
     RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"pair", "[", 
          RowBox[{"nPhotonOfClust", ",", "freqOld"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"pair", "[", 
          RowBox[{"nPhotonOfClust", ",", "freqNew"}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"pair", "[", 
          RowBox[{
           RowBox[{"prob", "\[LeftDoubleBracket]", 
            RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
           RowBox[{
            RowBox[{"prob", "\[LeftDoubleBracket]", 
             RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], "*", 
            "nObs"}]}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Green", ",", "Red", ",", "Black"}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Joined", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"False", ",", "False", ",", "True"}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PlotLabel", "\[Rule]", 
        RowBox[{
        "\"\<Initial (green) and final (red) cluster frequencies; \>\"", "<>",
          "probDistName", "<>", "\"\< distribution (black)\>\""}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<Number of photons n\>\"", ",", "\"\<Frequencies\>\""}], 
         "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "\[Rule]", "outputImageSize"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"outputAdd", "[", 
     RowBox[{"p10", ",", "iNPhotonAvgList", ",", "probDistName"}], "]"}], 
    ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
