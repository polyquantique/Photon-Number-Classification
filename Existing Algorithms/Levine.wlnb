Cell[TextData[{
 
 CounterBox["Section"],
 ".",
 
 CounterBox["Subsection"],
 ".",
 
 CounterBox["Subsubsection"],
 ". Annealing Update and End of Loop 2"
}], "Subsubsection",
 CellChangeTimes->{{3.6452032108857336`*^9, 3.6452032153503337`*^9}, {
