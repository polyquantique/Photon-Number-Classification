Cell[BoxData[
 RowBox[{
  RowBox[{"optionallyRejectBackgroundTraces", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"backgroundReject", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"iObsKeep", "=", 
        RowBox[{"getIObsKeep", "[", 
         RowBox[{
         "dat", ",", "peakPosCut", ",", "peakValCut", ",", "peakNumCut"}], 
         "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"iObsDrop", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"Length", "[", "dat", "]"}], "]"}], ",", "iObsKeep"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"p1", "=", 
        RowBox[{"ListPlot", "[", 
         RowBox[{
          RowBox[{"dat", "\[LeftDoubleBracket]", " ", 
           RowBox[{"randomSample", "[", 
            RowBox[{"iObsDrop", ",", "mSample"}], "]"}], " ", 
           "\[RightDoubleBracket]"}], ",", 
          RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
          RowBox[{"FrameLabel", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
            "\"\<t (shorter input units)\>\"", ",", 
             "\"\<V (input units)\>\""}], "}"}]}], ",", 
          RowBox[{"PlotLabel", "\[Rule]", 
           RowBox[{
            RowBox[{"ToString", "[", "mSample", "]"}], "<>", 
