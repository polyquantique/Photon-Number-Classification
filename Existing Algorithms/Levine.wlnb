Cell[BoxData[
 RowBox[{
  RowBox[{"findInitialObjectiveFunction", "[", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sqDevOfClust", "=", 
     RowBox[{"getSqDevOfClust", "[", 
      RowBox[{"dat", ",", "iObsOfClust", ",", "clustMeanTrace"}], "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"nOfClust", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"Length", ",", "iObsOfClust"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"logLikeProb", "=", 
     RowBox[{"probComboLogLikelihood", "[", 
      RowBox[{"nPhotonOfClust", ",", "nOfClust", ",", "nPhotonAvg"}], "]"}]}],
     ";", "\[IndentingNewLine]", 
    RowBox[{"sigmaObjFtn", "=", 
     RowBox[{
      SqrtBox[
       FractionBox[
        RowBox[{"Total", "[", "sqDevOfClust", "]"}], "nObs"]], "//", "N"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"print", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<PIKA: sigmaObjFtn \>\"", ",", 
      "sigmaObjFtn"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"sigmaObjFtn", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"sigmaObjFtn", ",", 
       RowBox[{"{", "nClust", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"objFtn", "=", 
     RowBox[{"getObjFtn", "[", 
      RowBox[{"sqDevOfClust", ",", "sigmaObjFtn", ",", "logLikeProb"}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"printSp", "[", 
     RowBox[{
     "iNPhotonAvgList", ",", "\"\<\>\"", ",", 
      "\"\<Initial objective function: \>\"", ",", "objFtn"}], "]"}], ";"}], 
   "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.645182809588396*^9, 3.645182813145173*^9}, {
