   "value": "getDatPeakLocVal [datPeakLoc_, dat_] :=\r\n    Table[\r\n        pair[datPeakLoc[iObs], dat[ iObs, datPeakLoc[iObs]]],\r\n        {iObs, Length[dat]}]",
