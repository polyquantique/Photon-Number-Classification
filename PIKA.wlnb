  {
   "kind": 2,
   "value": "comboLogLikelihood[freqList_] :=\r\n    LogGamma[Total[freqList] +1.] -\r\n        Total[LogGamma[freqList +1.]]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "poissonLogLikelihood[nList_, freqList_, mu_] :=\r\n    -mu * Total[freqList] + nList.freqlList * Log[mu] -\r\n        freqList.LogGamma[nList + 1.]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "probComboLogLikelihood[nList_, freqList_, mu_] :=\r\n    poissonLogLikelihood[nList, freqList, mu] +\r\n        comboLogLikelihood[freqList]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "poisson[mu_, nSigma_] := \r\n    Module[\r\n        {sigma, tab},\r\n        sigma = Sqrt[mu];\r\n        tab = Table[{n, (N[Exp[-mu]] +mu”n) /n!},\r\n            {n, Max [Floor[mu- sigma * nSigma], 0],\r\n            Ceiling [mu + sigma x nSigma] }];\r\n        Map[ {First [#], Last[#] / Total [tab[[All, 2]]]} &, tab]\r\n    ]",
   "languageId": "wolfram",
