   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "hanningFilter[n_] := Chop[Cos[(N[Pi] * Range[0, n-1])/n]^2]\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "readTESandFilter[iNPhoton_, iDataSet_, nTime_, fileInfo_] :=\r\n    Module[{datUse, dat, datFilt, nTimeUse, nSamplePerTrace, nTracePerFile, nFile},\r\n        {nsamplePerTrace, nTracePerFile} = fileInfo[{2, 31}];\r\n    nFile = Length[iDatasSet];\r\n    datUse = ConstantArray[{}, nTracePerFile * nFile];\r\n    Do[\r\n        dat = readTES[iNPhoton, {iDataSet[iFile]}, fileInfo];\r\n        hanning = hanningFilter[Last[Dimensions [dat]] / 2];\r\n        datFilt = Map[applyFiltershort[#, hanning] &, dat];\r\n        nTimeUse = Min[nTime, Length [hanning]];\r\n        datUse[(iFile - 1) * nTracePerFile +1 ;; \r\n            iFile * nTracePerFile] = datFilt[All, Range [nTimeUse]],\r\n        {iFile, nFile}\r\n    ];\r\n    datUse -= Mean[datUse[All, 10]] \r\n    (*zeroes the signal at an early point,\r\n    before any photons have arrived *)\r\n]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
