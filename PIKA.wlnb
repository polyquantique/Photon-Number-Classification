{
 "cells": [
  {
   "kind": 1,
   "value": "### 3 Terminology and Main Loop (runPika)",
   "languageId": "markdown",
   "outputs": [],
   "metadata": {
    "attachments": {}
   },
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "runPIKA[] := (\r\n    initialsetup[];\r\n    readAndFilterData[];\r\n    optionallyRejectBackgroundTraces[];\r\n    graphGlobalMeanTrace[];\r\n\r\n    findDotProductEffectivePhotonNumbers[];\r\n    Do[ (* Loop 1 *)\r\n        createInitialclusters[];\r\n        graphsSampleMiddleClusters[];\r\n        graphClusterMeans[];\r\n        findInitialObjectiveFunction[];\r\n        graphClusterDeviationsFromMean[];\r\n        prepareOptimizationLoop[];\r\n        Do[ (* Loop 2 *)\r\n            preparesubLoop[];\r\n            Do[ (* Loop 3 *)\r\n                getClusterAndNeighbors[];\r\n                updateRelevantDeviations[];\r\n                findCchangeInObjectiveFunction[];\r\n                decideWhetherToMove[];\r\n                updateIfMoving[];\r\n                , {jobs, nobs}\r\n\r\n            ] (* End Loop 3 *)\r\n            updateAnnealingTemperature[];\r\n            , {iCcool, nCool}\r\n\r\n        ]; (* End Loop 2 *)\r\n        prepareAnalysisAndoutput[];\r\n        graphNewSampleMiddleClusters[];\r\n        graphNewClusterMeans[];\r\n        graphProbabilityDistribution[];\r\n        graphNewClusterToMeanDeviations[];\r\n        graphNewMeanToMeanDeviations[];\r\n        graphNewEf fectivePhotonNumber[];\r\n        , {iNPhotonAvgList, Length[nPhotonAvgList]}\r\n    ] (* End Loop 1 *)\r\n    showOutput []\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1689003611240,
     "endTime": 1689003611346
    },
    "executionOrder": 1,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "initialsetup[] := (\r\n\r\n    SetOptions [$Output, PageWidth -> 110];\r\n    SetOptions[ListPlot, Joined -> True, Frame -> True, PlotRange —> All];\r\n    SetOptions[ListLogPlot, Joined -> True, Frame -> True, PlotRange -> All];\r\n    tstart = TimeUsed[];\r\n\r\n    If [useInputFile, Get [pikaInput]]; (* user defined override x *)\r\n    tAnnealOrig = tAnneal;\r\n\r\n    Print [\"Options read; now running\"];\r\n\r\n    fileInfo = {{partialFilePath, fileExt}, nSamplePerTrace, nTracePerFile};\r\n\r\n    outputCreateTabs[Length [nPhotonAvgList]];\r\n    print[0, \"dataset number (iNPhoton): \", iNPhoton];\r\n    print[0, \"file range (iDataSet): \", iDataSet];\r\n\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "readAndFilterData[] := (\r\n\r\n    print[0, \"PIKA: about to read data. iNPhoton \", iNPhoton];\r\n    dat = readTEsandFilter[iNPhoton, iDataSet, nTime, fileInfo];\r\n    print [0, \"PIKA: {nObs,nTime} \", Dimensions[dat]];\r\n\r\n    If [nDatUse > 0,\r\n        dat = randomSample[dat, nDatUse];\r\n        print[0, \"PIKA: nDatUse ... reduced to {nObs, nTime} \", Dimensions[dat]];\r\n    ];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "optionallyRejectBackgroundTraces[] := (\r\n\r\n    If [backgroundReject,\r\n        iobsKeep = getIObsKeep[dat, peakPosCut, peakValcut, peakNumCut];\r\n\r\n        iobsDrop = Complement [Range [Length[dat]], iObsKeep];\r\n        pl = ListPlot[dat[randomSample[iObsDrop, mSample]], Plotstyle -> Blue,\r\n\r\n            FrameLabel -> {\"t (shorter input units)\", \"V (input units) \"},\r\n            PlotLabel -> ToString[mSample] <> \"rejected traces\",\r\n            ImageSize -> outputImageSize\r\n        ];\r\n\r\n        outputAdd[pl, 0, \"\"];\r\n\r\n        dat = dat[iObsKeep];\r\n        iobsDrop =. ; (* after dat is overwritten these index sets lose their meaning *)\r\n        iobsKeep =.\r\n    ];\r\n\r\n    nObs = Length [dat];\r\n    print [0, \"PIKA: nObs \", nObs, \" traces selected\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphGlobalMeanTrace[] := (\r\n    meanTrace = getMeanOfEachTime[dat];\r\n    p2a = ListPlot[randomSample[dat, mSample], Plotstyle -> Black];\r\n    p2b = ListPlot[meanTrace, PlotStyle -> Red];\r\n    p2 = show[p2a, p2b, DisplayFunction -> $DisplayFunction,\r\n        FrameLabel -> {\"Time (input units)\", \"Voltage (input units)\"},\r\n        PlotLabel -> ToString[mSample] <> \" accepted traces (black) and mean trace (red)\",\r\n        ImageSize -> outputImagesSize];\r\n    Export [\"p2.pdf\", p2];\r\n    outputAdd[p2, 0, \"\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "findDotProductEffectivePhotonNumbers[] := (\r\n    nPhotonAvg = First[nPhotonAvgList];\r\n    nPhotonEff = nPhotonAvg * getDotToIdeal[dat, meanTrace];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "createInitialClusters[] := (\r\n    nPhotonAvg = nPhotonAvgList[iNPhotonAvgList];\r\n    {prob, nPhotonofClust, iObsOfClust, clustMeanTrace} =\r\n        groupProbability[dat, nPhotonAvg, nPhotonEff, nsSigma];\r\n    nClust = Length[clustMeanTrace];\r\n    print[iNPhotonAvgList, \"PIKA: nClust \", nClust];\r\n    printsSp[iNPhotonAvgList, \"Initial mean photon number: \", nPhotonAvg];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphsampleMiddleClusters[] := (\r\n    pda = ListPlot[randomSample[dat[iobsofCclust[Round[nClust /2] -1]], mSample],\r\n        Plotstyle -> Red, DisplayFunction —> Identity];\r\n    pdb = ListPlot[randomSample[dat[iobsofClust[Round[nClust /2] ]], mSample],\r\n        Plotstyle -> Green, DisplayFunction ->Identity];\r\n    pdc = ListPlot[randomSample[dat[iobsofCclust[Round[nClust /2] +1]], mSample],\r\n        Plotstyle -> Blue, DisplayFunction -> Identity];\r\n    p4 = Show [pdc, pdb, pda,\r\n        FrameLabel -> {\"Time (input units)\", \"Voltage (input units)\"},\r\n        PlotLabel -> ToString[mSample] <> \" traces for three clusters n=\" <>\r\n            ToString[nPhotonOfClust [Round [nClust / 2] - 1]] <> \" (red) to n=\"<>\r\n            ToString [nPhotonOfClust [Round [nClust / 2] + 1]] <> \" (blue) \",\r\n        DisplayFunction —> $DisplayFunction,\r\n        ImageSize -> outputImagesSize];\r\n    printsSp[iNPhotonAvgList, \"Sample Traces\", \"Before optimization:\"];\r\n    outputAdd[p4, iNPhotonAvgList, \"Sample Traces\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphClusterMeans[] := (\r\n    p6 = ListPlot [clustMeanTrace,\r\n        Plotstyle -> Green,\r\n        PlotLabel -> \"Cluster mean traces\",\r\n        FrameLabel -> {\"Time (input units)\", \"Voltage (input units)\"},\r\n        ImageSize -> outputImagesSize];\r\n    printsSp[iNPhotonAvgList, \"Cluster Means\", \"Before optimization:\"];\r\n    outputAdd[p6, iNPhotonAvgList, \"Cluster Means\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "findInitialObjectiveFunction[] := (\r\n    sqDevOfClust = getSqDevOfClust [dat, iObsOfClust, clustMeanTrace];\r\n    nofClust = Map[Length, iObsOfClust];\r\n    logLikeProb = probComboLogLikelihocod[nPhotonOfClust, nofClust, nPhotonAvg];\r\n\r\n    sigmaObjFtn = Sqrt[Total[sqDevOfClust] / nObs] // N;\r\n\r\n    print [iNPhotonAvgList, \"PIKA: sigmaObjFtn \", sigmaObjFtn];\r\n    sigmaObjFtn = Table[sigmaObjFtn, {nClust}];\r\n\r\n    objFtn = getObjFtn[sqDevOofClust, sigmaObjFtn, logLikeProb] ;\r\n    printsp[iNPhotonAvgList, \"Initial objective function: \", objFtn];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphClusterDeviationsFromMean[] := (\r\n    p7 = ListPlot[pair[nPhotonotciust, Sqrt[sqDevOfClust / nofClust]],\r\n\r\n    AxesOrigin -> {\r\n        Floor[Min[nPhotonofcClust], 10],\r\n        Floor[Min[Sqrt[sqDevOfClust / nofClust]], 10]\r\n    }\r\n\r\n    Joined -> False,\r\n    Plotstyle -> Pointsize [0.015],\r\n    FrameLabel -> {\"Number of photons n\", \"RMS deviation (Voltage input units)\"},\r\n    PlotLabel -> \"RMS deviations of clusters to their means\", \r\n    ImageSize -> outputImagesSize\r\n    ];\r\n\r\n    printsSp[iNPhotonAvgList, \"Cluster Deviations\", \"Before optimization:\"];\r\n    outputAdd[p7, iNPhotonAvgList, \"Cluster Deviations\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "prepareOptimizationLoop[] := (\r\n\r\n    If [Sort[Flatten[iObsOfClust]] != Range[Length[dat]],\r\n        print [iNPhotonAvgList,\r\n            \"PIKA: WARNING: iObsOfClust does not map each observation to a cluster\"]\r\n    ];\r\n    iclustofobs = getIClustOfObs[iObsOfClust];\r\n    If [Min[iclustOofObs] <= 0,\r\n        print [iNPhotonAvgList,\r\n            \"PIKA: WARNING: iClustOfObs does not map each observation to a cluster\"]\r\n    ];\r\n\r\n    neighborofClust = Transpose[{Range[nClust] -1, Range [nClust] +1}];\r\n    neighborofClust[1] = Drop[neighborofclust[1], 1];\r\n    neighborofClust[-1] = Drop[neighborofCclust[-1], -1];\r\n\r\n    kMove = 0; (* count of moves made *)\r\n    birthofclust = Table[0, {nClust}];\r\n    birthofobsClust = Table[-1, {nObs}, {nClust}]; (* older than birthofClust *)\r\n    sqDevOfObsClust = birthofobsClust (* dummy array of correct shape *)\r\n\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "preparesSubLoop[] := (\r\n    iobsAll = RandomSample[Range [nObs]];\r\n    printsSp[iNPhotonAvgList, \"Detailed Log\", \"Mean \", iNPhotonAvgList, \", round \", iCool,\r\n        \": kMove \", kMove, \" logLikeProb \", logLikeProb,\r\n        \" objFtn \", objFtn, \" TimeUsed \", TimeUsed[] - tsStart];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "getClusterAndNeighbors[] := (\r\n    iobs = iObsAll[joObs];\r\n    iclust = iClustofobs [i0bs];\r\n    If [nOfClust[iClust] <= 1, Continue[]];\r\n        neighbor = neighborofClust[iClust];\r\n    jClust = neighbor[RandomInteger[{l, Length[neighbor]}]]\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "updateRelevantDeviations[] := (\r\n    If[birthofObsClust[iObs, iClust] < birthofClust[iClust],\r\n        sqDevOfObsClust[iObs, iclust] = meanSquare[dat[iObs] - clustMeanTrace[iClust]];\r\n        birthofobsClust[iobs, iClust] = kMove\r\n    ];\r\n    If[birthofObsClust[iObs, jClust] < birthofClust[jClust],\r\n        sqDevOfObsClust[iObs, jClust] = meanSquare[dat[iObs] - clustMeanTrace[jClust]];\r\n        birthofobsClust[iobs, jClust] = kMove\r\n    ];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "findchangeInObjectiveFunction[] := (\r\n\r\n    deltal = deltaKMeansDel [nOfClust[iClust], sgDevOfObsClust[iObs, iClust]];\r\n    deltaJd = deltaKMeansAdd[nofClust[jClust], sgDevOfObsClust[iObs, jClust]];\r\n\r\n    deltaKMeansScaled = deltaJ / 2 * sigmaObjFtn[jclust]^2 - deltal / 2 * sigmaObjFtn[iclust]^2\r\n\r\n    deltaProb = If [jClust < iClust,\r\n        deltaPoissonDn[nPhotonOfClust[iClust], nofClust[jClust], nofClust[iClust], nPhotonAvg],\r\n        deltaPoissonUp [nPhotonOfClust[iClust], nofClust[jClust], nofClust[iClust], nPhotonAvg]\r\n    ];\r\n    deltaObjFtn = deltaKMeansScaled - deltaProb;\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "decideWhetherToMove[] := (\r\n    acceptMove = If[deltaObjFtn < 0,\r\n        True,\r\n        If[iCool > nGreedy,\r\n            RandomReal[] < Exp[-deltaObjFtn / tAnneal],\r\n            False\r\n        ]\r\n    ]\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "updateIfMoving[] := (\r\n    If [acceptMove, (* transfer a trace from cluster i to cluster j *)\r\n        printsSp[iNPhotonAvgList, \"Detailed Log\",\" Round \", iCool, \", observation \",\r\n            iObs, \": deltaObjFtn \", deltaObjFtn, \" from \", iclust, \" to \", jClust];\r\n        kMove ++;\r\n        birthofclust[iCclust] = kMove;\r\n        clustMeanTrace[iClust] = newMeanTraceDel[nOfClust[iCclust], clustMeanTrace[iclust], dat[iobs]];\r\n        nofClust[iclust] --;\r\n        birthofclust[jClust] = kMove;\r\n        clustMeanTrace[jClust] = newMeanTraceAdd[nofclust[jClust], clustMeanTrace[jClust], dat[iobs]];\r\n        nofClust[jClust] ++;\r\n        iclustofobs[iObs] = jClust;\r\n        sqDevOfClust[iCclust] -= deltal;\r\n        sqDevOfClust[jCclust] += deltad;\r\n        objFtn += deltaObjFtn;\r\n    ]\r\n    )",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "updateAnnealingTemperature[] := (\r\n    tAnneal *= coolConst\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "prepareAnalysisAndoutput[] := (\r\n    print [iNPhotonAvgList, \"final \", nCool,\" kMove \", kMove, \" logLikeProb \", logLikeProb, \r\n        \" objFtn \", objFtn, \" TimeUsed \", TimeUsed[] - tStart];\r\n\r\n    iobsofclustNew = getIObsOfClust[iClustOfobs];\r\n    iobsofclust0old = i0ObsofClust; (* not changed since before the optimization loop *)\r\n    freqgNew = Map[Length, iObsOfClustNew];\r\n    freqold = Map[Length, iobsofclustold];\r\n    \r\n    nPhotonAvgNew = nPhotonofClust.fregNew / Total [freqNew] // Nj;\r\n\r\n\r\n    print[iNPhotonAvgList, \"nPhotonAvg \", nPhotonAvg,\" nPhotonAvgNew \", nPhotonAvgNew] ;\r\n    printsSp[iNPhotonAvgList, \"\",\"Optimized mean photon number: \", nPhotonAvgNew];\r\n    printsp[iNPhotonAvgList, \"\", \"Optimized objective function: \", objFtn];\r\n)\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphNewsampleMiddleClusters[] := (\r\n    p8a = ListPlot[\r\n        randomsSample[dat[i0bsOfClustNew[Round[nClust /2] -1]], mSample],\r\n        Plotstyle -> Red,\r\n        DisplayFunction -> Identity];\r\n    p8b = ListPlot[\r\n        randomsample[dat[i0bsOfClustNew[Round[nClust /2]]], mSample],\r\n        Plotstyle -> Green,\r\n        DisplayFunction -> Identity];\r\n    p8c = ListPlot[\r\n        randomsSample[dat[i0bsOfClustNew[Round[nClust /2] + 1]], mSample],\r\n        Plotstyle -> Blue,\r\n        DisplayFunction -> Identity];\r\n    p8 = show[p8c, p8b, p8a,\r\n        PlotLabel » ToString[mSample] <> \" traces for three clusters n=\" <>\r\n            ToString[nPhotonOfClust [Round [nClust / 2] - 1] ] <> \" (red) to n=\"<>\r\n            ToString [nPhotonOfClust [Round [nClust / 2] + 1]] <> \" (blue)\", \r\n        FrameLabel -> {\"Time (input units)\", \"Voltage (input units)\"},\r\n        DisplayFunction —> $DisplayFunction,\r\n        ImageSize -> outputImagesSize];\r\n    printsSp[iNPhotonAvgList, \"Sample Traces\", \"After optimization:\"];\r\n    outputAdd[p8, iNPhotonAvgList, \"Sample Traces\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphNewClusterMeans[] := (\r\n    clustFreq = pair[nPhotonofClust, freqNew];\r\n    printsSp[iNPhotonAvgList, \"Numerical Cluster Means\",\r\n        \"After optimization, {nPhotonAvgNew, clustFreq,clustMeanTrace}=\"];\r\n    outputAdd[{nPhotonAvgNew, clustFreq, clustMeanTrace}, iNPhotonAvgList, \r\n        \"Numerical Cluster Means\"];\r\n\r\n    p9a = ListPlot[clustMeanTrace, DisplayFunction -> Identity, Plotstyle -> Blue,\r\n        PlotLabel -> \"Optimized cluster mean traces\", ImageSize -> outputImagesSize];\r\n    p9 = show [p6, p9a, DisplayFunction -> $DisplayFunction,\r\n        PlotLabel -> \"Initial (green) and optimized (blue) cluster mean traces\"];\r\n    printsSp[iNPhotonAvgList, \"Cluster Means\", \"After optimization:\"];\r\n    outputAdd[p9a, iNPhotonAvgList, \"Cluster Means\"];\r\n    outputAdd[p9, iNPhotonAvgList, \"Cluster Means\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphProbabilityDistribution[] := (\r\n    pl0 = ListPlot[\r\n        {pair[nPhotonofcClust, freqold],\r\n         pair[nPhotonofCclust, freqNew],\r\n         pair[prob[All, 1], prob[All, 2] * nObs]},\r\n        Plotstyle -> {Green, Red, Black},\r\n        Joined -> {False, False, True},\r\n        PlotLabel -> \"Initial (green) and final (red) cluster frequencies; \" <> \r\n            probDistName <> \" distribution (black)\",\r\n        FrameLabel -> {\"Number of photons n\", \"Frequencies\"},\r\n        ImageSize -> outputImagesSize\r\n    ];\r\n    outputAdd[pl0, iNPhotonAvgList, probDistName];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphNewClusterToMeanDeviations[] := (\r\n    sgDevClustClust = getsgDevClustClust[dat, iObsOfClustNew, clustMeanTrace];\r\n    sqrtsdccDiag = Table[\r\n        {nPhotonofciust[iclust], Sqrt[sqDevClustClust[iClust, iClust]] }\r\n        {iclust, nclust}];\r\n    sqrtsdccUDiag = Table[\r\n        {nPhotonofciust[iclust], Sqrt[sqDevClustClust[iclust, iClust + 1]]}\r\n        {iclust, nClust - 1}];\r\n    sqrtsdcclDiag = Table[\r\n        {nPhotonofciust[iclust], Sqrt[sqDevCclustClust[iclust, iClust - 1]]}\r\n        {iclust, 2, nClust}];\r\n\r\n    pl3 = ListPlot[{sqrtsdccDiag, sqrtsdccLDiag, sqrtsdccUDiag}, PlotsStyle » {Red, Green, Blue},\r\n        Joined -> True, Frame - True,\r\n        PlotLabel -> \"RMS deviation of cluster traces to means of clusters: R: same; G: +1; B: -1\",\r\n        FrameLabel -> {\"Cluster\", \"RMS deviation (input voltage units)\"},\r\n        ImageSize -> outputImagesSize\r\n        ];\r\n    printsSp[iNPhotonAvgList, \"Cluster Deviations\", \"After optimization:\"];\r\n    outputAdd[pl3, iNPhotonAvgList, \"Cluster Deviations\"];\r\n)\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphNewMeanToMeanDeviations[] := (\r\n\r\n    sgqDevMeanMean = getSqDevClustObs [clustMeanTrace, clustMeanTrace];\r\n    sqrtsdmmDiagl = Table[{nPhotonofciust[iclust], Sqrt[sqDevMeanMean[iclust, iClust +1]]}\r\n        {iclust, nClust - 1}];\r\n    sqrtsdmmDiag2 = Table[{nPhotonofciust[iclust], Sqrt[sqDevMeanMean[iclust, iClust +2]]}\r\n        {iclust, nClust - 2}];\r\n    sqrtsdmmbDiag3 = Table[{nPhotonofciust[iclust], Sqrt[sqDevMeanMean[iClust, iClust + 3]]}\r\n        {iclust, nClust - 3}];\r\n\r\n    pl5 = ListPlot[{sqrtsdmmDiagl, sqrtsdmmDiag2, sqrtsdmmbiag3},\r\n        Plotstyle -> {Red, Green, Blue},\r\n        Joined -> True,\r\n        Frame -> True,\r\n        PlotLabel -> \"RMS deviation of cluster means to each other, R: +1 G: +2 B: +3\",\r\n        FrameLabel -> {\"Cluster\", \"RMS deviation (voltage input units)\"},\r\n        ImageSize -> outputImagesSize\r\n    ];\r\n    outputAdd[pl5, iNPhotonAvgList, \"Cluster Deviations\"];\r\n)\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "graphNewEffectivePhotonNumber[] := (\r\n    nPhotonEff = getNPhotonEff[dat, nPhotonOfClust, clustMeanTrace];\r\n    binEdge = Table[nEff,\r\n        {nEff,\r\n            (Floor[Min[nPhotonEff] / binFract] - 1/2) * binFract,\r\n            (Ceilling[Max[nPhotonEff] / binFract] + 1/2) * binFract,\r\n            binFract}\r\n    ];\r\n\r\n    binCnt = BinCounts[nPhotonEff,\r\n        {(Floor[Min[nPhotonEff] / binFract] - 1/2) * binFract,\r\n         (Ceilling[Max[nPhotonEff] / binFract] + 1/2) * binFract,\r\n        binFract}\r\n    ];\r\n\r\n    binCtr = (Most[binEdge] + Rest[binEdge]) / 2\r\n\r\n    paircnt = pair[binCtr, binCnt];\r\n    paircntPlot = pair[binCtr, Table[If[binCnt[i] < 0.5, 0.5, binCnt[i]], {i, Length[binCcnt]}]];\r\n\r\n    p17 = ListLogPlot[pairCntPlot,\r\n        PlotLabel -> \"Effective photon number histogram (bin width \" <>TextString[binFract] <>\")\",\r\n        FrameLabel -> {\"Photon number\", \"counts\"},\r\n        ImageSize -> outputImagesSize\r\n    ];\r\n    outputAdd[pl7, iNPhotonAvgList, \"Effective Photon Numbers\"];\r\n\r\n    printsSp[iNPhotonAvgList, \"Numerical n_eff Bin Counts\",\r\n        \"First element is bin center; second is bin count.\"];\r\n    outputAdd[pairCnt, iNPhotonAvgList, \"Numerical n_eff Bin Counts\"];\r\n    printsSp[iNPhotonAvgList, \"Numerical n_eff\", \"Effective photon number for each observation:\"];\r\n    outputAdd[nPhotonEff, iNPhotonAvgList, \"Numerical n_eff\"];\r\n)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "showOutput[] := (\r\n    tEnd = TimeUsed[];\r\n    print[0, \"PIKA: time used: \", tEnd-tStart, \" s\"];\r\n    outputsShowTabView[]\r\n)",
   "languageId": "wolfram",
   "outputs": [],
